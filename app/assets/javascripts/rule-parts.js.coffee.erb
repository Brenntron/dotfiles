$ ->

  new_index = 0

  $('.rule-parts-add-reference-btn').on "click", (event) ->
    reference_form = '<div class="col-xs-10"> <div class="form-inline reference-input-section"> ' +
        '<div class="form-group"> ' +
        '<%= select(:rule, :reference, ReferenceType.all.pluck(:name, :id), {}, class: 'api-data-input', data: {'index': 'new0'}, name: 'reference_type_id') %>' +
        ' </div>' +
        '<div class="form-group"> '+
        '<input name="reference_data" size="40" class="form-control select-sm code api-data-input" data-index="new' + new_index + '" type="text" placeholder="reference data" required="true">' +
        ' </div>' +
        '<div class="form-group"> <button class="btn select-sm btn-link remove-ref">remove</button> </div>' +
        ' </div> </div>'
    new_index = new_index + 1
    reference = $(this).parents('.references_add')
    $(reference_form).appendTo(reference)
