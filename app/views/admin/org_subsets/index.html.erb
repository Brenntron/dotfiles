<div style="margin-top:50px;">
  <%= link_to admin_roles_path, class: "btn btn-primary btn-xs" do %>
    <i class="glyphicon glyphicon glyphicon-sunglasses" title="Add">Roles</i>
  <% end %><br><br>
  <%= link_to new_admin_org_subset_path, class: "btn btn-primary btn-xs" do %>
    <i class="glyphicon glyphicon-plus" title="Add"> Add</i>
  <% end %>
  <table id="roles-table" class="table table-striped">
    <% @org_subsets.each do |subset| %>
      <tr>
        <td>
          <%= link_to edit_admin_org_subset_path(subset.id), class: "btn btn-primary btn-xs" do %>
            <i class="glyphicon glyphicon-pencil" title="Edit"></i>
          <% end %>
          <%= link_to admin_org_subset_path(subset.id), method: :delete, class: "btn btn-danger btn-xs", data: {confirm: 'Are you sure you want to Delete this?'} do %>
            <i class="glyphicon glyphicon-remove" title="Delete"></i>
          <% end %>
          <%= subset.name %>
        </td>

      </tr>
    <% end %>
  </table>
</div>
