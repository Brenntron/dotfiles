#hamburger-space

.admin-title
  %h1 Scheduled Tasks

#alert_message{:role => "alert"}
  = render "shared/flash_messages", flash: flash


#content.index-table
  .nav-collapse.collapse
  %ul.nav
    %li.dropdown
      %a.dropdown-toggle{:href => "#", "role" => "button", "data-toggle" => "dropdown", "data-target" => "#"}
        Select Task Type
        %b.caret
      %ul.dropdown-menu{"role" => "menu"}
        %li= link_to 'Start Import', run_once_admin_scheduled_tasks_path
  .row
    .col-xs-6
      %h3 Scheduled Tasks
      .row
        .col-xs-4
          %p updated_at
        .col-xs-2
          %p task_type
        .col-xs-2
          %p completed
        .col-xs-3
          %p result
    .col-xs-6
      <h3>Pending Jobs <small>If there are jobs here then the worker is not running.</small></h3>
      .row
        .col-xs-4
          %p run_at
        .col-xs-2
          %p attempts
        .col-xs-2
          %p priority

  .row
    .col-xs-6

      #scheduled-tasks-div
        - @scheduled_tasks.each do |s_t|
          .row
            .col-xs-4
              .updated_at= s_t.updated_at
            .col-xs-2
              .task_type=  s_t.task_type
            .col-xs-2
              .completed=  s_t.completed
            .col-xs-3
              .completed=  s_t.result
    .col-xs-6

      #delayed_jobs-div
        - @delayed_jobs.each do |d_j|
          .row
            .col-xs-4
              .run_at= d_j.run_at
            .col-xs-2
              .locked_by= d_j.attempts
            .col-xs-2
              .run_at= d_j.priority
