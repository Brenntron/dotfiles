%input{type: 'hidden', name: 'token', value: current_user.authentication_token}
%input{type: 'hidden', name: 'xml_token', value: xml_token}
%input{type: 'hidden', name: 'current_user', value: current_user.id}

%h1 Rule Doc Tool

#set-snort-doc-status-div
  %h2 Set snort_doc_status
  = form_for(:rule, html: {onsubmit: 'event.preventDefault(); return submit_rule_doc_status(this);'}) do |rule_form|
    Rule id:
    = rule_form.text_field(:id, name: 'rule_id')
    = rule_form.select(:snort_doc_status, Rule::SNORT_DOC_STATUSES, {}, name: 'snort_doc_status')
    -#= rule_form.submit('Save', onsubmit: 'submit_rule_doc_status($(\'#set-snort-doc-status-div\'))')
    = rule_form.submit

#rule-doc-unpublished-div
  %h2 Unpublished Rules
  = @rules.count
  Unpublished Rules
  %ul
    - @rules[0..5000].each do |rule|
      %li
        = select_tag(:snort_doc_status,
                     options_for_select(Rule::SNORT_DOC_STATUSES, rule.snort_doc_status),
                     onchange: "set_rule_doc_status(#{rule.id}, this.value);")
        = rule.sid_colon_format
        = "(#{rule.id})"
  - if 5000 < @rules.count
    \... first 5000

