- flash.each do |type, message|
  .ac-flash-wrapper
    %div{:class => "ac-flash alert #{bootstrap_class_for(type)} alert-dismissible fade in"}
      %button.ac_flash_button.close{"aria-label" => "Close", "data-dismiss" => "alert", :type => "button"}
        %span{"aria-hidden" => "true"} ×
      = message

%input{type: 'hidden', name: 'token', value: current_user.authentication_token}
%input{type: 'hidden', name: 'xml_token', value: xml_token}
%input{type: 'hidden', name: 'current_user', value: current_user.id}

%h1 Rule Doc Upload

%h2 Upload YAML
#snort-doc-download-form-div
  = form_tag 'upload_docs', :multipart => true  do
    = file_field_tag 'rule_update[yaml_file]', multiple: true
    %br
    = submit_tag('Upload')


.content-wrapper
  .row
    .col-sm-12
      .btn.btn-primary{"aria-controls" => "multiCollapseExample1", "aria-expanded" => "false", "data-target" => "#multiCollapseExample1", "data-toggle" => "collapse", :type => "button"}
        The Json
      #multiCollapseExample1.collapse.show.multi-collapse
        .card.card-body
          %pre
            //json
            the json
  .row
    .col-sm-12
      .btn.btn-primary{"aria-controls" => "multiCollapseExample2", "aria-expanded" => "false", "data-target" => "#multiCollapseExample2", "data-toggle" => "collapse", :type => "button"}
        The Errors
      #multiCollapseExample2.collapse.multi-collapse
        .card.card-body
          %pre
            //errors
            the errors
  .row
    .col-sm-12
      .btn.btn-primary{"aria-controls" => "multiCollapseExample3", "aria-expanded" => "false", "data-target" => "#multiCollapseExample3", "data-toggle" => "collapse", :type => "button"}
        The Errors
      -if @result.nil?
        #multiCollapseExample3.collapse.multi-collapse
      -else
        #multiCollapseExample3.collapse.show.multi-collapse
        .card.card-body
          %pre
            //result
            the result