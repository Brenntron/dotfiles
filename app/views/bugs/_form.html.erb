<%= form_for @bug, remote:true do |f| %>
  <% unless @bug.new_record? %>
    <input type="hidden" id="edit_bug_has_blockers" name="has_blockers" value=<%= @bug.snort_blocked_bugs.any? %> />
    <div class="row">
      <div class="col-sm-12 form-group">
        <label for="state">State</label>
        <%=f.select :state, options_for_select(state_options(@bug), selected: @bug.state, disabled: disabled_state_options(current_user)),{} , class: 'form-control', id: 'bug-form-state-input' %>

        <% unless @bug.can_resolve? %>
        <span class="tiny text-muted">Can't set to pending.</span>
        <ul>
          <% @bug.resolve_errors.each do |error_message| %>
          <li><span class="tiny text-muted"><%= error_message %></span></li>
          <% end %>
        </ul>
        <% end %>
      </div>
    </div>
  <% end %>
    <div id="state_comment_row" class="row hidden_comment">
      <div class="col-sm-12 form-group">
        <label for="comment">State Comment</label>
        <textarea id="state_comment" rows="10" data-min-rows="10"
                  class="form-control create-input autoExpand"
                  placeholder="Please comment on why you are changing the state."></textarea>
      </div>
    </div>
    <div id="edit_escalation_new_state" class="row hidden_comment">
      <div class="col-sm-12 form-group">
        <label for="comment">Set Blocked Escalation State To:</label>
        <%= select_tag 'escalation_new_state', options_for_select(state_options_for_escalation_close) %>
      </div>
    </div>
    <div id="edit_escalation_new_message" class="row hidden_comment">
      <div class="col-sm-12 form-group">
        <label for="comment">Set Comment for Blocked Escalation Bug(s) To:</label>
        <textarea id="escalation_new_message_field" rows="10" data-min-rows="10"
                  class="form-control create-input autoExpand"
                  placeholder="Required.  Please comment any important information to the escalation bug here."></textarea>
      </div>
    </div>


    <div class="row">
      <div class="col-sm-12 form-group">
        <label for="priority">Priority</label>
        <%= f.select :priority, ['Unspecified', 'P1', 'P2', 'P3', 'P4', 'P5'], {}, class: "form-control", id: 'bug-form-priority-input' %>
      </div>
    </div>
    <div class="row">
      <div class="col-sm-12 form-group">
        <label for="component">Component</label>
        <%= f.select :component, ['Snort Rules', 'SO Rules', 'Malware'], {}, class: "form-control", id: 'bug-form-component-input' %>
      </div>
    </div>
    <div class="row">
      <div class="col-sm-12 form-group">
        <label for="classification">Classification</label>
        <%= f.select :classification, options_for_select(classification_selections(current_user.class_level), selected: Bug.classifications[@bug.classification]), {}, class: "form-control", id: 'bug-form-classification-input' %>
      </div>
    </div>
    <% unless @bug.new_record? %>
      <div class="row">
        <div class="col-sm-12 form-group">
          <label for="user_id">Assignee</label>
          <%=f.select :user_id, options_for_select(@bug.allowed_assignees.sort, selected: @bug.user_id), {include_blank: true}, class: 'form-control', required: true, id: 'bug-form-user-input' %>
        </div>
      </div>
    <% end %>
    <% unless @bug.new_record? %>
      <div class="row">
        <div class="col-sm-12 form-group">
          <label for="committer_id">Committer</label>
          <%=f.select :committer_id, options_for_select(@bug.allowed_committers.sort, selected: @bug.committer_id), {include_blank: true}, class: 'form-control', required: true, id: 'bug-form-committer-input' %>
        </div>
      </div>
    <% end %>
    <!--<div class="row">
      <div class="col-sm-12 form-group">
        <div class="sandbox">
          <label for="select-to-selectized">Tags</label>
          <select id="select-to-new"  name="bug[tag_names][]" class="contacts selectized" placeholder="Add some tags..." multiple="multiple" tabindex="-1" style="display: none;">
            <%# @bug.tags.each do |tag|%>
                <option value="<%#tag.name%>" selected="selected"></option>
            <%#end%>
          </select>
        </div>
      </div>
    </div>-->
    <div class="row">
      <div class="col-sm-12 form-group">
        <label for="summary">Summary</label>
        <%= f.text_field :summary, class: "form-control create-input", required: true, id: 'bug-form-summary-input' %>
      </div>
    </div>
    <div class="row">
      <div class="col-sm-12 form-group">
        <label for="whiteboard">Whiteboard</label>
        <%= f.text_field :whiteboard, class: "form-control create-input", id: 'bug-form-whiteboard-input' %>
      </div>
    </div>


    <div class="row">
      <div class="col-sm-12 form-group">
        <label for="description">Description</label>
        <%= f.text_area :description, class: "form-control", required: @bug.new_record?, disabled: !@bug.new_record?, id: 'bug-form-desc-input' %>
      </div>
    </div>

    <%= f.hidden_field :product, value: 'Research', id: 'bug-form-product-input' %>
    <%= f.hidden_field :version, value: 'No Version Specified' %>

    <div class="row">
      <div class="col-sm-12 form-group">
        <button class="btn btn-success edit-bug" value="submit">Save</button>
        <button class="select-sm btn btn-default hidden" id="synching_bug_form_button"><span class="glyphicon glyphicon-refresh glyphicon-refresh-animate"></span> sinking </button>
        <button class="select-sm btn btn-default hidden" id="saving_bug"><span class="glyphicon glyphicon-refresh glyphicon-refresh-animate"></span> saving</button>
      </div>
    </div>
<% end %>
