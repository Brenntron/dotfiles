<table class="table index-table sortable">
  <thead>
  <tr>
    <th class="indent AZ down sorted" data-defaultsign="nospan"><strong>Summary</strong></th>
    <th><strong>Tags</strong></th>
    <th><strong>&nbsp;&nbsp;&nbsp;State</strong></th>
    <th><strong>Priority</strong></th>
    <th><strong>User</strong></th>
    <th><strong>Committer</strong></th>
    <th></th>
  </tr>
  </thead>
  <tbody>
  <% @bugs.each do |bug| %>
      <tr id="bug_<%= bug.id %>">
        <td><%= bug.summary %></td>
        <td><%= bug.tags.map{|t| "[#{t.name}]"}.join(' ') %></td>
        <td>&nbsp;&nbsp;&nbsp;<%= bug.state %></td>
        <td><%= bug.priority %></td>

        <td class="bug-user">
          <% if bug.user %>
              <%= bug.user.cvs_username %>
          <% else %>
              -
          <% end %>
          <br/><span class="small text-muted bug-actions">take</span>
        </td>
        <td class="bug-user">
          <% if bug.committer %>
              <%= bug.committer.cvs_username %>
          <% else %>
              -
          <% end %>
        </td>

        <td>
          <%=link_to  "#" , class: "delete_bug", id: "delete_bug"+bug.id.to_s do %>
              <i class="glyphicon glyphicon-remove" title="Delete"></i>
          <% end %>
        </td>
      </tr>
  <% end %>
  </tbody>
</table>