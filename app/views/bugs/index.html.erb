<table class="table index-table">
  <thead>
  <tr>
    <td class="indent" data-defaultsign="nospan"><strong>Summary</strong></td>
    <td><strong>Tags</strong></td>
    <td><strong>X</strong></td>
    <td><strong>State</strong></td>
    <td><strong>Priority</strong></td>
    <td><strong>User</strong></td>
    <th></th>
    <td><strong>Committer</strong></td>
    <td></td>
  </tr>
  </thead>
  <tbody>
  <% @bugs.each do |bug| %>
      <tr id="bug_<%= bug.id %>" class="<%= set_bug_color(bug) %>">
        <td><%= link_to bug.summary, bug_path(bug.id) %> </td>
        <td><%= bug.tags.map { |t| "[#{t.name}]" }.join(' ') %></td>
        <td><span onclick="toggle_liberty(<%= bug.id %>)"><%= bug.liberty_clear? ? "OK" : "NO" %></span></td>
        <td><%= bug.state %></td>
        <td><%= bug.priority %></td>

        <td class="bug-user">
          <% if bug.user %>
            <%= bug.user.cvs_username %>
          <% else %>
            -
          <% end %>
          <br/><span class="small text-muted bug-wait" style="display: none" id="bug-wait-<%= bug.id %>">please wait</span>
        </td>
        <td>
          <% if bug.user && (bug.user.email != current_user.email) %>
            <button type=button class="small text-muted bug-actions take-bug" id="take-bug-<%= bug.id %>" data-id="<%= bug.id %>">take</button>
          <% else %>
            <button type=button class="small text-muted bug-actions return-bug" id="return-bug-<%= bug.id %>" data-id="<%= bug.id %>">return</button>
          <% end %>
        </td>
        <td class="bug-user">
          <% if bug.committer %>
              <%= bug.committer.cvs_username %>
          <% else %>
              -
          <% end %>
        </td>

        <td>
          <%= link_to "#", class: "delete_bug", id: "delete_bug"+bug.id.to_s do %>
              <i class="glyphicon glyphicon-remove" title="Delete"></i>
          <% end %>
        </td>
      </tr>
  <% end %>
  </tbody>
</table>
<div class="apple_pagination">
  <%= will_paginate @bugs %>
</div>