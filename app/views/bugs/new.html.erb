<div class='row item-info'>
  <div class='col-lg-10 col-sm-11'>
    <div class="row">
      <div class="col-xs-12">
        <h2 class="subtitle">Create A New Bug <button class="btn btn-sm btn-default" {{action 'cancelCreate'}}>cancel</button></h2>
        <p>Use this form to open a new Snort Rules bug on bugzilla.</p>
      </div>
    </div>
    <div class="row">
      <div class="col-xs-12">
        <div class="spacer"></div>
        <%= form_for @bug do |f| %>
        <div class="row">
          <div class="col-sm-12 form-group">
            <label for="version">Snort Version</label>
            <%= f.select :version, ['No Version Specified', '2.5.2', '2.6.0', '2.7.0', '3.0.0', '3.0.0-139', '3.0.0-146(RC3)'], {}, class: "form-control" %>
          </div>
        </div>
        <div class="row">
          <div class="col-sm-12 form-group">
            <label for="summary">Summary</label>
            <%= f.text_field :summary, class: "form-control create-input", required: true %>
          </div>
        </div>
        <div class="row">
          <div class="col-sm-12 form-group">
            <label for="description">Description</label>
            <%= f.text_area :description, class: "form-control", required: true %>
          </div>
        </div>
        <div class="row">
          <div class="col-sm-12 form-group">
            <button class="btn btn-success" value="submit">Create Bug</button>
          </div>
        </div>
        <div class="spacer"></div>
        <% end %>
      </div>
    </div>
  </div>
</div>