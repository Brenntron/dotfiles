
    <div class='row item-info'>
      <div class="row subheading">
        <div class="col-xs-12">
          <div class="col-xs-3">
            <div class="bug-details-columns">
              <h6>bugzilla id</h6>
                <h3>
                  <a class="top-space bugzilla_id" href="<%= get_bug_url %>" id="bugzilla_<%= @bug.id %>" target="_blank"><%=@bug.id%></a>
                  <small>
                    <span data-toggle="modal" data-target="#editBug">
                      <a type="button" style="text-decoration:none;" class="glyphicon glyphicon-pencil edit_bug" id="edit_bug" data-toggle="tooltip" data-placement="bottom" title="edit bug"></a>
                    </span>
                    <% if @bug.user.email != current_user.email %>
                      <a type="button" style="text-decoration:none;" class="glyphicon glyphicon-download-alt take-bug" id="take-bug-<%= @bug.id %>" data-id="<%= @bug.id %>" data-toggle="tooltip" data-placement="bottom" title="Take this bug"></a>
                    <%else%>
                      <a type="button" style="text-decoration:none;" class="glyphicon glyphicon-share-alt return-bug" id="return-bug-<%= @bug.id %>" data-id="<%= @bug.id %>" data-toggle="tooltip" data-placement="bottom" title="Return this bug"></a>
                    <%end%>
                    <span class="glyphicon glyphicon-refresh glyphicon-refresh-animate hidden" id="loading_image"> </span>
                    <a type="button" style="text-decoration:none;" class="glyphicon glyphicon-refresh resynch_bug" id="resynch_bug" data-toggle="tooltip" data-placement="bottom" title="resynch this bug with bugzilla"></a>
                    <button class="select-sm btn btn-default hidden" id="loading_image"><span class="glyphicon glyphicon-refresh glyphicon-refresh-animate"></span> synching</button>
                  </small>
                </h3>
            </div>
          </div>

          <div class="col-xs-1 state">
            <div class="bug-details-columns">
              <h6>state</h6>
              <h5 class="top-space"><%= @bug.state %></h5>
            </div>
          </div>
          <div class="col-xs-1">
            <div class="bug-details-columns">
              <h6>classification</h6>
              <h5 class="top-space"><%= @bug.classification %></h5>
            </div>
          </div>
          <div class="col-xs-1">
            <div class="bug-details-columns">
              <h6>component</h6><h5 class="top-space"><%= @bug.component %></h5>
            </div>
          </div>
          <div class="col-xs-1">
            <div class="bug-details-columns">
              <h6>priority</h6>
              <h5 class="top-space"><%= @bug.priority %></h5>
            </div>
          </div>
          <div class="col-xs-1">
            <div class="bug-details-columns">
              <h6>assignee</h6>
              <% if @bug.user %>
                <h5 class="top-space"><%= @bug.user.cvs_username %></h5>
              <% end %>
            </div>
          </div>
          <div class="col-xs-1">
            <div class="bug-details-columns">
              <h6>committer</h6>
              <% if @bug.committer %>
                <h5 class="bug-user top-space"><%= @bug.committer.cvs_username %></h5>
              <% end %>
            </div>
          </div>
          <div class="col-xs-3">
            <button class="select-sm btn btn-info back_btn pull-right" id="back_btn" style="margin-top:4px;margin-right:-28px"><i class="glyphicon glyphicon-th-list"></i> <strong class="hidden-xs">bug list</strong></button>
          </div>
        </div>

      <div class="row item-info">
        <div class="col-xs-12 hidden-xs bug_summary">
          <h5 class="edit-summary-field"><%= @bug.summary %></h5>
        </div>
      </div>

      </div>
      <div class="row">
        <div class="col-xs-12">
        </div>
      </div>
    </div>
    <div class="spacer">
      <%= render 'tabs' %>
    </div>

<div id="blanket" style="display:none;"></div>
<div id="searchWindow" style="display:none;">
  <div class="col-xs-1 col-xs-offset-11">
  </div>
  <div class="row center">
    <h3>Search</h3>
  </div>
  <div class="row">
  </div>
</div>
<input type="hidden" name="token" value="<%= current_user.authentication_token %>">
<input type="hidden" name="xml_token" value="<%= xml_token %>">


<div class="modal fade" id="editBug" tabindex="-1" role="dialog" aria-labelledby="editBug" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h4 class="modal-title" id="editBug">Update Bug <%=@bug.id%>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </h4>
      </div>
      <div class="modal-body">
        <%=render 'form' %>
      </div>
    </div>
  </div>
</div>
