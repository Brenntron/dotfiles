<div class="row top-space">
  <div class="col-sm-12">
    <h4 class="blue">&nbsp; Task Logs</h4>
  </div>
  <div class="col-sm-12">
    <table class="table table-condensed table-striped small">
      <thead>
      <tr>
        <td class="narrow-column">Completed</td>
        <td class="narrow-column">Failed</td>
        <td class="task-type-col">Type</td>
        <td>Result</td>
        <td class="user-col">User</td>
        <td class="narrow-column">CreatedAt</td>
      </tr>
      </thead>
      <tbody>
        <% if @bug.tasks.any? %>
          <% @bug.tasks.any_relations.reverse_chron.each_with_index do |task, index| %>
            <tr data-task-id="<%= task.id %>">
              <% if task.completed %>
                <td class="center"><input type="checkbox" checked></td>
              <% else %>
                  <td class="center"><input type="checkbox"></td>
              <% end %>
              <% if task.failed %>
                <td class="center failed-bg"><input type="checkbox" checked></td>
              <% else %>
                <td class="center"><input type="checkbox"></td>
              <% end %>
              <td class="task-type-col"><%= task.task_type %></td>
              <td>
                <div id="job-expand-<%= task.id %>" style="<%= job_expand_display(task, index) %>">
                  <span data-expand-id="job-expand-<%= task.id %>" data-collapse-id="job-collapse-<%= task.id %>"
                        onclick="expand_job_result(this)"
                        class="glyphicon glyphicon-expand job-results-button" title="Expand"></span>
                </div>
                <div id="job-collapse-<%= task.id %>" style="<%= job_collapse_display(task, index) %>">
                  <span data-expand-id="job-expand-<%= task.id %>" data-collapse-id="job-collapse-<%= task.id %>"
                        onclick="collapse_job_result(this)"
                        class="glyphicon glyphicon-collapse-up job-results-button" title="Expand"></span>
                  <pre><%= task.result %></pre>
                </div>
              </td>
              <td class="user-col"><%= User.find(task.user_id).cvs_username %></td>
              <td><%= task.created_at.strftime("%m/%d/%y") %></td>
            </tr>
            <tr style="display:none;">
              <td colspan="7" class="code">
                <strong>Rules:</strong>
                <% if 0 < task.any_rules %>
                  <% task.rules.each do |rule| %>
                    <%= rule.id %>,
                  <% end %>
                <% end %>
                <br/>
                <strong>Attachments:</strong>
                <% if 0 < task.any_attachments %>
                  <% task.attachments.each do |attach| %>
                    <%= attach.file_name %>,
                  <% end %>
                <% end %>
                <br/>
                <strong>Result:</strong><br/>
                <%= task.result %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="7" class="center text-muted"><em>No tasks for this bug.</em></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
