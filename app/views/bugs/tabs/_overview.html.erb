<div class="row top-space">
  <div class="col-sm-12">
    <h4 class="blue">Summary <span class="tiny text-muted">&nbsp; <a data-toggle="modal" data-target="#change_summary_modal">edit</a>&nbsp; </span></h4>
  </div>

  <div class="col-sm-12 bug_summary">
    <h4 id="current_bug_summary"><%= @bug.summary %></h4>
  </div>

</div>
<div class="row top-space">
  <div class="col-xs-12">
    <h4 class="blue"> References
      <span class="pull-right h6">
        <a data-toggle="modal" data-target="#referenceWindow"><i class="glyphicon glyphicon-plus"></i> Add Reference</a>
      </span>
    </h4>
  </div>
  <div class="col-xs-12 code">
    <% if @bug.references.any? %>
      <% if @bug.references.cves.any? %>
        <p>cve:</p>
        <% @bug.references.cves.each do |ref| %>
          <div class="col-xs-12">
            <code><a href="<%= get_ref_url(ref, "cve") %>" target="_blank"><%= ref.reference_data %></a></code>
          </div>
        <% end %>
      <% end %>
      <% if @bug.references.url.any? %>
        <p>url:</p>
        <% @bug.references.url.each do |ref| %>
            <div class="col-xs-12">
              <code><a href="<%= get_ref_url(ref, "url") %>" target="_blank"><%= ref.reference_data %></a></code>
            </div>
        <% end %>
      <% end %>
      <% if @bug.references.url.any? %>
        <p>bugtraq:</p>
        <% @bug.references.bugtraqs.each do |ref| %>
          <div class="col-xs-12">
            <code><a href="<%= get_ref_url(ref, "bugtraq") %>" target="_blank"><%= ref.reference_data %></a></code>
          </div>
        <% end %>
      <% end %>
      <% if @bug.references.telus.any? %>
        <p>telus:</p>
        <% @bug.references.telus.each do |ref| %>
          <div class="col-xs-12">
            <code><a href="<%= get_ref_url(ref, "telus") %>" target="_blank"><%= ref.reference_data %></a></code>
          </div>
        <% end %>
      <% end %>
      <% if @bug.references.apsb.any? %>
        <p>apsb:</p>
        <% @bug.references.apsb.each do |ref| %>
          <div class="col-xs-12">
            <code><a href="<%= get_ref_url(ref, "apsb") %>" target="_blank"><%= ref.reference_data %></a></code>
          </div>
        <% end %>
      <% end %>
      <% if @bug.references.msb.any? %>
        <p>msb:</p>
        <% @bug.references.msb.each do |ref| %>
          <div class="col-xs-12">
            <code><a href="<%= get_ref_url(ref, "msb") %>" target="_blank"><%= ref.reference_data %></a></code>
          </div>
        <% end %>
      <% end %>
      <% if @bug.references.osvdb.any? %>
        <p>osvdb:</p>
        <% @bug.references.osvdb.each do |ref| %>
          <div class="col-xs-12">
            <code><a href="<%= get_ref_url(ref, "cve") %>" target="_blank"><%= ref.reference_data %></a></code>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <p>< MISSING ></p>
    <% end %>
  </div>
</div>


<div class="row top-space">
  <div class="col-xs-12">
    <h4 class="blue"> Exploits</h4>
  </div>
  <div class="col-xs-12 code">
    <% if @bug.references.any? %>
      <p><%=exploit_link(@bug.references)%></p>
    <% end %>
    <p>----------------</p>
  </div>
</div>



