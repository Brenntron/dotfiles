<div class="row top-space">
  <div class="col-sm-12">
    <h4 class="blue">Tags</h4>
  </div>

  <div class="col-sm-12 bug_summary">
    <div class="sandbox">
      <div id="alert_message" role="alert"></div>
      <select id="select-to-edit" bug_id="<%=@bug.id%>" name="bug[tag_names][]" class="contacts selectized" placeholder="Add some tags..." multiple="multiple" tabindex="-1" style="display: none;">
        <% @bug.tags.each do |tag|%>
          <option value="<%=tag.name%>" selected="selected"></option>
        <%end%>
      </select>
    </div>
  </div>

</div>
<hr>
<div class="row top-space">
  <div class="col-xs-12">
    <h4 class="blue"> References
      <span class="pull-right h6">
        <a data-toggle="modal" data-target="#referenceWindow"><i class="glyphicon glyphicon-plus"></i> Add Reference</a>
      </span>
    </h4>
  </div>
  <div class="col-xs-12 code">
    <% if @bug.references.any? %>
        <% if @bug.references.cves.any? %>
            <p>cve:</p>
            <% @bug.references.cves.each do |ref| %>
                <div class="col-xs-12">
                  <code><a href="<%= get_ref_url(ref, "cve") %>" target="_blank"><%= ref.reference_data %></a></code>
                </div>
            <% end %>
        <% end %>
        <% if @bug.references.urls.any? %>
            <p>url:</p>
            <% @bug.references.urls.each do |ref| %>
                <div class="col-xs-12">
                  <code><a href="<%= get_ref_url(ref, "url") %>" target="_blank"><%= ref.reference_data %></a></code>
                </div>
            <% end %>
        <% end %>
        <% if @bug.references.bugtraqs.any? %>
            <p>bugtraq:</p>
            <% @bug.references.bugtraqs.each do |ref| %>
                <div class="col-xs-12">
                  <code><a href="<%= get_ref_url(ref, "bugtraq") %>" target="_blank"><%= ref.reference_data %></a></code>
                </div>
            <% end %>
        <% end %>
    <% else %>
        <p>< MISSING ></p>
    <% end %>
  </div>
  <input id="tag_list" class="hidden" value="<%=@tags%>"></input>
</div>
<hr>
<div class="row top-space">
  <div class="col-xs-12">
    <h4 class="blue"> Exploits</h4>
  </div>
  <div class="col-xs-12">
    <div class="exploit_notices red"></div>
  </div>
  <div class="col-xs-12 code">
    <% if @bug.references.any? %>
        <p><%= find_exploit_link(@bug.references) %></p>
    <% end %>
  </div>
</div>
<hr>
<div class="row top-space">
  <div class="col-xs-12">
    <h4 class="blue"> Metrics
    </h4>
  </div>
</div>
