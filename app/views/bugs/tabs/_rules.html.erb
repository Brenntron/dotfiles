<style>
  <%= Diffy::CSS %>
</style>
<div class="row top-bar">
  <div class="col-xs-12">
    <button class="select-sm btn btn-default rule-toolbar" id="overview"><i class="glyphicon glyphicon-list"></i><strong class="hidden-xs">&nbsp;&nbsp; list all</strong></button>
    <button class="select-sm btn btn-default rule-toolbar" id="view"><strong class="hidden-xs">view &nbsp;&nbsp;</strong><i class="glyphicon glyphicon-eye-open"></i></button>
    <button class="select-sm btn btn-default rule-toolbar" id="edit"><strong class="hidden-xs">edit &nbsp;&nbsp;</strong><i class="glyphicon glyphicon-pencil"></i></button>
    <button class="select-sm btn btn-default rule-toolbar" id="create"><strong class="hidden-xs">create &nbsp;&nbsp;</strong><i class="glyphicon glyphicon-plus"></i></button>
    <button class="select-sm btn btn-default rule-toolbar" id="remove"><strong class="hidden-xs">remove &nbsp;&nbsp;</strong><i class="glyphicon glyphicon-minus"></i></button>
    <button class="select-sm btn btn-default rule-toolbar" id="test"><strong class="hidden-xs">test rules &nbsp;&nbsp;</strong><i class="glyphicon glyphicon-flag"></i></button>
    <span class="text-muted small hidden-xs"><i id="bug-rules-loader" class="glyphicon glyphicon-refresh spin" style="display:none;"></i><i id="bug-rules-error" class="glyphicon glyphicon-alert" style="display:none;"></i> &nbsp;&nbsp;</span>
    <form class="form-inline pull-right" id="linkRuleForm">
      <div class="input-group">
        <input name="sid" class="form-control select-sm input-extra-narrow" placeholder="import rule" />
      <span class="input-group-btn">
        <button class="btn btn-default" type="button">Import</button>
      </span>
      </div><!-- /input-group -->
    </form>
  </div>
</div>
<hr class="short"/>
<div class="col-xs-12 alert_rules"></div>
<div class="row overview active">
  <div class="col-xs-12">
    <table class="table table-condensed table-hover rules_table">
      <thead class="small">
      <tr>
        <td><input type="checkbox" class="rules_check_box"></td>
        <td>State</td>
        <td>Version</td>
        <td>Message</td>
        <td>Check</td>
        <td>Match</td>
        <td>Nonmatch</td>
      </tr>
      </thead>
      <% if @rules.any? %>
        <tbody>
        <% @rules.each do |rule| %>
          <tr id=<%= rule.id %>>
            <td><input type="checkbox" id="rule_<%= rule.id %>" class="rule_check_box" value="<%= rule.id %>"></td>

            <td class="rule_state_<%=rule_state_color(rule.state)%>"><%= rule.state %></td>

            <td>
              <a class="blue show_rule" href="#">
                <% if rule.sid %>
                  <strong><%= rule.gid %>:<%= rule.sid %>:<%= rule.rev %></strong>
                <% else %>
                  new_rule
                <% end %>
              </a>
            </td>
            <td><code><%= rule.message %></code></td>
            <td class="center"><%= rule.average_check ? rule.average_check : '-' %></td>
            <td class="center"><%= rule.average_match ? rule.average_match : '-' %></td>
            <td class="center"><%= rule.average_nonmatch ? rule.average_nonmatch : '-' %></td>
          </tr>
        <% end %>
        </tbody>
      <% end %>
    </table>
  </div>
</div>
<div class="row create hidden">
  <div class="row top-space center">
    <div class="col-xs-2">
      <button class="select-sm btn btn-default rules" id="overview"><i class="glyphicon glyphicon-arrow-left"></i><strong class="hidden-xs">&nbsp;&nbsp; back</strong></button>
    </div>
    <div class="col-xs-8 col-sm-7 center">
      <h4>
        <span class="blue"></span>
        <a class="btn btn-xs btn-link" id="legacy_btn" href='#' style="display: none;">use legacy form</a>
        <a class="btn btn-xs btn-link" id="standard_btn" href='#'>use standard form</a>
      </h4>
    </div>
  </div>
  <div class="col-xs-12">
    <div class="col-xs-12"><hr/></div>
      <div class="col-xs-12">
        <%= render 'shared/rule_form' %>
      </div>
    <div class="row top-space"></div>
  </div>
</div>
<div class="row view hidden">
  <div class="col-xs-12">
    <div class="col-xs-12"><hr/></div>
    <%= render '/bugs/tabs/rules/view' %>
  </div>
</div>
<div class="row edit hidden">
  <div class="col-xs-12">
    <div class="col-xs-12"><hr/></div>
    <%= render '/bugs/tabs/rules/edit' %>
  </div>
</div>
<div class="row spacer"></div>

<script>
  $('.show_rule').on('click', function(e){
    e.preventDefault();
    var id = $(this).parents('tr').attr('id');
    $('.overview').removeClass('active').addClass('hidden');
    $('.view').removeClass('hidden').addClass('active').show();
    $.each($('.rules_table tr'), function() {
      var id = $(this).attr('id');
      if(!isNaN(id)){
        $('.rule_'+id).removeClass('active').addClass('hidden').hide();
      }
    });
    $('.rule_'+id).removeClass('hidden').addClass('active').show();
  });
</script>