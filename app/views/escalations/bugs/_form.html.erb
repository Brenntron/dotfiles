<%= form_for [:escalations, @bug],  remote:true do |f| %>
  <% unless @bug.new_record? %>
    <div class="row">
      <div class="col-sm-12 form-group">
        <label for="state">State</label>
        <%=f.select :state, options_for_select(esc_state_options(@bug), selected: @bug.state, disabled: esc_disabled_state_options(current_user)),{} , class: 'form-control', id: 'bug-form-state-input' %>

        <% unless @bug.can_resolve? %>
        <span class="tiny text-muted">Can't set to pending.</span>
        <ul>
          <% @bug.resolve_errors.each do |error_message| %>
          <li><span class="tiny text-muted"><%= error_message %></span></li>
          <% end %>
        </ul>
        <% end %>
      </div>
    </div>
  <% end %>
    <div id="state_comment_row" class="row hidden_comment">
      <div class="col-sm-12 form-group">
        <label for="comment">State Comment</label>
        <textarea id="state_comment" rows="10" data-min-rows="10"
                  class="form-control create-input autoExpand"
                  placeholder="Please comment on why you are changing the state."></textarea>
      </div>
    </div>
    <div class="row">
      <div class="col-sm-12 form-group">
        <label for="priority">Priority</label>
        <%= f.select :priority, ['Unspecified', 'P1', 'P2', 'P3', 'P4', 'P5'], {}, class: "form-control", id: 'bug-form-priority-input' %>
      </div>
    </div>
    <div class="row">
      <div class="col-sm-12 form-group">
        <label for="component">Component</label>
        <%= f.select :component, ['TAC','ATA','CSOC','Sales'], {}, class: "form-control" %>
      </div>
    </div>
    <%= f.hidden_field :product, value: 'Escalations' %>
    <%= f.hidden_field :version, value: 'unspecified' %>
    <% unless @bug.new_record? %>
      <div class="row">
        <div class="col-sm-12 form-group">
          <label for="user_id">Assignee</label>
          <%=f.select :user_id, options_for_select(@bug.allowed_assignees.sort, selected: @bug.user_id), {include_blank: true}, class: 'form-control', required: true%>
        </div>
      </div>
    <% end %>
    <!--<div class="row">
      <div class="col-sm-12 form-group">
        <div class="sandbox">
          <label for="select-to-selectized">Tags</label>
          <select id="select-to-new"  name="bug[tag_names][]" class="contacts selectized" placeholder="Add some tags..." multiple="multiple" tabindex="-1" style="display: none;">
            <%# @bug.tags.each do |tag|%>
                <option value="<%#tag.name%>" selected="selected"></option>
            <%#end%>
          </select>
        </div>
      </div>
    </div>-->
    <div class="row">
      <div class="col-sm-12 form-group">
        <label for="summary">Summary</label>
        <%= f.text_field :summary, class: "form-control create-input", required: true, id: 'bug-form-summary-input' %>
      </div>
    </div>
    <div class="row">
      <div class="col-sm-12 form-group">
        <label for="summary">Whiteboard</label>
        <%= f.text_field :whiteboard, class: "form-control create-input" %>
      </div>
    </div>

    <% if @bug.new_record? %>
      <div class="row">
        <div class="col-sm-12 form-group">
          <label for="description">Description</label>
          <%= f.text_area :description, class: "form-control", required: true %>
        </div>
      </div>
    <% end %>

    <div class="row">
      <div class="col-sm-12 form-group">
        <button class="btn btn-success edit-bug" value="submit">Save</button>
        <button class="select-sm btn btn-default hidden" id="synching_bug_form_button"><span class="glyphicon glyphicon-refresh glyphicon-refresh-animate"></span> sinking </button>
        <button class="select-sm btn btn-default hidden" id="saving_bug"><span class="glyphicon glyphicon-refresh glyphicon-refresh-animate"></span> saving</button>
      </div>
    </div>
<% end %>
