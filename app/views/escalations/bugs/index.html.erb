

<% if @final_giblets.present? %>
<% gib_ids = @final_giblets.map {|gib| gib.id}.join(",") %>
<% gib_names = @final_giblets.map {|gib| gib.name}.uniq.join(" ") %>
<div id="search-results-wrapper">
  <label class="search-label">Results for:</label><input id="save_giblet_search_field" type="hidden" value="<%= gib_ids %>" /><span class="searched-item"><%= gib_names %></span><button id="save_giblet_search_button">Save Search</button>
</div>
<% end %>
<table class="table index-table">
  <thead>
  <tr>
    <td class="indent" data-defaultsign="nospan"><strong>Summary</strong></td>
    <td><strong>Last Updated</strong></td>
    <td><strong>Component</strong></td>

    <td><strong>State</strong></td>
    <td><strong>Priority</strong></td>
    <td><strong>User</strong></td>

    <td></td>
  </tr>
  </thead>
  <tbody>
  <% @bugs.each do |bug| %>
      <tr id="bug_<%= bug.id %>" class="<%= set_bug_color(bug) %>">
        <td>
          <%= link_to bug.summary, escalations_bug_path(bug.id) %>
          <br/>
          <span class="tags-wrapper">
            <% uniq_gibs = bug.giblets.map {|g| g.name}.uniq %>
            <% uniq_gibs.each do |gib| %>
            <a href="<%= escalations_bugs_path({:tag_names => [gib], :page => 1}) %>"><button class="tag primary-tag"><%= gib %></button></a>
            <% end %>
          </span>
        </td>
        <td><%= display_last_updated_date(bug)%> <%= display_last_updated_time(bug)%></td>
        <td><%= bug.component %></td>

        <td><%= bug.state %></td>
        <td><%= bug.priority %></td>

        <td class="bug-user">
          <% if bug.user %>
            <%= bug.user.cvs_username %>
          <% else %>
            -
          <% end %>
          <br/><span class="small text-muted bug-wait" style="display: none" id="bug-wait-<%= bug.id %>">please wait</span>
          <% if bug.committer != current_user %>
            <% if bug.user && (bug.user.email != current_user.email) %>
                <button type=button class="small text-muted" id="take-bug-<%= bug.id %>" data-id="<%= bug.id %>" onclick="populate_bugid_in_modal(<%= bug.id %>)">take</button>
            <% else %>
                <button type=button class="small text-muted return-bug" id="return-bug-<%= bug.id %>" data-id="<%= bug.id %>">return</button>
            <% end %>
          <%end%>
        </td>

        <td>
          <%= link_to "#", class: "delete_bug", id: "delete_bug"+bug.id.to_s do %>
              <i class="glyphicon glyphicon-remove" title="Delete"></i>
          <% end %>
        </td>
      </tr>
  <% end %>
  </tbody>
</table>
<div class="apple_pagination">
  <%= will_paginate @bugs %>
</div>


<div class="modal fade" id="take_acknowledge_esc" tabindex="-1" role="dialog" aria-labelledby="take_acknowledge_esc" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h4 class="modal-title" id="editBug">Take and Acknowledge Escalation
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </h4>
      </div>
      <div class="modal-body">
        <%= hidden_field_tag 'acknowledge_bug_id', value: 0 %>
        <p>By Clicking OK you will take this bug and acknowledge that it has been seen</p>
        <br>
        <div class="row">
          <div class="col-sm-12 form-group">
            <label>
              <%= radio_button_tag 'acknowledge_response_take', "ack1", true %>
              <%= "Escalation has been acknowledged by #{current_user&.display_name}." %>
            </label>
          </div>
        </div>
        <div class="row">
          <div class="col-sm-12 form-group">
            <label>
              <%= radio_button_tag 'acknowledge_response_take', 'ack2' %>
              <%= text_area_tag 'acknowledge_response_custom_take', "", size: "50x2", placeholder: "custom acknowledgement goes here" %>
            </label>
          </div>
        </div>
        <div class="row">
          <div class="col-sm-12 form-group">
            <button class="btn btn-success acknowledge-bug" onclick="take_escalation_acknowledge(this,$('#acknowledge_bug_id').val())" data-dismiss="modal" aria-label="Close" value="submit">
              <span aria-hidden="true">OK</span>
            </button>
          </div>
        </div>
        <br>
      </div>
    </div>
  </div>
</div>