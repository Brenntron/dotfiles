<div class="row top-space">
  <div class="panel-group minimal-panel-group col-xs-12"  role="tablist" aria-multiselectable="true">


    <div class="panel panel-default">
      <div class="panel-heading" role="tab" id="scratchpad_notes_heading">
        <h4 class="panel-title">
          <a class="collapsed" data-toggle="collapse"  href="#scratchpad_notes_collapse" aria-expanded="false" aria-controls="collapseThree">
            <span class="blue">Scratchpad general notes</span>
          </a> <span class="caret"></span>
          &nbsp;&nbsp;
        </h4>
        <div class="alert_notes_scratch"></div>
      </div>
      <% scratchpad_note = @bug.notes.scratch_pad.first %>
      <div id="scratchpad_notes_collapse" class="panel-collapse" role="tabpanel" aria-labelledby="headingThree">
        <div class="panel-body row">
          <form id="scratchpad_notes_form">
            <div class="form-group col-xs-12 col-md-10 col-lg-11">
              <textarea id="scratchpadNotesEditArea" class="form-control disabled code wrapped_code select-sm autosize autoExpand" name="scratchpad_notes" rows="10" cols="100" style="background-color: #F0F0F0" readonly><%= scratchpad_note ? scratchpad_note.comment : "" %></textarea>
              <input type="hidden" name="scratchpad_note_id" value="<%= scratchpad_note ? scratchpad_note.id : nil %>">
            </div>
            <input type="hidden" name="scratchpad_type" value="scratchpad">
            <input type="hidden" name="bugzilla_id" value="<%= @bug.id %>">

                <div class="form-group col-xs-12 col-md-2 col-lg-1 right">
                  <button id="scratchpadNotesEditBtn" class="btn btn-default btn-sm">edit</button>
                  <button id="scratchpadNotesCancelBtn" class="btn btn-default btn-sm" style="display:none;">cancel</button>
                  <div class="top-space"></div>
                  <button id="scratchpadNotesSaveBtn" class="btn btn-warning btn-sm" value="submit" style="display:none;">save</button>
                </div>

          </form>
        </div>
      </div>
    </div>

  </div>
</div>