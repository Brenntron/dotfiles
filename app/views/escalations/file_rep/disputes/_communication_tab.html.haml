    .row
      .col-xs-12#email-reply.hidden
        .row
          .col-xs-12.email-reply-content-wrapper
            .row
              .col-xs-12.email-reply-header-information
                .row
                  .col-xs-4
                    .sender-receiver-info
                      %span.reply-symbol
                      %span.receiver-email
                  .col-xs-8
                    .template-select-wrapper
                      .template-label
                        Select a Template

                    %select.dropdown.email-template-select#select-reply-template
                      -if EmailTemplate.all.empty?
                        %option.hidden{value:'', disabled: true, selected: true} No Templates Created
                      -else
                        %option.hidden{value:'', disabled: true, selected: true} No Template Selected
                        =options_for_select(EmailTemplate.all.pluck(:template_name, :id))

                    .email-reply-button-wrapper
                      .email-reply-buttons
                        %button.attachment-button.attachment-label.attachment-reply
                        %button.delete-email
                .row
                  .col-xs-12
                    %input.communication-subject.reply-subject{type: 'text'}

                .row
                  .col-xs-12.file-wrapper-reply
                    #file-fields
            .row
              .col-xs-12.email-reply-body-wrapper
                %textarea.email-reply-body.reply-body{autofocus: true, maxlength: 64000}

        .row
          .col-xs-12.text-center
            %button.primary#send-reply
              Send



  .col-sm-3
    -##### Check to see if duplicate file rep tickets are possible, if not we just need to check to see if a ticket is resolved
    -#- if (@dispute.resolution != Dispute::DUPLICATE) && (@dispute.status != Dispute::RESOLVED)

    %h1.notes-header Notes
    %button.add-case-note-button#new-filerep-case-note-button
      Add Note


    .note-wrapper.new-case-note-row
      .row
        .col-xs-12
          .note-info-item.author-notation
            Creating new note
          .note-info-item.note-tool-buttons
            %button.note-save-button.new-filerep-case-note-save-button
            %button.note-cancel-button.new-filerep-case-note-cancel-button
            %button.note-copy-button
      .row
        .col-xs-12
          .note-block.content-editable.new-case-note-textarea{contenteditable: true}
            %pre



    -@file_rep_dispute.file_rep_comments.recent_first.each do |comment|
      .note-wrapper
        .row
          .col-xs-12
            .note-info-item.author-notation
              Written by
              %span.author-username
                =comment.user.cec_username
              = distance_of_time_in_words(Time.now.utc, comment.created_at.utc) + " ago."
            %br.hidden-break
            .note-info-item.time-stamp
              = format_timestamp(comment.created_at)
            .note-info-item.note-tool-buttons
              %button.hidden.note-save-button.filerep-update-note{class: "note-save-button#{comment.id}", comment_id: "#{comment.id}"}
              %button.hidden.note-cancel-button{class: "note-cancel-button#{comment.id}", comment_id: "#{comment.id}"}
              %button.note-copy-button.clipboard.clipboard-btn{comment_id: "#{comment.id}", "data-clipboard-action"=> "copy", "data-clipboard-text"=> "#{comment.comment}"}
              %button.filerep-note-delete-button{comment_id: "#{comment.id}"}

        .row
          .col-xs-12
            - if comment.user.cec_username == current_user.cec_username
              .note-block.content-editable{class: "note-block#{comment.id}", comment_id: "#{comment.id}", contenteditable: true}
                %pre=comment.comment
            - else
              .note-block{comment_id: "#{comment.id}"}
                %pre=comment.comment



    %input{:name => "token", :type => "hidden", :value => "#{current_user.authentication_token}"}
    %input{:type => "hidden", :name => "xml_token", :value => "#{xml_token}"}
    %input{:name => "dispute_id", :type => "hidden", :value => "#{@file_rep_dispute.id}"}
    %input{:name => "current_user_id", :type => "hidden", :value => "#{current_user.id}"}

  :javascript
    AC.Helpers.clipboard()
    // Default sort of case history
    $(document).ready(function(){
      list = $("#case-history tr").get();
      sort_function = function(a, b) {
        return $(".case-history-datetime", b).data().dbDate.localeCompare($(".case-history-datetime", a).data().dbDate);
      };
      list.sort(sort_function);
      for (var i = 0; i < list.length; i++) {
          list[i].parentNode.appendChild(list[i]);
      }
    })

