.row
  .col-sm-3
    %h1 Case History
    .row.table-toolbar
      .col-xs-5
        %label Sort:
        %select#history-sort-dropdown
          %option#date-desc="Date, Desc"
          %option#date-asc="Date, Asc"
          %option#author="Author"
          %option#kind="Kind"
      .col-xs-7
        %label Show:
        %select#history-display-dropdown
          %option#all="Everything"
          %option#email="Email"
          %option#note-history="Notes"
          %option#version="Status"
    .row
      .col-xs-12
        %table#case-history
          -@file_rep_dispute.dispute_emails.each do |email|
            %tr.email-row{class: "email-#{email.status}", email_id: "#{email.id}"}
              %td.alt-col.icon-col
                %span.case-history-icon.email-icon{:data => {:history_kind => "email"}}
              %td
                %span.case-history-author
                  =email.from
                %span.case-history-preview
                  =email.subject
              %td.alt-col.case-history-datetime{:data => {:db_date => email.created_at}}
                = format_date(email.created_at)
                %br
                =email.created_at.strftime("%H:%M:%S")
          -@file_rep_dispute.file_rep_comments.recent_first.each do |comment|
            %tr.note-history-row
              %td.alt-col.icon-col
                %span.case-history-icon.note-icon{:data => {:history_kind => "note"}}
              %td
                %span.case-history-author
                  =comment.user.cec_username
                %span.case-history-preview
                  =comment.comment.truncate(75, omission: '...')
              %td.alt-col.case-history-datetime{:data => {:db_date => comment.created_at}}
                = format_date(comment.created_at)
                %br
                =comment.created_at.strftime("%H:%M:%S")
          -@versioned_items.each do |item|
            -item.versions.each do |version|
              %tr.version-row
                %td.alt-col.icon-col
                  %span.case-history-icon.disp-status-icon{:data => {:history_kind => "version"}}
                %td
                  %span.case-history-author
                    =whodunnit_helper(version)
                  -version.changeset.each do |field, (changed_from, changed_to) |
                    %span.case-history-preview
                      =field_changeset_handler(field, changed_from)
                      %span.emphasize #{changed_from}
                      to
                      %span.emphasize #{changed_to}.
                %td.alt-col.case-history-datetime{:data => {:db_date => version.created_at}}
                  = format_date(version.created_at)
                  %br
                  =version.created_at.strftime("%H:%M:%S")

  .col-sm-6.border-section
    .row
      .col-xs-12.highlighted-section-header
        %h1 Communication
        .email-notice-block.customer-facing-notice
          Customer Facing Message
        .communication-toolbar
          %button.new-email-button
            Compose New Email

          -#  Uncomment if / when we decide to have email templates
          -#%button.mng-templates-button
          -#  Manage Email Templates

    .row
      .col-xs-12.email-header-information.hidden
        .email-header-data
          .communication-subject
          .sender-receiver-info
            %span.content-label-sm From
            %span.author-username
            %br
            %span.content-label-sm To
            %span.receiver-email
            %br
            %span.attachment-label#incoming-attachment.hidden
            %span.email-attachments

        .email-response-button-wrapper
          .email-response-buttons
            %button.reply-button
            %button.forward-button
          %span.email-datetime
    .row
      .col-xs-12.email-msg-body
        %pre.email-msg-content

    = render 'escalations/file_rep/disputes/new_email_dialog'



