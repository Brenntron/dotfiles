%input{type:'hidden', name: 'token', value: "#{current_user.authentication_token}"}
%input{type:'hidden', name: 'xml_token', value: "#{xml_token}"}
%input{type:'hidden', name: 'current_user', value: "#{current_user.authentication_token}"}

%h1 Research Data
.row
  .col-xs-12
    #research-tab-toolbar.toolbar
      %div
        %label.toolbar-section-label View Datasets
        %span.toolbar-select-wrapper
          %label.toolbar-button-label.esc-tooltipped.icon-threat-grid{for: 'data-show-tg-cb', title: 'Threat Grid'}
            %input.dataset-cb.toolbar-checkbox#data-show-tg-cb{type: 'checkbox', checked: 'checked'}
            %span.toolbar-button-text
              Threat Grid
          %label.toolbar-button-label.esc-tooltipped.icon-reversing-labs{for: 'data-show-reversing-cb', title: 'Reversing Labs'}
            %input.dataset-cb.toolbar-checkbox#data-show-reversing-cb{type: 'checkbox', checked: 'checked'}
            %span.toolbar-button-text
              Reversing Labs
      %div
        %label.toolbar-section-label Data
        %button.toolbar-button.sync-button#file-rep-sync-button.esc-tooltipped{title: 'Refresh Data', onclick: 'refresh_research_data()'}
          %span.toolbar-button-text Refresh Data
      %div#resubmit-to-resources
        %label.toolbar-section-label Reports
        %span.toolbar-select-wrapper
          %label.toolbar-button-label.esc-tooltipped.icon-threat-grid{for: 'data-resubmit-tg-cb', title: 'Threat Grid'}
            %input.rerun-dataset-cb.toolbar-checkbox#data-resubmit-tg-cb{type: 'checkbox', checked: 'checked', 'data-service': 'threatgrid'}
            %span.toolbar-button-text
              Threat Grid
          %label.toolbar-button-label.esc-tooltipped.icon-reversing-labs-light.not-available{for: 'data-resubmit-reversing-cb', title: 'Reversing Labs'}
            %input.rerun-dataset-cb.toolbar-checkbox#data-resubmit-reversing-cb{type: 'checkbox', 'data-service':'reversinglab', disabled:true}
            %span.toolbar-button-text
              Reversing Labs
        %button.toolbar-button.icon-reports#file-rep-resubmit-evaluate-button.esc-tooltipped{title: 'Rerun Sample', onclick: 'evaluate_file()'}
          %span.toolbar-button-text Rerun Sample

.row
  .col-xs-12.col-sm-6#threatgrid-report-wrapper
    %h2.research-data-header.threatgrid-header Threat Grid
    #tg-loader
      .inline-loader-wrapper
        .gear-loader-wrapper
          = inline_svg 'icon_gears_loader.svg', class: 'gears-loader'
        %span.loader-msg Loading data...
    .tg-data-present
      %span.sample-present-true
      %div.data-report-wrapper
        .row
          .col-xs-4.col-xl-4
            %label.data-report-label Submitted to TG
            %span.data-report-content#tg-submission-date
          .col-xs-4.col-xl-5
            %label.data-report-label Run Status
            %span.data-report-content#tg-run-status
          .col-xs-4.col-xl-3.text-right
            .data-report-score#tg-score
            %label.content-label-sm TG Score
        %hr.thin
        .row
          .col-xs-12
            %label.data-report-label Tags
            %span.data-report-content#tg-tags
        %hr.thin
        .row
          .col-xs-12
            %label.data-report-label Behaviors
            %table.data-report-table#tg-behaviors
              %thead
                %tr
                  %th Name
                  %th Threat
                  %th Title
        %hr.thin
        .row
          .col-xs-6
            %label.data-report-label Full Json
          .col-xs-6#tg-full-json
            %button.expand-toggle-button.tooltipped{'data-toggle': 'collapse', 'aria-expanded': true, 'data-target': "#collapse_tg_json", 'aria-controls': "collapse_tg_json", 'title': 'Expand / Collapse'}
            %button.download-small-button.tooltipped#download-tg-json{'title': 'Download JSON'}
        .row.collapse_area.collapse.in#collapse_tg_json
          .col-xs-12.report-size
            %pre.data-report-code-content#tg-full
    .tg-data-missing.text-center
      %span.sample-present-false
      %div.data-report-wrapper
        %span.missing-data#threatgrid-status-message Not in ThreatGrid
        %br
        %button.primary#send-to-threatgrid{ onclick:'evaluate_file("threatgrid")' }
          Push Sample to ThreatGrid
    .tg-report-run.text-center
      %div.data-report-wrapper.missing-data
        Sample is running.
        %br Running a sample can take 10 minutes or longer.

  .col-xs-12.col-sm-6#reversing-labs-report-wrapper
    %h2.research-data-header.reversinglab-header Reversing Labs
    #rl-loader
      .inline-loader-wrapper
        .gear-loader-wrapper
          = inline_svg 'icon_gears_loader.svg', class: 'gears-loader'
        %span.loader-msg Loading data...
    .rl-data-present
      %span.sample-present-true
      %div.data-report-wrapper
        .row
          .col-xs-4.col-lg-4
            %label.data-report-label First Seen
            %span.data-report-content#rl-first-seen-date
          .col-xs-4.col-lg-5
            %label.data-report-label Most Recent Scan
            %span.data-report-content#rl-most-recent-date
          .col-xs-4.col-lg-3.text-right
            .data-report-score#rl-scanner-results
            %label.content-label-sm Scanner Results
        %hr.thin
        .row
          .col-xs-12
            %table.data-report-table#rl-scanner-table
              %thead
                %tr
                  %th AV Vendor
                  %th Time Scanned
                  %th Results
    .rl-data-missing.text-center
      %span.sample-present-false
      %div.data-report-wrapper
        %span.missing-data Not in Reversing Labs


