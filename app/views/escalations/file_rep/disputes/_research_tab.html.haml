%input{type:'hidden', name: 'token', value: "#{current_user.authentication_token}"}
%input{type:'hidden', name: 'xml_token', value: "#{xml_token}"}
%input{type:'hidden', name: 'current_user', value: "#{current_user.authentication_token}"}

%h1 Research Data
.row
  .col-xs-12
    #research-tab-toolbar.toolbar
      %div
        %label.toolbar-section-label View Datasets
        %span.toolbar-select-wrapper
          %label.toolbar-button-label.esc-tooltipped.icon-talos-sandbox{for: 'data-show-sandbox-cb', title: 'Talos Sandbox'}
            %input.toolbar-checkbox#data-show-sandbox-cb{type: 'checkbox', checked: 'checked'}
            %span.toolbar-button-text
              Talos Sandbox
          %label.toolbar-button-label.esc-tooltipped.icon-threat-grid{for: 'data-show-tg-cb', title: 'Threat Grid'}
            %input.toolbar-checkbox#data-show-tg-cb{type: 'checkbox', checked: 'checked'}
            %span.toolbar-button-text
              Threat Grid
          %label.toolbar-button-label.esc-tooltipped.icon-reversing-labs{for: 'data-show-reversing-cb', title: 'Reversing Labs'}
            %input.toolbar-checkbox#data-show-reversing-cb{type: 'checkbox', checked: 'checked'}
            %span.toolbar-button-text
              Reversing Labs
      %div
        %label.toolbar-section-label Layout View
        %span.toolbar-select-wrapper
          %label.toolbar-button-label.esc-tooltipped.icon-show-as-columns{for: 'data-show-as-columns', title: 'Column View'}
            %input.toolbar-checkbox#data-show-columns{type: 'radio', checked: 'checked'}
            %span.toolbar-button-text
              Column View
          %label.toolbar-button-label.esc-tooltipped.icon-show-as-stacked{for: 'data-show-as-stacked', title: 'Stacked View'}
            %input.toolbar-checkbox#data-show-as-stacked{type: 'radio'}
            %span.toolbar-button-text
              Stacked View
      %div
        %label.toolbar-section-label Data
        %button.toolbar-button.sync-button.esc-tooltipped{title: 'Refresh Data'}
          %span.toolbar-button-text Refresh Data

.row
  .col-xs-12.col-sm-4
    %h2.research-data-header.sandbox-header Talos Sandbox
    -# if file sample is in sandbox, display most recent run info here
    %span.sample-present-true
    -#  else display this
    -# %span.sample-present-false
    %div.data-report-wrapper
      -# The below is placeholder for visual data that will be formatted from the returned api call to the sandbox
      .row
        .col-xs-3
          %label.data-report-label
            Latest Run
          %span.data-report-content
            2012-12-12T12:12:12Z
        .col-xs-3
          %label.data-report-label
            Run Status
          %span.data-report-content
            Completed
        .col-xs-4
          %button.secondary.view-report-external-button
            View HTML Report
        .col-xs-2.text-right
          .data-report-score
            29
          %label.content-label-sm
            Sandbox Score


  .col-xs-12.col-sm-4#threatgrid-report-wrapper
    %h2.research-data-header.threatgrid-header Threat Grid
    .tg-data-present
      %span.sample-present-true
      %div.data-report-wrapper
        .row
          .col-xs-4
            %label.data-report-label Submitted to TG
            %span.data-report-content#tg-submission-date
          .col-xs-4
            %label.data-report-label Run Status
            %span.data-report-content#tg-run-status
          .col-xs-4.text-right
            .data-report-score#tg-score
            %label.content-label-sm TG Score

        %hr.thin
        .row
          .col-xs-12
            %label.data-report-label Tags
            %span.data-report-content#tg-tags
        %hr.thin
        .row
          .col-xs-12
            %label.data-report-label Behaviors
            %table.data-report-table#tg-behaviors
              %thead
                %tr
                  %th Name
                  %th Threat
                  %th Title
        %hr.thin
        .row
          .col-xs-12
            %label.data-report-label Full Json
            %pre.data-report-code-content#tg-full
    .tg-data-missing.text-center
      %span.sample-present-false
      %div.data-report-wrapper
        %span.missing-data Not in ThreatGrid
        %br
        %button.primary
          Push Sample to ThreatGrid


  .col-xs-12.col-sm-4#reversing-labs-report-wrapper
    %h2.research-data-header.reversing-labs-header Reversing Labs
    .rl-data-present
      %span.sample-present-true
      %div.data-report-wrapper
        .row
          .col-xs-4
            %label.data-report-label First Seen
            %span.data-report-content#rl-first-seen-date
          .col-xs-4
            %label.data-report-label Most Recent Scan
            %span.data-report-content#rl-most-recent-date
          .col-xs-4.text-right
            .data-report-score#rl-scanner-results
            %label.content-label-sm Scanner Results
        %hr.thin
        .row
          .col-xs-12
            %table.data-report-table#rl-scanner-table
              %thead
                %tr
                  %th AV Vender
                  %th Time Scanned
                  %th Results
    .rl-data-missing.text-center
      %span.sample-present-false
      %div.data-report-wrapper
        %span.missing-data Not in Reversing Labs
