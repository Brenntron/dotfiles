.content-wrapper
  %h1 AMP Naming Conventions Details
  .row
    .col-xs-12
      -# If user has role to edit AMP Naming Conventions, show this button
      %button.primary.edit-button#amp-edit-button{onclick: 'edit_amp_naming_conventions();'} Edit AMP Naming Conventions
  .row
    .col-xs-12
      %table.table.responsive#amp-naming-details-table
        %thead
          %tr
            %th Pattern
            %th Example
            %th Engine
            %th Engine Description
            %th Notes
            %th Public Facing Notes
            %th Point of Contact
        %tbody
          - @conventions.each do |convention|
            -# Hard coding this temporarily. Need to convert to database and actual data
            %tr{'data-sort-sequence': "#{convention.table_sequence}", 'data-id': "#{convention.id}"}
              %td
                %span.table-content
                  %span.table-code= convention.pattern
                %span.table-form-content
                  %input{type: 'text'}
              %td
                %span.table-content
                  = convention.example
                %span.table-form-content
                  %input{type: 'text'}
              %td
                %span.table-content
                  = convention.engine
                %span.table-form-content
                  %input{type: 'text'}
              %td
                %span.table-content
                  = convention.engine_description
                %span.table-form-content
                  %textarea
              %td
                %span.table-content
                  = convention.notes
                %span.table-form-content
                  %textarea
              %td
                %span.table-content
                  = convention.public_notes
                %span.table-form-content
                  %textarea
              %td
                %span.table-content
                  = convention.contact
                %span.table-form-content
                  %textarea
