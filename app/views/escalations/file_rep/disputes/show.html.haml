-#view single record
.row
  .col-xs-12.col-sm-6
    .content-wrapper.top-case-info.ticket-overview-wrapper
      %h4 Ticket Overview
      .row
        .col-xs-12.col-sm-12.col-md-12.col-lg-5
          .row
            .col-xs-7.col-sm-7.col-with-divider
              %label.content-label-sm
                Case ID
              .top-info-data.case-id-tag
                = @file_rep_dispute.id.to_s.rjust(10, '0')
              %label.content-label-sm
                Status
              -#  Add ruby code for status here
              %span.dropdown.top-info-data
                %button#show-edit-ticket-status-button.inline-select-dropdown.ticket-status-button.dropdown-toggle{title:'Edit Ticket Status', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false',  }
                  - if @file_rep_dispute.status.nil?
                    NEW
                  - else
                    = @file_rep_dispute.status

                .dropdown-menu.inline-dropdown-menu#show-edit-ticket-status-dropdown{'aria-labelledby': 'show-edit-ticket-status-button'}
                  %ul
                    %li.status-radio-wrapper
                      %input.ticket-status-radio{type: 'radio', name: 'file-dispute-status', id: 'file-status-new', value: 'NEW'}
                      %label.radio-label.ticket-status-radio-label{for:'file-status-new'} New
                    %li.status-radio-wrapper
                      %input.ticket-status-radio{type: 'radio', name: 'file-dispute-status', id: 'file-status-researching', value: 'RESEARCHING'}
                      %label.radio-label.ticket-status-radio-label{for:'file-status-researching'} Researching
                    %li.status-radio-wrapper
                      %input.ticket-status-radio{type: 'radio', name: 'file-dispute-status', id: 'file-status-escalated', value: 'ESCALATED'}
                      %label.radio-label.ticket-status-radio-label{for:'file-status-escalated'} Escalated
                    %li.status-radio-wrapper
                      %input.ticket-status-radio{type: 'radio', name: 'file-dispute-status', id: 'file-status-pending', value: 'PENDING'}
                      %label.radio-label.ticket-status-radio-label{for:'file-status-pending'} Customer Pending
                    %li.status-radio-wrapper
                      %input.ticket-status-radio{type: 'radio', name: 'file-dispute-status', id: 'file-status-onhold', value: 'ONHOLD'}
                      %label.radio-label.ticket-status-radio-label{for:'file-status-onhold'} On Hold
                    %li.status-radio-wrapper
                      %input.ticket-status-radio{type: 'radio', name: 'file-dispute-status', id: 'file-status-assigned', value: 'ASSIGNED'}
                      %label.radio-label.ticket-status-radio-label{for:'file-status-assigned'} Assigned
                    %li.status-radio-wrapper
                      %input.ticket-status-radio{type: 'radio', name: 'file-dispute-status', id: 'file-status-closed', value: 'RESOLVED'}
                      %label.radio-label.ticket-status-radio-label{for:'file-status-closed'} Resolved / Closed


            .col-xs-5.col-sm-5.col-with-divider
              %label.content-label-sm
                Assignee
              .top-info-data
                - if @file_rep_dispute.assigned.nil? || @file_rep_dispute.assigned == 'Unassigned'
                  %span.missing-data "Unassigned"
                - else
                  %span= @file_rep_dispute.assigned.cvs_username

                -# dbinebri: placing the take/change/return buttons here for now, retaining the commented logic after
                .dispute-owner-buttons-wrapper
                  %button.return-ticket-button.esc-tooltipped{title: 'Return Ticket To Open Queue'}
                  %button.take-ticket-button#show_ticket_assign.esc-tooltipped{title: 'Assign this ticket to me'}
                  %button#index_change_assign.dispute-inline-buttons.ticket-owner-button.dropdown-toggle.esc-tooltipped{title: 'Change Assignee', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}

                -#- if @dispute.assignee == 'Unassigned'
                -#  %span.missing-data#dispute-assignee= @dispute.assignee || "None"
                -#- else
                -#  %span= @dispute.assignee || "None"
