<%= simple_form_for (@rulehit_resolution_mailer_template), :url => escalations_rulehit_resolution_mailer_template_path do |f| %>
  <%= f.error_notification %>

  <div class="form-inputs">
    <%= f.input :mnemonic %>
    <%= f.input :to %>
    <%= f.input :cc %>
    <%= f.input :subject %>
    <%= f.input :body %>
  </div>

  <div class="form-actions">
    <%= f.button :submit %>
  </div>
<% end %>
<script>
    $( document ).ready(function() {
        $('body').addClass('escalations--webrep--disputes-controller')
    });
</script>