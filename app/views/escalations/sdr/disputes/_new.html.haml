%form#new-sdr-dispute-form{method: 'get', 'accept-charset': 'UTF-8'}

  .form-group
    %input{type:'hidden', name: 'token', value: "#{current_user.authentication_token}"}
    %input{type:'hidden', name: 'xml_token', value: "#{xml_token}"}
    %input{type:'hidden', name: 'current_user', value: "#{current_user.authentication_token}"}

  .form-group
    .dispute-error-inline.hidden
      Invalid URL detected
      %a.new-dispute-close.close ×

  .form-group
    %label.content-label-sm Sender Domain
    %input.form-control

  .form-group
    %label.content-label-sm Priority
    %select.form-control.priority{name:'priority'}
      %option P1
      %option P2
      %option{:selected => 'selected'} P3
      %option P4
      %option P5

  .form-group
    %label.content-label-sm Reputation
    %select.form-control{name:'reputation'}
      %option{:selected => 'selected', :value => 'false positive'} False Positive
      %option{:value => 'false negative'} False Negative

  .form-group
    %label.content-label-sm Platform
    %input.form-control#platforms{list: 'sdr-platform-list', required: true}
      %datalist#sdr-platform-list

  .form-group
    %label.content-label-sm Customer
    %input.form-control#customers{list: 'sdr-customer-list'}
      %datalist#sdr-customer-list

  %hr.thin
  .form-group.text-center
    %button.primary{value: 'submit', type: 'button', class:'submit_new_dispute', onclick: 'window.submit_new_dispute(this); return false;'}
      Create
    %button.secondary#cancel_sdr_dispute{value: 'cancel',type: 'button'}
      Cancel
