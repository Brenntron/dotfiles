              No data
            %hr.thin
          .col-xs-2
            %h5 CREATED
            %hr.thin
            %p#umbrellaCreated.missing-data
              No data
            %hr.thin
      %hr.thin
      .row
        .col-xs-12
          %h4 BEAKER
        .col-xs-12
          %pre#beakerCodeBlock.code-snippet.code-block
            = @beaker_info
        .col-xs-12.sdr-entries
          - @dispute.sender_domain_reputation_dispute_attachments.each do |attachment|
            %a= attachment.file_name
            %button.expand-row-button-inline
            %hr.thin
    .sdr-research-data-missing.text-center
      %span.missing-data
        No data
