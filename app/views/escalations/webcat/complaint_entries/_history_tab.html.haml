.row.ce-history-tab
  .col-xs-12.ce-history-column
    %h1.ce-tab-title
      History

    %h2 Domain History
    %table.data-report-table.bottom-divider#ce_domain_history_table
      %thead
        %tr
          %th Action
          %th Confidence
          %th Description
          %th Time
          %th User
          %th Category
      %tbody#ce_domain_history_table_body
    .loader-div#ce_domain_history_loader
      .gear-loader-wrapper
        = inline_svg 'icon_gears_loader.svg'
        %span.loader-msg Loading...

    %h2 Entry History
    %table.data-report-table.bottom-divider#ce_entry_history_table
      %thead
        %tr
          %th Time
          %th User
          %th Changes
      %tbody#ce_entry_history_table_body
    .loader-div#ce_entry_history_loader
      .gear-loader-wrapper
        = inline_svg 'icon_gears_loader.svg'
      %span.loader-msg Loading...

    %h2 XBRS Timeline
    %table.data-report-table.bottom-divider#ce_xbrs_history_table
      %thead
        %tr
          %th Timestamp
          %th Score
          %th V2 Content Cats
          %th V3 Content Cats
          %th Threat Cats
          %th Rule Hits
      %tbody#ce_xbrs_history_table_body
    .loader-div#ce_xbrs_history_loader
      .gear-loader-wrapper
        = inline_svg 'icon_gears_loader.svg'
      %span.loader-msg Loading...

