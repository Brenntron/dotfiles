= form_for NamedSearch.new, url: escalations_webcat_complaint_entries_path, method: 'get', 'accept-charset': 'UTF-8', html: {id: 'cat_named_search'} do |named_form|
  -# Default search criteria
  .form-group.search-item
    %label.content-label-sm{for: 'ip_or_uri'} Complaint (URL/IP/Domain)
    %input.form-control.selectize#complaint-input{name: 'ip_or_uri', multiple: 'multiple', tabindex:'-1'}
    %button#remove-criteria-complaint.remove-input{onclick:'clearSelectize("complaint-input")'}

  .form-group.search-item
    %label.content-label-sm{for: 'company-input'} Submitter Org
    %select.form-control.selectize#company-input{name: 'company-input', multiple: 'multiple', tabindex:'-1'}
    %button#remove-criteria-company.remove-input{onclick:'clearSelectize("company-input")'}

  .form-group.search-item
    %label.content-label-sm{for: 'channel'} Added Through Channel
    %input.form-control.selectize#channel-input{name: 'channel', list: 'channel-input-list', multiple: 'multiple', tabindex:'-1'}
    %datalist#channel-input-list
    %button#remove-criteria-channel.remove-input{onclick:'clearSelectize("channel-input")'}

  .form-group.search-item
    %label.content-label-sm{for: 'status'} Status
    %input.form-control.selectize#status-input{name: 'status', multiple: 'multiple', tabindex:'-1'}
    %button#remove-criteria-status.remove-input{onclick:'clearSelectize("status-input")'}

  .form-group.search-item
    %label.content-label-sm{for: 'date-submitted-newer'} Date Submitted (Newer)
    %input.form-control#submitted-newer-input{name: 'date-submitted-newer', type: 'date'}
    %button#remove-criteria-submitted-newer.remove-input

  .form-group.search-item
    %label.content-label-sm{for: 'tags'} Tags
    %select.form-control.selectize#tags-input{name: 'tags', multiple: 'multiple', tabindex:'-1'}
    %input.hidden#search_tag_list{value: ComplaintTag.all.sort_by(&:name).map { |tag| tag.name }.join(','), name: 'tags'}
    %button#remove-criteria-tags.remove-input{onclick:'clearSelectize("tags-input")'}

  -# Additional search criteria
  .form-group.search-item.hidden
    %label.content-label-sm Assignee
    %select.form-control.selectize#assignee-input{name: 'assignee-input', multiple: 'multiple', tabindex:"-1"}
    %button#remove-criteria-assignee.remove-input{onclick:'clearSelectize("assignee-input")'}

  .form-group.search-item.hidden
    %label.content-label-sm Category
    %select.form-control.selectize#category-input{name: 'category-input', multiple: 'multiple', tabindex:'-1'}
    %button#remove-criteria-category.remove-input{onclick:'clearSelectize("category-input")'}

  .form-group.search-item.hidden
    %label.content-label-sm Entry ID
    %input.form-control.selectize#entryid-input{name: 'entry_id', multiple: 'multiple', tabindex:'-1'}
    %button#remove-criteria-entryid.remove-input{onclick:'clearSelectize("entryid-input")'}

  .form-group.search-item.hidden
    %label.content-label-sm Complaint ID(s) (comma separate multiples)
    %input.form-control.selectize#complaintid-input{name: 'complaint_id', multiple: 'multiple', tabindex:'-1'}
    %button#remove-criteria-complaintid.remove-input{onclick:'clearSelectize("complaintid-input")'}

  .form-group.search-item.hidden
    %label.content-label-sm Jira ID(s) (comma separate multiples)
    %input.form-control.selectize#jiraid-input{name: 'jira_id', multiple: 'multiple', tabindex:'-1', placeholder: 'ex: SDOCS-123'}
    %button#remove-criteria-jiraid.remove-input{onclick:'clearSelectize("jiraid-input")'}

  .form-group.search-item.hidden
    %label.content-label-sm Resolution
    %input.form-control.selectize#resolution-input{name: 'resolution', multiple: 'multiple', tabindex:'-1'}
    %button#remove-criteria-resolution.remove-input{onclick:'clearSelectize("resolution-input")'}
  
  .form-group.search-item.hidden
    %label.content-label-sm Submitter Type
    %input.form-control.selectize#submitter-type-input{name: 'submitter-type', multiple: 'multiple', tabindex: '-1', data: 'webcat'}
    %button#remove-criteria-submitter-type.remove-input{onclick: 'clearSelectize("submitter-type-input")'}

  .form-group.search-item.hidden
    %label.content-label-sm Submitter Name
    %input.form-control.selectize#name-input{name: 'customer-name', multiple: 'multiple', tabindex:'-1'}
    %button#remove-criteria-customer-name.remove-input{onclick:'clearSelectize("name-input")'}

  .form-group.search-item.hidden
    %label.content-label-sm Submitter Email
    %input.form-control#email-input{name: 'customer-email', list: 'customerEmailList'}
    %datalist#customerEmailList
    %button#remove-criteria-customer-email.remove-input

  .form-group.search-item.hidden
    %label.content-label-sm Platform
    %input.form-control.selectize#platform-input{name: 'platform', multiple: 'multiple', tabindex: '-1', data: 'webcat'}
    %button#remove-criteria-platform.remove-input{onclick: 'clearSelectize("platform-input")'}

  .form-group.search-item.hidden
    %label.content-label-sm Date Submitted (Older)
    %input.form-control#submitted-older-input{name: 'date-submitted-older', type: 'date'}
    %button#remove-criteria-submitted-older.remove-input

  .form-group.search-item.hidden
    %label.content-label-sm Last Modified (Newer)
    %input.form-control#modified-newer-input{type: 'date', name: 'date-modified-newer'}
    %button#remove-criteria-modified-newer.remove-input

  .form-group.search-item.hidden
    %label.content-label-sm Last Modified (Older)
    %input.form-control#modified-older-input{type: 'date', name: 'date-modified-older'}
    %button#remove-criteria-modified-older.remove-input

  .form-group-wrapper-relative
    %button#add-search-items-button
      Add Search Criteria
    #search-criteria-options
      .multicol-2
        %ul
          -# Default shown options
          %li.hidden
            %label.search-criteria-label
              %input.search-checkbox#complaint-cb{type: 'checkbox', name: 'search-criteria', value: 'Complaint (URL/IP/Domain)', for: 'complaint-input'}
              Complaint (URL/IP/Domain)
          %li.hidden
            %label.search-criteria-label
              %input.search-checkbox#company-cb{type: 'checkbox', name: 'search-criteria', value: 'Submitter Org', for: 'company-input'}
              Submitter Org
          %li.hidden
            %label.search-criteria-label
              %input.search-checkbox#channel-cb{type: 'checkbox', name: 'search-criteria', value: 'Added Through Channel', for: 'channel-input'}
              Added Through Channel
          %li.hidden
            %label.search-criteria-label
              %input.search-checkbox#status-cb{type: 'checkbox', name: 'search-criteria', value: 'Status', for: 'status-input'}
              Status
          %li.hidden
            %label.search-criteria-label
              %input.search-checkbox#submitted-newer-cb{type: 'checkbox', name: 'search-criteria', value: 'Date Submitted (Newer)', for: 'submitted-newer-input'}
              Date Submitted (Newer)
          %li.hidden
            %label.search-criteria-label
              %input.search-checkbox#tags-cb{type: 'checkbox', name: 'search-criteria', value: 'Tags', for: 'tags-input-selectized'}
              Tags
          -#  Default hidden options below
          %li
            %label.search-criteria-label
              %input.search-checkbox#category-cb{type: 'checkbox', name: 'search-criteria', value: 'Category', for: 'category-input'}
              Category
          %li
            %label.search-criteria-label
              %input.search-checkbox#assignee-cb{type: 'checkbox', name: 'search-criteria', value: 'Assignee', for: 'assignee-input'}
              Assignee
          %li
            %label.search-criteria-label
              %input.search-checkbox#entry-id-cb{type: 'checkbox', name: 'search-criteria', value: 'Entry ID', for: 'entryid-input'}
              Entry ID
          %li
            %label.search-criteria-label
              %input.search-checkbox#complaint-id-cb{type: 'checkbox', name: 'search-criteria', value: 'Complaint ID', for: 'complaintid-input'}
              Complaint ID
          %li
            %label.search-criteria-label
              %input.search-checkbox#jira-id-cb{type: 'checkbox', name: 'search-criteria', value: 'Jira ID', for: 'jiraid-input'}
              Jira ID
          %li
            %label.search-criteria-label
              %input.search-checkbox#resolution-cb{type: 'checkbox', name: 'search-criteria', value: 'Resolution', for: 'resolution-input'}
              Resolution
          %li
            %label.search-criteria-label
              %input.search-checkbox#submitter-type-cb{type: 'checkbox', name: 'search-criteria', value: 'Submitter Type', for: 'submitter-type-input'}
              Submitter Type
          %li
            %label.search-criteria-label
              %input.search-checkbox#name-cb{type: 'checkbox', name: 'search-criteria', value: 'Submitter Name', for: 'name-input'}
              Submitter Name
          %li
            %label.search-criteria-label
              %input.search-checkbox#email-cb{type: 'checkbox', name: 'search-criteria', value: 'Submitter Email', for: 'email-input'}
              Submitter Email
          %li
            %label.search-criteria-label
              %input.search-checkbox#platform-cb{type: 'checkbox', name: 'search-criteria', value: 'Platform', for: 'platform-input'}
              Platform
          %li
            %label.search-criteria-label
              %input.search-checkbox#submitted-older-cb{type: 'checkbox', name: 'search-criteria', value: 'Date Submitted (Older)', for: 'submitted-older-input'}
              Date Submitted (Older)
          %li
            %label.search-criteria-label
              %input.search-checkbox#modified-newer-cb{type: 'checkbox', name: 'search-criteria', value: 'Last Modified (Newer)', for: 'modified-newer-input'}
              Last Modified (Newer)
          %li
            %label.search-criteria-label
              %input.search-checkbox#modified-older-cb{type: 'checkbox', name: 'search-criteria', value: 'Last Modified (Older)', for: 'modified-older-input'}
              Last Modified (Older)

      .form-group.text-center
        %button.tertiary#cancel-add-criteria
          Close

  %hr.thin
  .form-group
    %label.content-label-sm
      Add Name to save this search criteria to My Saved Searches
    %input.form-control{name: 'search_name', :type => 'text', :maxlength => '50'}
  .form-group.text-center
    %button.primary#submit-advanced-search{type: 'button', value: 'submit', onclick: 'set_webcat_advanced();'}
      Submit Search
    %button.secondary#reset-advanced-search.reset{type: 'button', onclick: 'webcat_reset_search();'}
      Reset Search



-# Fetch user preferences for which fields to display in the advanced search
:javascript

  $(document).ready( function() {
    window.set_advanced_search_pref();
  });


