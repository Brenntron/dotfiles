= form_for NamedSearch.new, url: escalations_webcat_complaint_entries_path, method: 'get', 'accept-charset': 'UTF-8', html: {id: 'cat_named_search'} do |named_form|
  -# Default search criteria
  .form-group.search-item
    %label.content-label-sm{for: 'ip_or_uri'} Complaint (URL/IP/Domain)
    %input.form-control.selectize#complaint-input{name: 'ip_or_uri', multiple: 'multiple'}
    %button.remove-input{onclick:'clearSelectize("complaint-input")'}

  .form-group.search-item
    %label.content-label-sm{for: 'company-input'} Company
    %select.form-control.selectize#company-input{name: 'company-input', multiple: 'multiple', tabindex:"-1"}
    %button.remove-input{onclick:'clearSelectize("company-input")'}

  .form-group.search-item
    %label.content-label-sm{for: 'channel'} Added Through Channel
    %input.form-control.selectize#channel-input{name: 'channel', list: 'channel-input-list', multiple: 'multiple'}
    %datalist#channel-input-list
    %button.remove-input{onclick:'clearSelectize("channel-input")'}

  .form-group.search-item
    %label.content-label-sm{for: 'status'} Status
    %input.form-control.selectize#status-input{name: 'status', multiple: 'multiple', tabindex:"-1"}
    %button.remove-input{onclick:'clearSelectize("status-input")'}

  .form-group.search-item
    %label.content-label-sm{for: 'date-submitted-newer'} Date Submitted (Newer)
    %input.form-control#submitted-newer-input{name: 'date-submitted-newer', type: 'date'}
    %button.remove-input

  .form-group.search-item
    %label.content-label-sm{for: 'tags'} Tags
    %select.form-control.selectize#tags-input{name: 'tags', multiple: 'multiple', tabindex:"-1"}
    %input.hidden#search_tag_list{value: ComplaintTag.all.map { |tag| tag.name }.join(','), name: 'tags'}
    %button.remove-input{onclick:'clearSelectize("tags-input")'}

  -# Additional search criteria
  .form-group.search-item.hidden
    %label.content-label-sm Category
    %select.form-control.selectize#category-input{name: 'category-input', multiple: 'multiple', tabindex:"-1"}
    %button.remove-input{onclick:'clearSelectize("category-input")'}

  .form-group.search-item.hidden
    %label.content-label-sm Entry ID
    %input.form-control.selectize#entryid-input{name: 'entry_id', multiple: 'multiple'}
    %button.remove-input{onclick:'clearSelectize("entryid-input")'}

  .form-group.search-item.hidden
    %label.content-label-sm Complaint ID(s) (comma separate multiples)
    %input.form-control.selectize#complaintid-input{name: 'complaint_id', multiple: 'multiple'}
    %button.remove-input{onclick:'clearSelectize("complaintid-input")'}

  .form-group.search-item.hidden
    %label.content-label-sm Resolution
    %input.form-control.selectize#resolution-input{name: 'resolution', multiple: 'multiple', tabindex:"-1"}
    %button.remove-input{onclick:'clearSelectize("resolution-input")'}

  .form-group.search-item.hidden
    %label.content-label-sm Customer Name
    %input.form-control.selectize#name-input{name: 'customer-name', multiple: 'multiple', tabindex:"-1"}
    %button.remove-input{onclick:'clearSelectize("name-input")'}

  .form-group.search-item.hidden
    %label.content-label-sm Customer Email
    %input.form-control#email-input{name: 'customer-email', list: 'customerEmailList'}
    %datalist#customerEmailList
    %button.remove-input

  .form-group.search-item.hidden
    %label.content-label-sm Date Submitted (Older)
    %input.form-control#submitted-older-input{name: 'date-submitted-older', type: 'date'}
    %button.remove-input

  .form-group.search-item.hidden
    %label.content-label-sm Last Modified (Newer)
    %input.form-control#modified-newer-input{type: 'date', name: 'date-modified-newer'}
    %button.remove-input

  .form-group.search-item.hidden
    %label.content-label-sm Last Modified (Older)
    %input.form-control#modified-older-input{type: 'date', name: 'date-modified-older'}
    %button.remove-input

  %button#add-search-items-button
    Add Search Criteria
  #search-criteria-options
    .multicol-2
      %ul
        -# Default shown options
        %li.hidden
          %label.search-criteria-label
            %input.search-checkbox#complaint-cb{type: 'checkbox', name: 'search-criteria', value: 'Complaint (URL/IP/Domain)', for: 'complaint-input'}
            Complaint (URL/IP/Domain)
        %li.hidden
          %label.search-criteria-label
            %input.search-checkbox#company-cb{type: 'checkbox', name: 'search-criteria', value: 'Company', for: 'company-input'}
            Company
        %li.hidden
          %label.search-criteria-label
            %input.search-checkbox#channel-cb{type: 'checkbox', name: 'search-criteria', value: 'Added Through Channel', for: 'channel-input'}
            Added Through Channel
        %li.hidden
          %label.search-criteria-label
            %input.search-checkbox#status-cb{type: 'checkbox', name: 'search-criteria', value: 'Status', for: 'status-input'}
            Status
        %li.hidden
          %label.search-criteria-label
            %input.search-checkbox#submitted-newer-cb{type: 'checkbox', name: 'search-criteria', value: 'Date Submitted (Newer)', for: 'submitted-newer-input'}
            Date Submitted (Newer)
        %li.hidden
          %label.search-criteria-label
            %input.search-checkbox#tags-cb{type: 'checkbox', name: 'search-criteria', value: 'Tags', for: 'tags-input-selectized'}
            Tags
        -#  Default hidden options below
        %li
          %label.search-criteria-label
            %input.search-checkbox#category-cb{type: 'checkbox', name: 'search-criteria', value: 'Category', for: 'category-input'}
            Category
        %li
          %label.search-criteria-label
            %input.search-checkbox#entry-id-cb{type: 'checkbox', name: 'search-criteria', value: 'Entry ID', for: 'entryid-input'}
            Entry ID
        %li
          %label.search-criteria-label
            %input.search-checkbox#complaint-id-cb{type: 'checkbox', name: 'search-criteria', value: 'Complaint ID', for: 'complaintid-input'}
            Complaint ID
        %li
          %label.search-criteria-label
            %input.search-checkbox#resolution-cb{type: 'checkbox', name: 'search-criteria', value: 'Resolution', for: 'resolution-input'}
            Resolution
        %li
          %label.search-criteria-label
            %input.search-checkbox#name-cb{type: 'checkbox', name: 'search-criteria', value: 'Customer Name', for: 'name-input'}
            Customer Name
        %li
          %label.search-criteria-label
            %input.search-checkbox#email-cb{type: 'checkbox', name: 'search-criteria', value: 'Customer Email', for: 'email-input'}
            Customer Email
        %li
          %label.search-criteria-label
            %input.search-checkbox#submitted-older-cb{type: 'checkbox', name: 'search-criteria', value: 'Date Submitted (Older)', for: 'submitted-older-input'}
            Date Submitted (Older)
        %li
          %label.search-criteria-label
            %input.search-checkbox#modified-newer-cb{type: 'checkbox', name: 'search-criteria', value: 'Last Modified (Newer)', for: 'modified-newer-input'}
            Last Modified (Newer)
        %li
          %label.search-criteria-label
            %input.search-checkbox#modified-older-cb{type: 'checkbox', name: 'search-criteria', value: 'Last Modified (Older)', for: 'modified-older-input'}
            Last Modified (Older)

    .form-group.text-center
      %button.primary#add-search-criteria
        Add Search Criteria
      %button.tertiary#cancel-add-criteria
        Cancel

  %hr.thin
  .form-group
    %label.content-label-sm
      Add Name to save this search criteria to My Saved Searches
    %input.form-control{name: 'search_name', :type => 'text', :maxlength => '50'}
  .form-group.text-center
    %button.primary#submit-advanced-search{type: 'button', value: 'submit', onclick: 'set_webcat_advanced();'}
      Submit Search
    %button.secondary#reset-advanced-search.reset{type: 'button', onclick: 'webcat_reset_search();'}
      Reset Search


