.toolbar#webcat-index-toolbar
  %div
    %label.toolbar-section-label
      Open in New Tab
    %button.toolbar-button.open-selected.esc-tooltipped.toolbar-button-spacer{onclick: 'open_selected()', type: 'button', title: 'Open Selected'}
      %span.toolbar-button-text Open Selected
    %button.toolbar-button.open-all.esc-tooltipped{onclick: 'open_all()', type: 'button', title: 'Open All'}
      %span.toolbar-button-text Open All
  %div
    %label.toolbar-section-label
      Edit
    %button.toolbar-button.take-ticket-toolbar-button.esc-tooltipped.toolbar-button-spacer{onclick: 'take_selected()', type: 'button', title: 'Take'}
      %span.toolbar-button-text Take
    %button.toolbar-button.return-ticket-toolbar-button.esc-tooltipped{onclick: 'return_selected()', type: 'button', title: 'Return'}
      %span.toolbar-button-text Return
  %div
    %label.toolbar-section-label
      View Nested Data
    %button.toolbar-button.collapse-button.esc-tooltipped.toolbar-button-spacer{onclick: 'collapse_selected()', type: 'button', title: 'Collapse Selected'}
      %span.toolbar-button-text Collapse Selected
    %button.toolbar-button.collapse-all.esc-tooltipped.toolbar-button-spacer{onclick: 'collapse_all()', type: 'button', title: 'Collapse All'}
      %span.toolbar-button-text Collapse All
    %button.toolbar-button.expand-row-button.esc-tooltipped.toolbar-button-spacer{onclick: 'expand_selected()', type: 'button', title: 'Expand Selected'}
      %span.toolbar-button-text Expand Selected
    %button.toolbar-button.expand-all.esc-tooltipped{type: 'button', title: 'Expand All'}
      %span.toolbar-button-text Expand All
  %div
    %label.toolbar-section-label Data
    %button.toolbar-button.sync-button#fetch.esc-tooltipped.toolbar-button-spacer{ onclick: 'fetch_complaints();', title: 'Fetch Complaints'}
      %span.toolbar-button-text Fetch Complaints
    %button.toolbar-button.sync-button#fetch_wbnp.esc-tooltipped{ onclick: 'fetch_wbnp_data();', title: 'Fetch WBNP Data'}
      %span.toolbar-button-text Fetch WBNP Data
  %div
    %label.toolbar-section-label Bulk
    %button.toolbar-button.master-submit-button#master-submit.esc-tooltipped{ onclick: 'master_submit();', title: 'Submit Changes', disabled: true}
      %span.toolbar-button-text Submit Changes
  %div
    %label.toolbar-section-label
      Pin Toolbar
    %button.toolbar-button.attach-to-top-button#attach-to-top.esc-tooltipped{ onclick: 'attach_to_top();', title: 'Pin Toolbar to Top (or press Cmd/Ctrl + Shift + 6)'}
      %span.toolbar-button-text Pin Toolbar to Top



  %div.toolbar-checkbox-wrapper
    %input{type: 'checkbox', checked: true, id:'self_review'}
      Allow Self Review




