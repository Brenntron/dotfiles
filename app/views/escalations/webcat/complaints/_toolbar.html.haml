.toolbar
  %div
    %label.toolbar-section-label
      Select
    %button.toolbar-button.select-all-button{onclick: 'select_all_pages()', type: 'button'}
      Select All
    %button.toolbar-button.select-none-button{onclick: 'unselect_all_pages()', type: 'button'}
      Unselect All
    %button.toolbar-button.open-viewable-button{onclick: 'open_viewable()', type: 'button'}
      Open Viewable
    %button.toolbar-button.open-selected-button{onclick: 'open_selected()', type: 'button'}
      Open Nonviewable
    %button.toolbar-button.open-selected-button{onclick: 'open_selected()', type: 'button'}
      Open Selected
  %div
    %label.toolbar-section-label
      Edit
    %button.toolbar-button#edit-button{onclick: 'edit_selected_complaints()', type: 'button'}
      Edit Selected
    %button.toolbar-button.take-button{onclick: 'take_selected()', type: 'button'}
      Take Selected
    %button.toolbar-button.return-button{onclick: 'return_selected()', type: 'button'}
      Return Selected
    %button.toolbar-button.url-cat-button{'data-toggle': 'modal', type: 'button', 'data-target': '#cat_new_url_modal'}
      Categorize New URL
  %div
    %label.toolbar-section-label
      View
    %button.toolbar-button.collapse-all-button{onclick: 'collapse_all()', type: 'button'}
      Collapse All
    %button.toolbar-button.collapse-sel-button{onclick: 'collapse_all()', type: 'button'}
      Collapse Selected
    %button.toolbar-button.expand-all-button{onclick: 'collapse_all()', type: 'button'}
      Expand All
    %button.toolbar-button.expand-sel-button{onclick: 'collapse_all()', type: 'button'}
      Expand Selected


