.content-wrapper
  - content_for(:webcat_page) do
    Cluster Management
  - content_for(:webcat_icon) do
    icon-categories

  .cluster-mgt-loader-wrapper.hidden
    .gear-loader-wrapper
      = inline_svg 'icon_gears_loader.svg', class: 'gears-loader'
    %span.loader-msg Loading data...

  .complaint-mgt-top-area.cluster-mgt-top-area
    .row.cluster-title
      .col-xl-3.col-lg-4.col-md-5.col-sm-6.col-xs-12.dashboard-left-data
        %h1= content_for :webcat_page
        %span.top-info-icon{class: "#{content_for :webcat_icon}"}
      .col-xl-9.col-lg-8.col-md-7.col-sm-6.col-xs-12.search-stg
        .row
          .col-xs-10
            .row
              .col-xs-9
                %input#cluster_filter_field.text_field.search-box{placeholder: 'Regex', autofocus: 'true'}
              .col-xs-3.no_pad
                %button.primary{onclick: 'apply_filter_to_table()', class:'apply-filter-btn icon-filter-white'}Apply Filter

  .row
    .col-xs-6.temp-spacer
      .row.default-padding

        .result-label.vertical-separator
          Current Cluster Entries:
          %span#total_results
        .result-label
          Regex:
          %span \d

      .toolbar.cluster-table-toolbar
        .div
          %label.toolbar-section-label View
          %button.toolbar-button.icon-opened-selected.esc-tooltipped{onclick: 'open_selected()', type: 'button', title: 'Open Viewable'}
            %span.toolbar-button-text Open Selected
          %button.toolbar-button.icon-open-all.esc-tooltipped{onclick: 'open_all()', type: 'button', title: 'Open All'}
            %span.toolbar-button-text Open All
        %button.toolbar-button.cat-btn.icon-copycat.esc-tooltipped{'onclick': 'copycat_dialog()', title: 'CopyCat Tool'}
          %span.toolbar-button-text CopyCat Tool

    .col-xs-6.temp-spacer
      .card
        .content-label-sm Comment
        .card-body
          %input.text_field
          %button.toolbar-button.icon-submit{'onclick': 'categorize_clusters()'} Submit Changes

  .row
    .col-xs-12
      %table.table.responsive#clusters-index
        %thead
          %tr
            %th
              -#  Expandable button area
            %th
              %input#clusters_check_box{type: 'checkbox'}
            %th Cluster ID
            %th Cluster Domain
            %th Global Volume
            %th WBRS Score
            %th Categories

#copycat_dialog{title: 'CopyCat Tool'}
  .dialog-content-wrapper
    %select#copycat-categories.selectize{:multiple=>"multiple", :placeholder=>"Add Categories", :value=>"", :name=>""}

  .copycat-tool-footer
    %button.toolbar-button.cat-paste-btn.icon-paste{'onclick': 'copycat_paste()'} Paste Categories
    %button.toolbar-button.cat-clear-btn.icon-clear{'onclick': 'copycat_clear()'} Clear Categories

#whois_dialog{title: 'Domain Lookup Information'}
