- content_for(:webcat_page) do
  Cluster Management
- content_for(:webcat_icon) do
  icon-categories

.content-wrapper

  .cluster-mgt-loader-wrapper.hidden
    .gear-loader-wrapper
      = inline_svg 'icon_gears_loader.svg', class: 'gears-loader'
    %span.loader-msg Loading data...
    %input#user_id{type: 'hidden', name: 'user_id', value: "#{current_user.id}"}
  .complaint-mgt-top-area.cluster-mgt-top-area
    .row
      .col-xl-3.col-lg-4.col-md-5.col-sm-6.col-xs-12
        %h1= content_for :webcat_page
        %span.top-info-icon{class: "#{content_for :webcat_icon}"}
      .col-xl-9.col-lg-8.col-md-7.col-sm-6.col-xs-12
        .row
          .col-xs-9
            %input#cluster_filter_field.text_field.search-box{placeholder: 'Regex', autofocus: 'true'}
          .col-xs-3.no_pad
            %button#cluster_filter_button.primary{onclick: 'apply_filter_to_table()', class:'apply-filter-btn icon-filter-white'}Apply Filter

  .row
    .col-xs-7
      .current-cluster-info-wrapper
        .result-label
          Current Cluster Entries:
          %span#total_results
        .result-label.regex-area.hidden
          Regex:
          %span#regex-filter

    .col-xs-5
      .card
        .content-label-sm Comment
        .card-body
          %input#cluster_comment_field.text_field
          %button.toolbar-button.icon-submit.cluster-comment-btn{'onclick': 'categorize_clusters()'} Submit Changes
  .row
    .col-xs-12
      .toolbar.cluster-table-toolbar
        %div
          %label.toolbar-section-label View
          %button.toolbar-button.icon-opened-selected.esc-tooltipped.toolbar-button-spacer{title: 'Open Viewable', onclick: 'open_selected_clusters()'}
            %span.toolbar-button-text Open Selected
          %button.toolbar-button.icon-open-all.esc-tooltipped{title: 'Open All', onclick: 'open_all_clusters()'}
            %span.toolbar-button-text Open All
        %div
          %label.toolbar-section-label View Nested Data
          %button.toolbar-button.collapse-button.esc-tooltipped.toolbar-button-spacer{onclick: 'collapse_selected_clusters("clusters-index")', type: 'button', title: 'Collapse Selected'}
            %span.toolbar-button-text Collapse Selected
          %button.toolbar-button.collapse-all.esc-tooltipped.toolbar-button-spacer{onclick: 'collapse_all_clusters("clusters-index")', type: 'button', title: 'Collapse All'}
            %span.toolbar-button-text Collapse All
          %button.toolbar-button.expand-row-button.esc-tooltipped.toolbar-button-spacer{onclick: 'expand_selected_clusters("clusters-index")', type: 'button', title: 'Expand Selected'}
            %span.toolbar-button-text Expand Selected
          %button.toolbar-button.expand-all.esc-tooltipped{onclick: 'expand_all_clusters("clusters-index")', type: 'button', title: 'Expand All'}
            %span.toolbar-button-text Expand All
        %button.toolbar-button.copycat-btn.icon-copycat.esc-tooltipped{'onclick': 'copycat_dialog()', title: 'CopyCat Tool'}
          %span.toolbar-button-text CopyCat Tool
        %button.toolbar-button.wsa-btn.icon-telemetry.esc-tooltipped{'onclick': 'open_wsa_status()', title: 'WSA Telemetry Status'}
          %span.toolbar-button-text WSA Telemetry Status
  .row
    .col-xs-12
      %table.table.responsive#clusters-index
        %thead
          %tr
            %th
              -#  Expandable button area
            %th
              %input#clusters_check_box{type: 'checkbox'}
            %th Cluster ID
            %th Cluster Domain
            %th Global Volume
            %th WBRS Score
            %th Categories

#copycat_dialog{title: 'CopyCat Tool'}
  .dialog-content-wrapper
    %select#copycat-categories.selectize{:multiple=>"multiple", :placeholder=>"Add Categories", :value=>"", :name=>""}

  .copycat-tool-footer
    %button.toolbar-button.copycat-paste-btn.icon-paste{'onclick': 'copycat_paste()'} Paste Categories
    %button.toolbar-button.copycat-clear-btn.icon-clear{'onclick': 'copycat_clear()'} Clear All Categories

#wsa_status_dialog{title: 'WSA Telemetry Status'}
  .dialog-content-wrapper
    %input#wsa_statuses.text_field{placeholder: "Search by Companies or Serial Numbers"}
  .wsa-tool-footer
    %button.toolbar-button.wsa-search-status-btn.icon-search{'onclick': 'get_wsa_status()'} Search Statuses

#whois_dialog{title: 'Domain Lookup Information'}
