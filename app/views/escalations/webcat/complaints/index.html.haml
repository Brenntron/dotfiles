:javascript
  $(document).ready(function() {
    $('#complaints-index').DataTable({
      // order: [[3, 'desc']],
      columns: [
        {                                 // checkbox
          data: 'id',
          render: function ( data ) {
              return '<input type="checkbox" name="cbox" class="complaint_check_box" id="cbox' + data + '" value="' + data + '" />';
          }
        },
        {data: "id"},
        // {data: null, defaultContent: ''}, //Priority

        {data: "status"},
        {data: "complaint_entries_count"},
        {data: "complaint_entry_preview"},
        {data: "created_at"},
        {data: "customer"},

      ]
    });
    populate_webcat_index_table();

  } );
