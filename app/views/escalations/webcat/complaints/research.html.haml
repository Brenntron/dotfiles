.content-wrapper.research-page
  .webcat-research-search-wrapper
    -# shared loader for detail and quick lookup
    .ajax-message-div#domainHistoryLoader
      .loader-gears
        =inline_svg 'icon_gears_loader.svg'
      %span.loader-msg Active search processing, please wait...
    .ajax-message-div#xbrsHistoryLoader
      .loader-gears
        =inline_svg 'icon_gears_loader.svg'
      %span.loader-msg Loading data...
    .research-header-wrapper
      %span.icon-research.top-info-icon
      %h1 Categorization Research

      %ul#research-tabs.nav.nav-tabs{role: 'tablist'}
        %li.no-transition.active{role: 'presentation', data: "domain-history"}
          %a.esc-tooltipped.no-transition#webcat-research-domain-history-link{href:'#domain-history','aria-controls':'domain-history', 'aria-label': 'Domain history tab','data-toggle':'tab', role:"tab", title:"Domain History"}
            Domain History
        %li.no-transition{role: 'presentation', data: "xbrs-history"}
          %a.esc-tooltipped.no-transition#webcat-research-xbrs-history-link{href: "#xbrs-history", class: "xbrs-history-tab", 'aria-controls': 'xbrs-history', 'aria-label': 'Xbrs history tab', 'data-toggle': 'tab', role: "tab", title: "XBRS History"}
            XBRS History

      .input-group.search-group#webcat-research-search
        = text_field_tag 'general_search', "#{}", class: 'search-box', placeholder: 'Search'

        %button#advanced-search-button.btn.btn-default.nav-tool-button.dropdown-toggle{'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
          Advanced
        .dropdown-menu.nav-tools-dropdown#advanced-search-dropdown{'aria-labelledby': 'advanced-search-button'}
          %h3.nav-tool-dropdown-header.inverse
            Advanced Search
          #advanced-search-wrapper.nav-tool-content-wrapper
            = render 'escalations/webcat/complaints/advanced_search'

  .domain-table-wrapper
    %table.domain-table
      %thead
        %tr
          %th
            domain
          %th
            current category
          %th
            reputation
      %tbody
        %tr
          %td.domain-table-listing
          %td.domain-table-current-category
          %td.domain-table-reputation

  .toolbar.webcat-research-toolbar
    %div
      %label.toolbar-section-label
        Edit
      %span.dropdown
        %button#webcat-research-categorize-url.webcat-research-categorize-url-button.toolbar-button.dropdown-toggle.esc-tooltipped{title: 'Categorize URL', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
          %span.toolbar-button-text Categorize URL
        %div{'aria-labelledby': 'webcat-research-categorize-url', id: 'categorize-url-dropdown', class: 'dropdown-menu toolbar-dropdown'}
          .selected-urls-wrapper
            %label.selected-urls-label
              Selected URLs
            #selected-urls-list
          .selected-urls-categories-wrapper
            %label.selected-urls-categories-label
              Enter up to 5 categories
            %input.input-group.search-group
            %button{type: 'submit', name: 'commit', id: 'cat-research', class: 'toolbar-button esc-tooltipped', onclick: 'detail_research(); return false', 'data-disable-with': 'Submit'}
              %span.toolbar-button-text
                Submit


  .research-tab-wrapper.tab-content
    .tab-pane.domain-history-pane#domainHistoryPane{role: 'tabpanel'}
      = render 'escalations/webcat/complaints/domain_history_tab'
    .tab-pane#xbrsHistoryPane{role: 'tabpanel'}
      = render 'escalations/webcat/complaints/xbrs_history_tab'
