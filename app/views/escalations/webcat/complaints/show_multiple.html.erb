<% content_for(:webcat_page) do %>
  Complaints Show
<% end %>

<%= render "escalations/webcat/shared/telemetry" %>

<div class="tool-bar">
  <%= render "show_toolbar" %>
</div>
<br>

<input type="hidden" name="token" value="<%= current_user.authentication_token %>">
<input type="hidden" name="current_user_id" value="<%= current_user.id %>">
<input type="hidden" name="xml_token" value="<%= xml_token %>">
<div class="row">
  <div class="col-xs-6">
    <% @complaints.each do |complaint| %>
      <% complaint.complaint_entries.each do |entry| %>
        <div id="complaint_entry_row_<%= entry.id %>" class="row" onclick="display_preview_window('<%=entry.id%>','<%=entry.subdomain%>','<%=entry.domain%>','<%=entry.path%>')">
          <div class="col-xs-12"><p><%= complaint.customer.name%> from <%=complaint.customer.company.name %> | <%=complaint.tag%> </p></div>
          <div class="col-xs-1">
            <%= check_box_tag "#{entry.id}_site_checkbox", '{"site": "' + entry.domain.to_s + '", "viewable": "' + entry.viewable.to_s + '" }' %>
            <div>ID: <%= entry.id %> </div>
          </div>
          <div class="col-xs-8">
            <div>Domain:<br> <%= entry.domain %></div>
            <div>Tag:<br> <%= entry.tag %></div>
            <div>Status: <%= entry.status %></div>
          </div>
          <div class="col-xs-3">
            <div>
              <%= radio_button_tag "complaint_entry_resolution_#{entry.id}", "#{entry.id}_dont_fix", true %>
              <%= label_tag "Dont Fix", nil, title: "Selecting Dont Fix indicates that you have no idea how to categorize the site." %>
              <br>

              <%= radio_button_tag "complaint_entry_resolution_#{entry.id}", "#{entry.id}_fixed", false %>
              <%= label_tag "Fixed", nil, title: "Selecting fixed indicates the category of the site will be changed." %>
              <br>

              <%= radio_button_tag "complaint_entry_resolution_#{entry.id}", "#{entry.id}_unchanged", false %>
              <%= label_tag "unchanged", nil, title: "Selecting unchanged indicates that no change will be made to the category of the site." %>
              <br>

              <%= radio_button_tag "complaint_entry_resolution_#{entry.id}", "#{entry.id}_invalid", false %>
              <%= label_tag "Invalid", nil, title: "Selecting Invalid indicates that currently there is no way to categorize the site at all." %>
              <br>
            </div>
          </div>
        </div>
        <br>
      <% end %>
    <% end %>
  </div>
  <div class="col-xs-6">
    <div class="row">
      <div class="col-xs-12">
        <div class="preview-url">Previewing</div>
        <a id="preview_window_header_a" href="#" target="_blank"><p id="preview_window_header_p"></p></a>
        <div class="embed-responsive embed-responsive-1by1">
          <iframe id="preview_window" class="embed-responsive-item webcat-iframe" src="" sandbox></iframe>
        </div>
      </div>
    </div>
    <div class="row">

      <div class="col-sm-6 col-xs-12">
        <div class="form-group">
          <%= label_tag "Prefix", nil, class: "h4" %><br>
          <%= text_field_tag "complaint_id_x_prefix", nil, placeholder: "Prefix", class: "form-control" %>
          <%= label_tag "Categories", nil, class: "h4" %><br>
          <%= text_field_tag "complaint_id_x_categories", nil, placeholder: "cat1, cat2, cat3, etc...", class: "form-control" %>
        </div>
      </div>
      <div class="col-sm-6 col-xs-12">
        <%= button_tag "mark for commit", type: "submit", class: "btn-lg btn-primary" %>
      </div>
      <div class="col-xs-12">
        <div class="form-group">
          <%= label_tag "Comment", nil, class: "h4" %><br>
          <%= text_field_tag "complaint_id_x_comment", nil, placeholder: "entry level comment", class: "form-control" %>
          <br>
        </div>
      </div>
    </div>
  </div>
</div>

