.content-wrapper
  .row
    .col-xs-12
      %h1 CSAM Reports

      .toolbar.csam-reports-toolbar
        .toolbar-container
          %label.toolbar-section-label
            Send Report
          %button.toolbar-button.toolbar-button-spacer.icon-reports.esc-tooltipped#resend-csam-reports-button{title: 'Resend reports to IWF or NCMEC', disabled: 'disabled'}
            %span Resend Reports
          %button.toolbar-button.icon-email.esc-tooltipped#email-csam-reports-button{title: 'Forward reports to external email address', disabled: 'disabled'}
            %span
              Forward Reports

      %table.table.responsive.dataTable.no-footer.webcat-list-view#webcat-csam-reports-index{role:'datatable'}
        %thead
          %tr
            %th.attention-flag-col
              -# attention flag
            %th Entry ID
            %th Date Entry was Resolved
            %th URL
            %th Analyst
            %th Source
            %th Report ID
            %th Date Sent
            %th
              -# actions column


- @reports.each do |report|
  .csam-report-dialog{id: "#{report.source}_report_dialog_#{report.id}", title: "#{report.source} Report ##{report.report_ident}"}
    .dialog-content-wrapper
      .row
        .col-xs-12
          %h4 Report Response
          = report.result

          %hr
          %h4 Report Content
          = report.report_submitted
