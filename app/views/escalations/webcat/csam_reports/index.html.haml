- @reports.each do |report|
  .csam-report-dialog{id: "#{report.source}_report_dialog_#{report.report_ident}", title: "#{report.source} Report ##{report.report_ident}"}
    .dialog-content-wrapper
      .row
        .col-xs-12
          %h4 Report Response
          = report.result

          %hr
          %h4 Report Content
          = report.report_submitted
