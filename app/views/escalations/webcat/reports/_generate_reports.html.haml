%h1 Generate Reports
.row
  .col-xs-12
    - if current_user.has_role?('admin')
      .report-listing-div
        %h2 OLD Engineer Report (admins only)

        = simple_form_for :report, url: old_resolution_escalations_webcat_reports_path, method: :get,
                            html: { target: :_blank } do |rpt_form|
          = rpt_form.input :date_from, as: :string, input_html: {type: :date}
          = rpt_form.input :date_to, as: :string, input_html: {type: :date}
          = rpt_form.submit 'Report', data: { disable_with: false }


    .report-listing-div
      %h2 Engineer Report

      = simple_form_for :report, url: resolution_escalations_webcat_reports_path, method: :get,
                          html: { target: :_blank } do |rpt_form|
        = rpt_form.input :date_from, as: :string, input_html: {type: :date}
        = rpt_form.input :date_to, as: :string, input_html: {type: :date}
        = rpt_form.submit 'Report', data: { disable_with: false }


    .report-listing-div
      %h2 Complaint Entry Report

      = simple_form_for :report, url: complaint_entry_escalations_webcat_reports_path, method: :get,
                          html: { target: :_blank } do |rpt_form|
        = rpt_form.input :date_from, as: :string, input_html: {type: :date, id: 'complaint_entry_report_from'}
        = rpt_form.input :date_to, as: :string, id: 'complaint_entry_report_to', input_html: {type: :date, id: 'complaint_entry_report_to'}
        = rpt_form.input :customer_name, required: false, input_html: { size: 60 }
        = rpt_form.submit 'Report', data: { disable_with: false }, id: 'complaint_entry_report'