      #categorize-same-form
        %form{method: 'get', 'accept-charset': 'UTF-8'}
          %h5 Categorize Multiple URLs With Same Categories
          .form-group
            %label.content-label-sm Categories
            %select.form-control#multi_cat_url_cats.cat_new_url.selectize{multiple: "multiple", placeholder: "Enter up to 5 categories", style: "display: none;"}
          .form-col-wrapper
            .form-group
              %label.content-label-sm Platform
              %select#multiurl_platform_select.form-control
            .form-group
              %label.content-label-sm Tags
              %select#multiurl_tag_select.form-control.selectize.tags-new-url{placeholder: "Select or create tags", multiple: "multiple"}
          .form-group
            %label.content-label-sm URLs/IP Addresses
            %textarea#categorize_urls{required: true}
          .form-group.text-center
            #bulk_cat_url_loader.webcat-loader.gear-loader-wrapper.hidden
              = inline_svg 'icon_gears_loader.svg', class: 'gears-loader'
              %span.loader-msg Loading data...
            %button.add-categories-button.primary#cat_multiple_urls{type: "button", onclick: "multiple_url_categorization()"} Categorize URLs
            %button.remove-categories.secondary{type: "button", onclick: "drop_multiple_url_categories()"} Drop All Categories
