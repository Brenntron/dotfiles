.nav-tool-blocks.col-xs-3.col-sm-3.col-md-2.col-lg-2.dropdown
  %a#categorize-urls.dropdown-toggle{href: '#', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
    %span{class: 'nav-toolbar-icon icon-categorize-white'}
    Categorize URLs
  .dropdown-menu.nav-tools-dropdown{'aria-labelledby': 'categorize-urls'}
    %h3.nav-tool-dropdown-header.inverse
      Categorize URLs
    .row.categorize-radio-wrapper
      .col-xs-6
        %input.cat-url-radio{type: 'radio', autocomplete: 'off', name: 'categorize-url-form-type', id: 'cat-urls-diff', value: 'cat-urls-diff', checked: true}
        %label.radio-label{for: 'cat-urls-diff'} Different categories for each url
      .col-xs-6
        %input.cat-url-radio{type: 'radio', autocomplete: 'off', name: 'categorize-url-form-type', id: 'cat-urls-same', value: 'cat-urls-same', checked: false}
        %label.radio-label{for: 'cat-urls-same'} Same categories for all urls

    .nav-tool-content-wrapper#categorize-urls-form-wrapper
      #categorize-diff-form
        %form{method: 'get', 'accept-charset': 'UTF-8'}
          %h5 Categorize URLs with Different Categories
          .webcat-loader.gear-loader-wrapper.hidden
            = inline_svg 'icon_gears_loader.svg', class: 'gears-loader'
            %span.loader-msg Loading...
          .toolbar
            %div
              %button.toolbar-button.current-categories-button.esc-tooltipped{type: 'button', title: 'Lookup Current Categories', onclick: 'lookup_prefix()'}
                %span Lookup Current Categories
              %button.toolbar-button.delete-categories-button.esc-tooltipped{type: 'button', title: 'Drop All Current Categories', onclick: 'drop_current_categories()' }
                %span Drop All Current Categories

          - 5.times do |i|
            .form-group.individual-url
              %div.cat-url-msg{id: "cat-url-msg-#{i}"}
              %label.content-label-sm URL
              %input.url-input.inline-input.form-control{id: "url_#{i}", type: "text", :value => "", placeholder: "URL", autofocus: 'true', tabindex: '1' }
              %button.inline-button.history-button.esc-tooltipped#history-1{type: 'button', onclick: "retrieve_history(#{i})", title: 'Entry Category History'}
              %label.content-label-sm Categories
              %select.form-control.cat_new_url.selectize{id: "cat_new_url_#{i}", multiple: "multiple", placeholder: "Enter up to 5 categories", style: "display: none;", tabindex: "2" }
              .form-col-wrapper
                %label.content-label-sm Platform
                %select.form-control.platform-new-url{id: "platform_new_url_#{i}"}
                %label.content-label-sm.tags-label Tags
                %select.form-control.tags-new-url.selectize{id: "tags_new_url_#{i}", placeholder: "Select or create tags", multiple: "multiple"}


