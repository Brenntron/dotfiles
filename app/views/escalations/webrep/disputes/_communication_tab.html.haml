.row
  .col-sm-3
    %h1 Case History
    .row.table-toolbar
      .col-xs-6
        Sort by:
        %select#history-sort-dropdown
          %option#date="Date (default)"
          %option#author="Author"
          %option#kind="Kind"
      .col-xs-6
        History to Show:
        %select#history-display-dropdown
          %option#all="Everything (default)"
          %option#email="Email"
          %option#note-history="Note"
          %option#version="Status"
    .row
      .col-xs-12
        %table#case-history
          -@dispute.dispute_emails.each do |email|
            %tr.email-row{class: "email-#{email.status}", email_id: "#{email.id}"}
              %td.alt-col.icon-col
                %span.case-history-icon.email-icon{:data => {:history_kind => "email"}}
              %td
                %span.case-history-author
                  =email.from
                %span.case-history-preview
                  =email.subject
              %td.alt-col.case-history-datetime{:data => {:db_date => email.created_at}}
                =email.created_at.strftime("%Y-%d-%m")
                %br
                =email.created_at.strftime("%H:%M:%S")
          -@dispute.dispute_comments.recent_first.each do |comment|
            %tr.note-history-row
              %td.alt-col.icon-col
                %span.case-history-icon.note-icon{:data => {:history_kind => "note"}}
              %td
                %span.case-history-author
                  =comment.user.cec_username
                %span.case-history-preview
                  =comment.comment.truncate(75, omission: '...')
              %td.alt-col.case-history-datetime{:data => {:db_date => comment.created_at}}
                =comment.created_at.strftime("%Y-%d-%m")
                %br
                =comment.created_at.strftime("%H:%M:%S")
          -@versioned_items.each do |item|
            -item.versions.each do |version|
              %tr.version-row
                %td.alt-col.icon-col
                  %span.case-history-icon.disp-status-icon{:data => {:history_kind => "version"}}
                %td
                  %span.case-history-author
                    =whodunnit_helper(version)
                  -version.changeset.each do |field, (changed_from, changed_to) |
                    %span.case-history-preview
                      =field_changeset_handler(field, changed_from)
                      %span.emphasize #{changed_from}
                      to
                      %span.emphasize #{changed_to}.
                %td.alt-col.case-history-datetime{:data => {:db_date => version.created_at}}
                  =version.created_at.strftime("%Y-%d-%m")
                  %br
                  =version.created_at.strftime("%H:%M:%S")

  .col-sm-6.border-section
    .row
      .col-xs-12.highlighted-section-header
        %h1 Communication
        .email-notice-block.customer-facing-notice
          Customer Facing Message
        .communication-toolbar
          %button.new-email-button
            Compose New Email
          %button.mng-templates-button
            Manage Email Templates


    .row
      .col-xs-12.email-header-information.hidden
        .email-header-data
          .communication-subject
          .sender-receiver-info
            %span.content-label-sm From
            %span.author-username
            %br
            %span.content-label-sm To
            %span.receiver-email
            %br
            %span.attachment-label#incoming-attachment.hidden
            %span.email-attachments

        .email-response-button-wrapper
          .email-response-buttons
            %button.reply-button
            %button.forward-button
          %span.email-datetime
    .row
      .col-xs-12.email-msg-body
        %pre.email-msg-content

    = render 'escalations/webrep/disputes/new_email_dialog'

    #manageTemplatesDialog{title: 'Manage Email Templates'}
      %table.table
        %thead
          %tr.table-header-highlight
            %th Template Name
            %th Description
            %th.min70
          -EmailTemplate.all.each do |template|
            %tr
              %td=template.template_name
              %td=template.description
              %td
                %button.table-button.edit-button.edit-template{template_id: template.id, name: 'edit-template'}
                %button.table-button.delete-button.delete-template{template_id: template.id, name: 'delete-template'}

      #new-template-form-wrapper
        %h4.dialog-inset-header New Email Template
        %form
          .dialog-form-information
            %span.content-label-sm Name
            %input#new-template-name{autofocus: true, required: true, type: 'text', name: 'template-name'}
            %span.content-label-sm Description
            %input#new-template-desc{required: true, type: 'text', name: 'template-description'}
          .template-content-wrapper
            %textarea.template-content#new-template-body

      #edit-template-form-wrapper
        %h4.dialog-inset-header Edit Email Template
        %form
          .dialog-form-information
            %span.content-label-sm Name
            %input#edit-template-name{autofocus: true, required: true, type: 'text', name: 'template-name'}
            %span.content-label-sm Description
            %input#edit-template-desc{required: true, type: 'text', name: 'template-description'}
            %input.hidden#template-id
          .template-content-wrapper
            %textarea.template-content#edit-template-body

      .dialog-section-divider
        %button.primary#save-email-template.hidden
          Save Template
        %button.secondary#create-email-template
          Create New Template
        %button.primary#edit-email-template.hidden
          Update Template
        %button.secondary.hidden#cancel-edit-email-template
          Cancel


    .row
      .col-xs-12#email-reply.hidden
        .row
          .col-xs-12.email-reply-content-wrapper
            .row
              .col-xs-12.email-reply-header-information
                .row
                  .col-xs-4
                    .sender-receiver-info
                      %span.reply-symbol
                      %span.receiver-email
                  .col-xs-8
                    .template-select-wrapper
                      .template-label
                        Select a Template

                    %select.dropdown.email-template-select#select-reply-template
                      -if EmailTemplate.all.empty?
                        %option.hidden{value:'', disabled: true, selected: true} No Templates Created
                      -else
                        %option.hidden{value:'', disabled: true, selected: true} No Template Selected
                        =options_for_select(EmailTemplate.all.pluck(:template_name, :id))

                    .email-reply-button-wrapper
                      .email-reply-buttons
                        %button.attachment-button.attachment-label.attachment-reply
                        %button.delete-email
                .row
                  .col-xs-12
                    %input.communication-subject.reply-subject{type: 'text'}

                .row
                  .col-xs-12.file-wrapper-reply
                    #file-fields
            .row
              .col-xs-12.email-reply-body-wrapper
                %textarea.email-reply-body.reply-body{autofocus: true}

        .row
          .col-xs-12.text-center
            %button.primary#send-reply
              Send



  .col-sm-3
    - if (@dispute.resolution != Dispute::DUPLICATE) && (@dispute.status != Dispute::RESOLVED)
      %h1.notes-header Notes
      %button.add-case-note-button#new-case-note-button
        Add Note


      .note-wrapper.new-case-note-row
        .row
          .col-xs-12
            .note-info-item.author-notation
              Creating new note
            .note-info-item.note-tool-buttons
              %button.note-save-button.new-case-note-save-button
              %button.note-cancel-button.new-case-note-cancel-button
              %button.note-copy-button
        .row
          .col-xs-12
            .note-block.content-editable.new-case-note-textarea{contenteditable: true}
              %pre

    -@dispute.dispute_comments.recent_first.each do |comment|
      .note-wrapper
        .row
          .col-xs-12
            .note-info-item.author-notation
              Written by
              %span.author-username
                =comment.user.cec_username
              = distance_of_time_in_words(Time.now, comment.created_at) + " ago."
            %br.hidden-break
            .note-info-item.time-stamp
              =comment.created_at.strftime("%Y-%d-%m %H:%M:%S")
            .note-info-item.note-tool-buttons
              %button.hidden.note-save-button.update-note{class: "note-save-button#{comment.id}", comment_id: "#{comment.id}"}
              %button.hidden.note-cancel-button{class: "note-cancel-button#{comment.id}", comment_id: "#{comment.id}"}
              %button.note-copy-button.clipboard.clipboard-btn{comment_id: "#{comment.id}", "data-clipboard-action"=> "copy", "data-clipboard-text"=> "#{comment.comment}"}
              %button.note-delete-button{comment_id: "#{comment.id}"}

        .row
          .col-xs-12
            - if comment.user.cec_username == current_user.cec_username
              .note-block.content-editable{class: "note-block#{comment.id}", comment_id: "#{comment.id}", contenteditable: true}
                %pre=comment.comment
            - else
              .note-block{comment_id: "#{comment.id}"}
                %pre=comment.comment



    %input{:name => "token", :type => "hidden", :value => "#{current_user.authentication_token}"}
    %input{:type => "hidden", :name => "xml_token", :value => "#{xml_token}"}
    %input{:name => "dispute_id", :type => "hidden", :value => "#{@dispute.id}"}
    %input{:name => "current_user_id", :type => "hidden", :value => "#{current_user.id}"}

  :javascript
    AC.Helpers.clipboard()
    // Default sort of case history
    $(document).ready(function(){
      list = $("#case-history tr").get();
      sort_function = function(a, b) {
        return $(".case-history-datetime", b).data().dbDate.localeCompare($(".case-history-datetime", a).data().dbDate);
      };
      list.sort(sort_function);
      for (var i = 0; i < list.length; i++) {
          list[i].parentNode.appendChild(list[i]);
      }
    })

