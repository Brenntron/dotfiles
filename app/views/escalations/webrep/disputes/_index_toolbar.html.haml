.toolbar
  %div
    %label.toolbar-section-label
      Table View
    %span.dropdown
      %button#table-show-columns-button.toolbar-button.show-col-button.dropdown-toggle.esc-tooltipped{title: 'Show/Hide Columns', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
        %span.toolbar-button-text
          Show/Hide Columns
      .dropdown-menu.toolbar-dropdown#table-show-columns-dropdown{'aria-labelledby': 'table-show-columns-button'}
        .dropdown-menu-content-block
          .dropdown-menu-toolbar-header.ticket-showcol-header Ticket Entry Details
          %ul
            %li.toggle-vis{'data-column':'2'}
              %input{type: 'checkbox', checked: true} Priority
            %li.toggle-vis{'data-column':'3'}
              %input{type: 'checkbox', checked: true} Case ID
            %li.toggle-vis{'data-column':'4'}
              %input{type: 'checkbox', checked: true} Status
            %li.toggle-vis{'data-column':'5'}
              %input{type: 'checkbox'} Resolution
            %li.toggle-vis{'data-column':'6'}
              %input{type: 'checkbox', checked: true} Ticket Type
            %li.toggle-vis{'data-column':'7'}
              %input{type: 'checkbox', checked: true} Dispute
            %li.toggle-vis{'data-column':'8'}
              %input{type: 'checkbox', checked: true} Owner
            %li.toggle-vis{'data-column':'9'}
              %input{type: 'checkbox', checked: true} Time Submitted

          %ul
            %li.toggle-vis{'data-column':'10'}
              %input{type: 'checkbox', checked: true} Age
            %li.toggle-vis{'data-column':'11'}
              %input{type: 'checkbox'} Case Origin
            %li.toggle-vis{'data-column':'12'}
              %input{type: 'checkbox'} Submitter Type
            %li.toggle-vis{'data-column':'13'}
              %input{type: 'checkbox'} Submitter Org
            %li.toggle-vis{'data-column':'14'}
              %input{type: 'checkbox'} Submitter Domain
            %li.toggle-vis{'data-column':'15'}
              %input{type: 'checkbox'} Contact Name
            %li.toggle-vis{'data-column':'16'}
              %input{type: 'checkbox'} Contact Email

        .dropdown-menu-content-block
          .dropdown-menu-toolbar-header.entry-showcol-header Dispute Entry Details
          %ul
            %li.toggle-vis-nested{'data-column': 'entry-col-content'}
              %input{type: 'checkbox', checked: true} Dispute Entry
            %li.toggle-vis-nested{'data-column': 'entry-col-status'}
              %input{type: 'checkbox', checked: true} Entry Status
            %li.toggle-vis-nested{'data-column': 'entry-col-res'}
              %input{type: 'checkbox', checked: true} Entry Resolution
            %li.toggle-vis-nested{'data-column': 'entry-col-disp'}
              %input{type: 'checkbox', checked: true} Suggested Disposition
            %li.toggle-vis-nested{'data-column': 'entry-col-cat'}
              %input{type: 'checkbox', checked: true} Category
            %li.toggle-vis-nested{'data-column': 'entry-col-wbrs-score'}
              %input{type: 'checkbox', checked: true} WBRS Score
            %li.toggle-vis-nested{'data-column': 'entry-col-wbrs-hits'}
              %input{type: 'checkbox', checked: true} WBRS Total Rule Hits
            %li.toggle-vis-nested{'data-column': 'entry-col-wbrs-rules'}
              %input{type: 'checkbox'} WBRS Rules

          %ul
            %li.toggle-vis-nested{'data-column': 'entry-col-sbrs-score'}
              %input{type: 'checkbox', checked: true} SBRS Score
            %li.toggle-vis-nested{'data-column': 'entry-col-sbrs-hits'}
              %input{type: 'checkbox', checked: true} SBRS Total Rule Hits
            %li.toggle-vis-nested{'data-column': 'entry-col-sbrs-rules'}
              %input{type: 'checkbox'} SBRS Rules

    %button.toolbar-button.expand-row-button#expand-all-index-rows.esc-tooltipped{title: 'Expand All Rows'}
      %span.toolbar-button-text Expand All Rows
    %button.toolbar-button.collapse-button#collapse-all-index-rows.esc-tooltipped{title: 'Collapse All Rows'}
      %span.toolbar-button-text Collapse All Rows

  %div
    %button.take-ticket-button#index_ticket_assign.esc-tooltipped{title: 'Assign to me', onclick: 'take_disputes();'}
      %span.toolbar-button-text

  %div
    %label.toolbar-section-label
      Edit Ticket
    %span.dropdown
      %button#index_ticket_status.toolbar-button.ticket-status-button.dropdown-toggle.esc-tooltipped{title: 'Edit Ticket Status', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
        %span.toolbar-button-text
          Edit Ticket Status
      .dropdown-menu.toolbar-dropdown#index-edit-ticket-status-dropdown{'aria-labelledby': 'index_ticket_status'}
        %ul
          %li.status-radio-wrapper
            %input.ticket-status-radio{type: 'radio', name: 'ticket-status', id: 'RESEARCHING', value:'RESEARCHING' }
            %label.ticket-status-radio-label.radio-label{for: 'RESEARCHING'} Researching
          %li.status-radio-wrapper
            %input.ticket-status-radio{type: 'radio', name: 'ticket-status', id: 'ESCALATED', value: 'ESCALATED'}
            %label.ticket-status-radio-label.radio-label{for: 'ESCALATED'} Escalated
          %li.status-radio-wrapper
            %input.ticket-status-radio{type: 'radio', name: 'ticket-status', id: 'CUSTOMER_PENDING', value: 'CUSTOMER_PENDING'}
            %label.ticket-status-radio-label.radio-label{for: 'CUSTOMER_PENDING'} Customer Pending
          %li.status-radio-wrapper
            %input.ticket-status-radio{type: 'radio', name: 'ticket-status', id: 'ON_HOLD', value: 'ON_HOLD'}
            %label.ticket-status-radio-label.radio-label{for: 'ON_HOLD'} On Hold
          %li.status-radio-wrapper
            %input.ticket-status-radio.index-resolution-drodown-menu{type: 'radio', name: 'ticket-status', id: 'RESOLVED_CLOSED', value: 'RESOLVED_CLOSED'}
            %label.ticket-status-radio-label.radio-label{for: 'RESOLVED_CLOSED'} Resolved / Closed
            .dropdown-menu#index-ticket-resolution-submenu
              .col-xs-6.submenu-left-wrapper
                .submenu-header
                  Ticket Resolution
                %ul
                  %li
                    %input.ticket-resolution-radio{type: 'radio', name: 'ticket-resolution', id: 'FIXED_FP', value: 'FIXED_FP'}
                    %label.ticket-res-radio-label.radio-label{for: 'FIXED_FP'} Fixed - FP
                  %li
                    %input.ticket-resolution-radio{type: 'radio', name: 'ticket-resolution', id: 'FIXED_FN', value: 'FIXED_FN'}
                    %label.ticket-res-radio-label.radio-label{for: 'FIXED_FN'} Fixed - FN
                  %li
                    %input.ticket-resolution-radio{type: 'radio', name: 'ticket-resolution', id: 'UNCHANGED', value: 'UNCHANGED'}
                    %label.ticket-res-radio-label.radio-label{for: 'UNCHANGED'} Unchanged
                  %li
                    %input.ticket-resolution-radio{type: 'radio', name: 'ticket-resolution', id: 'INVALID', value: 'INVALID'}
                    %label.ticket-res-radio-label.radio-label{for: 'INVALID'} Invalid / Junk Mail
                  %li
                    %input.ticket-resolution-radio{type: 'radio', name: 'ticket-resolution', id: 'TEST_TRAINING', value: 'TEST_TRAINING'}
                    %label.ticket-res-radio-label.radio-label{for: 'TEST_TRAINING'} Test / Training
                  %li
                    %input.ticket-resolution-radio{type: 'radio', name: 'ticket-resolution', id: 'OTHER', value: 'OTHER'}
                    %label.ticket-res-radio-label.radio-label{for: 'OTHER'} Other
              .col-xs-6.submenu-right-wrapper
                .resolution-comment-wrapper
                  %label.content-label-sm.customer-facing-comment
                    Customer Facing Comment
                  %textarea.ticket-status-comment
                  .button-row-center
                    %button.primary.change_ticket_status_button
                      Submit

          %li.status-radio-wrapper
            %input.ticket-status-radio{type: 'radio', name: 'ticket-status', id: 'RE-OPENED', value: 'RE-OPENED'}
            %label.ticket-status-radio-label.radio-label{for: 'RE-OPENED'} Re-Opened
          %li.non-resolution-submit-wrapper#ticket-non-res-submit
            %label.content-label-sm
              Comment
            %textarea.ticket-status-comment
            .button-row-center
              %button.primary.change_ticket_status_button
                Submit

    - if current_user.has_role?('manager')
      %span.dropdown
        %button#index_change_assign.toolbar-button.ticket-owner-button.show-col-button.dropdown-toggle.esc-tooltipped{title: 'Change Assignee', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
          %span.toolbar-button-text
            Change Assignee
        .dropdown-menu.toolbar-dropdown#index-change-assign-dropdown{'aria-labelledby': 'index_change_assign'}
          %select{name: 'index_target_assignee', id: 'index_target_assignee'}
            - User.all.order('cvs_username ASC').each do |u|
              %option{id: u.id, value: u.id, label: u.cvs_username}
          %button{class: 'btn btn-default nav-tool-button', type:'button', id: 'button_reassign', onclick:'toolbar_index_change_assignee();'}
            Assign

    %span.dropdown
      %button#index_mark_related.toolbar-button.mark-related-button.esc-tooltipped{title: 'Mark as Related', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
        %span.toolbar-button-text
          Mark as Related
      .dropdown-menu.toolbar-dropdown#set-related-dispute-div{'aria-labelledby': 'index_mark_related'}
        %form#set-related-dispute-form{onsubmit: 'set_relating_disputes(this);return false;'}
          %label.content-label-sm Original Ticket ID
          %br
          %input.dispute-id{type: 'text', name: 'dispute_id'}
          .button-row-center
            %button.primary#set-related-dispute-submit-button{type:'button', id: 'button_related_dispute', onclick:'related_disputes();'}
              Submit

  %div
    %label.toolbar-section-label
      Edit Dispute Entry
    %span.dropdown
      %button#index-entry-status-button.toolbar-button.ticket-status-button.esc-tooltipped{title: 'Edit Entry Status', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
        %span.toolbar-button-text
          Edit Entry Status
      .dropdown-menu.toolbar-dropdown#index-edit-entry-status-dropdown{'aria-labelledby': 'index_ticket_status'}
        %ul
          %li.status-radio-wrapper
            %input.entry-status-radio{type: 'radio', name: 'entry-status', id: "#{DisputeEntry::STATUS_RESEARCHING}"}
            %label.entry-status-radio-label.radio-label{for: "#{DisputeEntry::STATUS_RESEARCHING}"} Researching
          %li.status-radio-wrapper
            %input.entry-status-radio{type: 'radio', name: 'entry-status', id: "#{DisputeEntry::STATUS_ESCALATED}"}
            %label.entry-status-radio-label.radio-label{for: "#{DisputeEntry::STATUS_ESCALATED}"} Escalated
          %li.status-radio-wrapper
            %input.entry-status-radio{type: 'radio', name: 'entry-status', id: "#{DisputeEntry::STATUS_CUSTOMER_PENDING}"}
            %label.entry-status-radio-label.radio-label{for: "#{DisputeEntry::STATUS_CUSTOMER_PENDING}"} Customer Pending
          %li.status-radio-wrapper
            %input.entry-status-radio{type: 'radio', name: 'entry-status', id: "#{DisputeEntry::STATUS_ON_HOLD}"}
            %label.entry-status-radio-label.radio-label{for: "#{DisputeEntry::STATUS_ON_HOLD}"} On Hold
          %li.status-radio-wrapper
            %input.entry-status-radio.index-resolution-drodown-menu{type: 'radio', name: 'entry-status', id: 'RESOLVED_CLOSED'}
            %label.entry-status-radio-label.radio-label{for: 'RESOLVED_CLOSED'} Resolved / Closed
            .dropdown-menu#index-entry-resolution-submenu
              .col-xs-6.submenu-left-wrapper
                .submenu-header
                  Entry Resolution
                %ul
                  %li
                    %input.entry-resolution-radio{type: 'radio', name: 'entry-resolution', id: "#{DisputeEntry::STATUS_RESOLVED_FIXED_FP}"}
                    %label.entry-res-radio-label.radio-label{for: "#{DisputeEntry::STATUS_RESOLVED_FIXED_FP}"} Fixed - FP
                  %li
                    %input.entry-resolution-radio{type: 'radio', name: 'entry-resolution', id: "#{DisputeEntry::STATUS_RESOLVED_FIXED_FN}"}
                    %label.entry-res-radio-label.radio-label{for: "#{DisputeEntry::STATUS_RESOLVED_FIXED_FN}"} Fixed - FN
                  %li
                    %input.entry-resolution-radio{type: 'radio', name: 'entry-resolution', id: "#{DisputeEntry::STATUS_RESOLVED_UNCHANGED}"}
                    %label.entry-res-radio-label.radio-label{for: "#{DisputeEntry::STATUS_RESOLVED_UNCHANGED}"} Unchanged
                  %li
                    %input.entry-resolution-radio{type: 'radio', name: 'entry-resolution', id: "#{DisputeEntry::STATUS_RESOLVED_INVALID}"}
                    %label.entry-res-radio-label.radio-label{for: "#{DisputeEntry::STATUS_RESOLVED_INVALID}"} Invalid / Junk Mail
                  %li
                    %input.entry-resolution-radio{type: 'radio', name: 'entry-resolution', id: "#{DisputeEntry::STATUS_RESOLVED_TEST}"}
                    %label.entry-res-radio-label.radio-label{for: "#{DisputeEntry::STATUS_RESOLVED_TEST}"} Test / Training
                  %li
                    %input.entry-resolution-radio{type: 'radio', name: 'entry-resolution', id: "#{DisputeEntry::STATUS_RESOLVED_OTHER}"}
                    %label.entry-res-radio-label.radio-label{for: "#{DisputeEntry::STATUS_RESOLVED_OTHER}"} Other
              .col-xs-6.submenu-right-wrapper
                .resolution-comment-wrapper
                  %label.content-label-sm.customer-facing-comment
                    Customer Facing Comment
                  %textarea.entry-status-comment#entry-status-comment
                  .button-row-center
                    %button.primary{onclick: "toolbar_index_edit_status()"}
                      Submit

          %li.status-radio-wrapper
            %input.entry-status-radio{type: 'radio', name: 'entry-status', id: 'RE-OPENED'}
            %label.entry-res-radio-label.radio-label{for: 'RE-OPENED'} Re-Opened
          %li.non-resolution-submit-wrapper#entry-non-res-submit
            %label.content-label-sm
              Comment
            %textarea.entry-status-comment#entry-status-non-res-comment
            .button-row-center
              %button.primary{onclick: "toolbar_index_edit_status()"}
                Submit


    %span.dropdown
      %button#index-adjust-wlbl.toolbar-button.adjust-wlbl-button.dropdown-toggle.esc-tooltipped{title: 'Adjust WL/BL', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
        %span.toolbar-button-text Adjust WL/BL
      .dropdown-menu.toolbar-dropdown#wlbl_adjust_entries_index{'aria-labelledby': 'wlbl_entries_button'}
        -#For each checked checkbox populate this information
        = form_for :wlbl, html: {class: 'adjust-wlbl-form'} do |wlbl_form|
          .dispute-wlbl-adjust-wrapper
            .dispute-name-wrapper
              %label.content-label-sm Dispute
              %br
              %span.entry-dispute-name
            %table.dispute_tool_current
              %tr
                %td.text-center
                  %label.content-label-sm Current Score
                  %br
                  %span.current-wbrs-score
                %td.text-center
                  %label.content-label-sm New Score
                  %br
                  %span.new_wbrs_score
            .inline-tool-content-wrapper
              .row
                .col-xs-12
                  %label.content-label-sm{for: "wlbl-list-type-select"} Adjust WL/BL List
              .row
                .col-xs-6
                  %ul.wlbl-toggle-list
                    %li
                      %label.toggle-switch
                        %input.wl-weak-checkbox{type: 'checkbox', name: 'wl-bl-list-inline', class: 'wl-bl-list-inline', value: "WL-weak"}
                        %span.toggle-slider
                      WL - Weak
                    %li
                      %label.toggle-switch
                        %input.wl-med-checkbox{type: 'checkbox', name: 'wl-bl-list-inline', class: 'wl-bl-list-inline', value: "WL-med"}
                        %span.toggle-slider
                      WL - Medium
                    %li
                      %label.toggle-switch
                        %input.wl-heavy-checkbox{type: 'checkbox', name: 'wl-bl-list-inline', class: 'wl-bl-list-inline', value: "WL-heavy"}
                        %span.toggle-slider
                      WL - Heavy
                .col-xs-6
                  %ul.wlbl-toggle-list
                    %li
                      %label.toggle-switch
                        %input.bl-weak-checkbox{type: 'checkbox', name: 'wl-bl-list-inline', class: 'wl-bl-list-inline', value: "BL-weak"}
                        %span.toggle-slider
                      BL - Weak
                    %li
                      %label.toggle-switch
                        %input.bl-med-checkbox{type: 'checkbox', name: 'wl-bl-list-inline', class: 'wl-bl-list-inline', value: "BL-med"}
                        %span.toggle-slider
                      BL - Medium
                    %li
                      %label.toggle-switch
                        %input.bl-heavy-checkbox{type: 'checkbox', name: 'wl-bl-list-inline', class: 'wl-bl-list-inline', value: "BL-heavy"}
                        %span.toggle-slider
                      BL - Heavy

              .comment-wrapper
                %label.content-label-sm Comment
                %textarea.dropdown-comment.adjust-wlbl-input.note-input
              .button-row-center
                %button.primary.dropdown-submit-button{type: 'button', disabled: true, onclick:'index_adjust_wlbl_button(this);'}
                  Submit Changes


    %button.toolbar-button.adjust-reptool-button#reptool_entries_button.esc-tooltipped{title: 'Adjust RepTool BL'}
      %span.toolbar-button-text
        Adjust RepTool BL
  %div
    %label.toolbar-section-label
      File
    %form#disputes-index-export-form{action: escalations_webrep_disputes_path(format: :xlsx), method: :get}
      = hidden_field_tag('data_json', '{}', id: 'disputes-index-export-data-input')
      %button.toolbar-button.export-button.esc-tooltipped{title: 'Export to CSV'}
        %span.toolbar-button-text
          Export to CSV

