%form#new-dispute-form{method: 'get', 'accept-charset': 'UTF-8'}

  .form-group
    %input{type:'hidden', name: 'token', value: "#{current_user.authentication_token}"}
    %input{type:'hidden', name: 'xml_token', value: "#{xml_token}"}
    %input{type:'hidden', name: 'current_user', value: "#{current_user.authentication_token}"}

  .form-group
    %label.content-label-sm URLs/IP Addresses
    %textarea#ips_urls{required: true, name:'ips_urls'}
  .form-group
    %label.content-label-sm.assignee-label Assignee
    %input.form-control#assignee{name: 'assignee', list: 'assignee-list', required: true, value: "#{current_user.cvs_username}"}
    %datalist#assignee-list
  .form-group
    %label.content-label-sm Priority
    %select.form-control#priority{name:'priority'}
      %option P1
      %option P2
      %option{:selected => 'selected'} P3
      %option P4
      %option P5
  .form-group
    %label.content-label-sm Ticket Type
    %select.form-control#ticket-type-dropdown{name:'ticket_type'}
      %option{:selected => 'selected'} Web
      %option Email
      %option Email & Web

  %hr.thin
  .form-group.text-center
    %button.primary{value: 'submit', type: 'button', onclick: 'submit_new_dispute(this)'}
      Create
    %button.secondary#cancel_dispute{type: 'button'}
      Cancel
