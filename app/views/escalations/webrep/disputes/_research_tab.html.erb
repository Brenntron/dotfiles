
    <h1>Research Data</h1>
    <div class="row">
      <div class="col-xs-12">
        <div class="toolbar">
          <div>
            <label class="toolbar-section-label">Table View</label>
            <button class="toolbar-button show-col-button">
              <span class="toolbar-button-text">
                Show / Hide Columns
              </span>
            </button>
            <button class="toolbar-button collapse-button">
              <span class="toolbar-button-text">
                Expand/Collapse Rows
              </span>
            </button>
          </div>
          <div>
            <label class="toolbar-section-label">Edit</label>
            <button class="toolbar-button edit-button">
                <span class="toolbar-button-text">
                  Edit Dispute Entry
                </span>
            </button>
            <button class="toolbar-button add-dispute-entry">
              <span class="toolbar-button-text">
                Add Dispute Entry
              </span>
            </button>
          </div>
          <div>
            <label class="toolbar-section-label">Reputation</label>
              <button id="wlbl_entries_button" class="toolbar-button adjust-wlbl-button dropdown-toggle" title="Adjust WL/BL" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <span class="toolbar-button-text">
                  Adjust WBRS WL/BL
                </span>
              </button>
              <button id="reptool_entries_button" class="toolbar-button adjust-reptool-button dropdown-toggle" title="Adjust RepTool BL" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <span class="toolbar-button-text">
                  Adjust RepTool BL
                </span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-xs-12">
        <table class="table table-sm">
          <thead>
            <tr>
              <th><input id="disputes_check_box" type="checkbox"/></th>
              <th><!-- tools --></th>
              <th>Dispute</th>
              <th>Category</th>
              <th class="text-center">Original WBRS Score</th>
              <th class="text-center wbrs-highlight">Current WBRS Score</th>
              <th class="text-center">WBRS Rule Hits Total</th>
              <th class="text-center sbrs-highlight">SBRS Score</th>
              <th class="text-center">SBRS Rule Hits Total</th>
              <th>WL/BL Entries</th>
            </tr>
          </thead>
          <tbody>
          <% @entries.each do |entry| %>
            <tr>
              <td><input class="dispute_check_box" type="checkbox"/></td>
              <td class="dispute_rep_tools"></td>
              <td>paragon-downloads.com</td>
              <td>Computer and Internet</td>
              <td class="text-center">5.6</td>
              <td class="text-center wbrs-highlight">8.7</td>
              <td class="text-center">6</td>
              <td class="text-center sbrs-highlight"><%= entry.score unless entry.score_type != "SBRS" %></td>
              <td class="text-center">0</td>
              <td>WL - Medium</td>
            </tr>
            <tr class="nested-data-row">
              <td colspan="2"><!-- Spacer for checkbox and tools --></td>
              <td colspan="3">
                <table class="table-nested-reputation">
                  <tr>
                    <th>Category</th>
                    <td>Computers & Technology</td>
                  </tr>
                  <tr>
                    <th>Hostname</th>
                    <td><%= entry.hostname %></td>
                  </tr>
                  <tr>
                    <th>WBRS Rules</th>
                    <td>
                      <table class="table-nested-rep-rules">
                        <tr>
                          <th>Rule</th>
                          <th>Rule Description</th>
                          <th class="text-center">Malware Probability</th>
                        </tr>
                        <tr>
                          <td class="emphasis">vsvd</td>
                          <td>Verisign Verified Domains</td>
                          <td class="text-center data-small-emphasis">24.86%</td>
                        </tr>
                        <tr>
                          <td class="emphasis">wlh</td>
                          <td>Heavy-weight manual whitelist</td>
                          <td class="text-center data-small-emphasis">2.5%</td>
                        </tr>
                        <tr>
                          <td class="emphasis">wlm</td>
                          <td>Medium-weight manual whitelist</td>
                          <td class="text-center data-small-emphasis">22.50%</td>
                        </tr>
                        <tr>
                          <td class="emphasis">wuwl</td>
                          <td>SURBL Whitelist</td>
                          <td class="text-center data-small-emphasis">23.13%</td>
                        </tr>
                        <tr>
                          <td class="emphasis">tuse</td>
                          <td>TRUSTe Site Seal</td>
                          <td class="text-center data-small-emphasis">34.78%</td>
                        </tr>
                        <tr>
