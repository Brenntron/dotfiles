                                    %tr.plus-ip-rule-row
                                      %td.uri-plus-ip-rule-indicator
                                      %td= wbrs_hit.name
                                      %td
                                        - if rulehit.length > 0
                                          = rulehit.first.description
                                      %td.text-center
                                        - if rulehit.length > 0
                                          - malware_prob = rulehit.first.probability / 100.0
                                          - if malware_prob > 50
                                            %span.mal-highlight
                                              = rulehit.first.probability / 100.0
                                              \%
                                          - else
                                            = rulehit.first.probability / 100.0
                                            \%


