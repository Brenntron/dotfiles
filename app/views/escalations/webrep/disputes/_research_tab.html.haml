%input{type:'hidden', name: 'token', value: "#{current_user.authentication_token}"}
%input{type:'hidden', name: 'xml_token', value: "#{xml_token}"}
%input{type:'hidden', name: 'current_user', value: "#{current_user.authentication_token}"}


%h1 Research Data
.row
  .col-xs-12

    #research-tab-toolbar.toolbar
      %div
        %label.toolbar-section-label Table View
        %button.toolbar-button.expand-row-button.toolbar-button-spacer#expand-all-rows
          %span.toolbar-button-text Expand All Rows
        %button.toolbar-button.collapse-button#collapse-all-rows
          %span.toolbar-button-text Collapse All Rows
      - if (@dispute.resolution != Dispute::DUPLICATE) && (@dispute.status != Dispute::RESOLVED)
        %div
          %label.toolbar-section-label Edit
          %button.toolbar-button.edit-button#edit-dispute-entry-button.esc-tooltipped{title: 'Edit Dispute Entry'}
            %span.toolbar-button-text Edit Dispute Entry
          %span.dropdown
            %button.toolbar-button.add-dispute-entry#add-entries-button.dropdown-toggle.esc-tooltipped.dropdown-button-margin-left{title: 'Add Dispute Entry', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
              %span.toolbar-button-text Add Dispute Entry
            .dropdown-menu.toolbar-dropdown#add_entries_dropdown{'aria-labelledby': 'add-entries-button'}
              .input-group.add-entry-group
                %input{id: 'add_dispute_entry', name: 'dispute_entry_content', class: 'form-control', placeholder: 'Entry Content'}
                  %button{class: 'btn btn-default nav-tool-button', type:'button', id: 'button_add_dispute_entry', onclick: 'add_dispute_entry();'}
                    Submit
              .loading-bar
                .load-bar-segment.hidden
                .load-bar-segment.hidden
                .load-bar-segment.hidden
          %span.dropdown
            %button#research-convert-to-webcat.convert-ticket-button.toolbar-button.dropdown-button-margin-left{onclick: 'prep_dispute_to_convert_from_research();', type: 'button', title: 'Convert ticket to web categorization ticket', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
              %span.toolbar-button-text Convert to Webcat
            .dropdown-menu.toolbar-dropdown#webrep-convert-ticket-dropdown{'aria-labelledby': 'move-to-webcat'}
              .dropdown-tool-text-divider.primary-text-divider Convert to Categorization Dispute
              .inline-tool-content-wrapper
                .dropdown-loader-wrapper.hidden
                  .gear-loader-wrapper
                    = inline_svg 'icon_gears_loader.svg', class: 'gears-loader'

                %label.content-label-sm
                  Ticket ID to Convert:
                %span.ticket-id-to-convert#dispute-id-to-convert

                %label.content-label-sm
                  Ticket Entries:
                  %span.convert-entry-count
                .convert-entry-table-wrapper
                  %table#entries-to-convert.complaint-entries-to-convert
                    %thead
                      %tr
                        %th Entry ID
                        %th Entry Content
                        %th Current Categories
                        %th.text-right Suggested Categories
                    %tbody

                %hr.thin
                .comment-wrapper
                  %label.content-label-sm{for: '#convert-ticket-summary'} Ticket Summary
                  %textarea#convert-ticket-summary.dropdown-comment.note-input
                .button-row-center
                  %button#convert-webrep-ticket-dropdown.primary.dropdown-submit-button{type: 'button', onclick:'convert_dispute_to_webcat();', disabled: 'disabled'}
                    Convert Ticket

      - if (@dispute.resolution != Dispute::DUPLICATE) && (@dispute.status != Dispute::RESOLVED)
        %div
          %label.toolbar-section-label Reputation
          %span.dropdown
            %button#wlbl_entries_button.toolbar-button.adjust-wlbl-button.dropdown-toggle.esc-tooltipped.toolbar-button-spacer{title: 'Adjust WL/BL', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false', onclick: 'bulk_get_current_wlbl("show")'}
              %span.toolbar-button-text Adjust WL/BL
            .dropdown-menu.toolbar-dropdown#wlbl_adjust_entries{'aria-labelledby': 'wlbl_entries_button'}
              = form_for :wlbl, html: {class: 'adjust-wlbl-form bulk-wlbl-form'} do |wlbl_form|
                .dispute-wlbl-adjust-wrapper
                  .dropdown-tool-text-divider.primary-text-divider
                    Current WBRS Reputation

                  %table.dispute_tool_current
                    %thead
                      %tr
                        %th.content-label-sm Dispute
                        %th.content-label-sm.no-word-break Current WL/BL List
                        %th.text-center.content-label-sm.no-word-break Current WBRS Score
                        %th.content-label-sm.no-word-break.th-threat-cat Threat Category
                    %tbody

                  .dropdown-tool-text-divider.secondary-text-divider
                    Adjust WBRS Reputation

                  .inline-tool-content-wrapper
                    .row
                      .col-xs-3
                        %input{type: 'radio', name: 'wlbl-action-radio', id: 'wlbl-add', value: 'wlbl-add', checked: true}
                        %label.radio-label{for: 'wlbl-add'} Add to list
                      .col-xs-4
                        %input{type: 'radio', name: 'wlbl-action-radio', id: 'wlbl-remove', value: 'wlbl-remove'}
                        %label.radio-label{for: 'wlbl-remove'} Remove from list
                      .col-xs-5.replace-tc-radio.hidden
                        %input{type: 'radio', name: 'wlbl-action-radio', id: 'wlbl-replace', value: 'wlbl-replace'}
                        %label.radio-label{for: 'wlbl-replace'} Replace threat categories

                    .row.tc-replace-note.hidden
                      .col-xs-12
                        %span NOTE: Submitting zero threat categories removes associated blacklists too.

                    .row.lists-row
                      .col-xs-12
                        %label.content-label-sm{for: "wlbl-list-type-select"} Lists
                        .row.dropdown-tool-grey-row
                          .col-xs-4
                            %ul
                              %li
                                %input.wl-weak-checkbox.wl-bl-list-inline{type: 'checkbox', name: 'wl-bl-list-inline', value: "WL-weak"} WL - Weak
                              %li
                                %input.bl-weak-checkbox.wl-bl-list-inline{type: 'checkbox', name: 'wl-bl-list-inline', value: "BL-weak"} BL - Weak
                          .col-xs-4
                            %ul
                              %li
                                %input.wl-med-checkbox.wl-bl-list-inline{type: 'checkbox', name: 'wl-bl-list-inline', value: "WL-med"} WL - Medium
                              %li
                                %input.bl-med-checkbox.wl-bl-list-inline{type: 'checkbox', name: 'wl-bl-list-inline', value: "BL-med"} BL - Medium
                          .col-xs-4
                            %ul
                              %li
                                %input.wl-heavy-checkbox.wl-bl-list-inline{type: 'checkbox', name: 'wl-bl-list-inline', value: "WL-heavy"} WL - Heavy
                              %li
                                %input.bl-heavy-checkbox.wl-bl-list-inline{type: 'checkbox', name: 'wl-bl-list-inline', value: "BL-heavy"} BL - Heavy

                    -# threat cats row (1 of 2 for this file)
                    .row.dropdown-tool-grey-row.threat-cat-row.hidden
                      .threat-cat-note
                        %label.content-label-sm
                          Threat Categories
                          %span.threat-cat-required
                            *Required for adding to any blacklist.
                            %span.five-note Up to 5 can be selected
                      .threat-cat-area
                        .row
                        - Wbrs::ThreatCategory.selections.each do |label, value|
                          .col-md-6.threat-cat-cell
                            = wlbl_form.check_box(:thrt_cat_id, {id: nil, class: "wlbl_thrt_cat_id wlbl_thrt_cat_id_#{value}"}, value)
                            = label

                    .comment-wrapper
                      %label.content-label-sm WL/BL Comment
                      %textarea.dropdown-comment.adjust-wlbl-input.note-input
                    .button-row-center
                      %button.primary.dropdown-submit-button{type: 'button', onclick:'submit_bulk_wlbl("show");', disabled: true}
                        Submit Reputation Changes

          %span.dropdown
            %button#reptool_entries_button.toolbar-button.adjust-reptool-button.dropdown-toggle.esc-tooltipped{title: 'Adjust RepTool BL', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false', onclick: 'bulk_get_current_reptool("show");'}
              %span.toolbar-button-text Adjust RepTool BL
            .dropdown-menu.toolbar-dropdown#reptool_adjust_entries{'aria-labelledby': 'reptool_entries_button'}
              =form_for :reptool, html: {class: 'adjust-reptool-form'} do |rep_form|
                .dispute-reptool-adjust-wrapper
                  .dropdown-tool-text-divider.primary-text-divider
                    Current Reptool Classification
                  %table.dispute_tool_current
                    %thead
                      %tr
                        %th.content-label-sm.th-reptool-dispute Dispute
                        %th.content-label-sm.th-reptool-active-classes Active Classes
                        %th.content-label-sm.th-reptool-expiration Expiration
                        %th.content-label-sm.th-reptool-comment Comment
                    %tbody
                      -# Each checked entry will populate information here

                  .dropdown-tool-text-divider.secondary-text-divider
                    .inline-text Adjust RepTool Classification
                    .inline-label-wrapper.float-right
                      %input#reptool-toolbar-force.reptool-toolbar-force{type: 'checkbox', name: 'force', value: true}
                      %label{for: "reptool-toolbar-force"} Force commit

                  .inline-tool-content-wrapper
                    .row
                      .col-xs-12
                        %input{type: 'radio', name: 'reptool-action-radio', id: 'reptool-maintain', value: 'reptool-maintain', checked: true, onclick: 'reptool_form_prep(this, "bulk")'}
                        %label.radio-label{for: 'reptool-maintain'} Maintain current classifications
                        %input{type: 'radio', name: 'reptool-action-radio', id: 'reptool-override', value: 'reptool-override', onclick: 'reptool_form_prep(this, "bulk")'}
                        %label.radio-label{for: 'reptool-override'} Replace current classifications
                        %input{type: 'radio', name: 'reptool-action-radio', id: 'reptool-drop', value: 'reptool-drop', onclick: 'reptool_form_prep(this, "bulk")'}
                        %label.radio-label{for: 'reptool-drop'} Drop all classifications (set entry to EXPIRED)
                    %hr.thin.form-divider
                    .row.reptool-classifications-row
                      .col-xs-12
                        %label.content-label-sm{for: 'reptool-class-type-select'} Classifications
                        .row.dropdown-tool-grey-row.nested-radio-row.reptool-class-radio-row
                          .col-xs-6
                            %input{type: 'radio', name: 'reptool-classes-radio', id: 'reptool-classes-add', value: 'add', checked: true}
                            %label.radio-label{for: 'reptool-classes-add'} Add selected classifications
                          .col-xs-6
                            %input{type: 'radio', name: 'reptool-classes-radio', id: 'reptool-classes-remove', value: 'remove'}
                            %label.radio-label{for: 'reptool-classes-remove'} Remove selected classifications
                        %hr.thin.form-divider
                        .row.dropdown-tool-grey-row.checkbox-wrapper-row
                          .col-xs-4
                            %ul
                              %li
                                %input.reptool-class-cb.reptool-cb-attackers{type: 'checkbox', name: 'classification', value: 'attackers', onclick: 'reptool_form_prep(this, "bulk")'}
                                  attackers
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'banking_fraud', onclick: 'reptool_form_prep(this, "bulk")'}
                                  banking_fraud
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'bogon', onclick: 'reptool_form_prep(this, "bulk")'}
                                  bogon
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'bots', onclick: 'reptool_form_prep(this, "bulk")'}
                                  bots
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'cnc', onclick: 'reptool_form_prep(this, "bulk")'}
                                  cnc
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'cryptomining', onclick: 'reptool_form_prep(this, "bulk")'}
                                  cryptomining
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'dga', onclick: 'reptool_form_prep(this, "bulk")'}
                                  dga
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'exploitkit', onclick: 'reptool_form_prep(this, "bulk")'}
                                  exploitkit
                          .col-xs-4
                            %ul
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'high_risk', onclick: 'reptool_form_prep(this, "bulk")'}
                                  high_risk
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'ioc', onclick: 'reptool_form_prep(this, "bulk")'}
                                  ioc
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'link_sharing', onclick: 'reptool_form_prep(this, "bulk")'}
                                  link_sharing
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'malicious', onclick: 'reptool_form_prep(this, "bulk")'}
                                  malicious
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'malware', onclick: 'reptool_form_prep(this, "bulk")'}
                                  malware
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'newly_seen', onclick: 'reptool_form_prep(this, "bulk")'}
                                  newly_seen
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'open_proxy', onclick: 'reptool_form_prep(this, "bulk")'}
                                  open_proxy
                          .col-xs-4
                            %ul
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'open_relay', onclick: 'reptool_form_prep(this, "bulk")'}
                                  open_relay
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'phishing', onclick: 'reptool_form_prep(this, "bulk")'}
                                  phishing
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'response', onclick: 'reptool_form_prep(this, "bulk")'}
                                  response
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'spam', onclick: 'reptool_form_prep(this, "bulk")'}
                                  spam
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'spyware', onclick: 'reptool_form_prep(this, "bulk")'}
                                  spyware
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'suspicious', onclick: 'reptool_form_prep(this, "bulk")'}
                                  suspicious
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'tor_exit_node', onclick: 'reptool_form_prep(this, "bulk")'}
                                  tor_exit_node

                    .comment-wrapper
                      %label.content-label-sm RepTool Comment
                      %textarea.dropdown-comment.adjust-reptool-bl-input.comment-input.typed-in-comment-bulk{placeholder: 'Reason behind this change...'}
                      .reptool-generated-comment
                    .button-row-center
                      %button.primary.dropdown-submit-button{type: 'button', onclick: 'submit_bulk_reptool();'}
                        Submit Changes

      %div
        %label.toolbar-section-label Data
        %button.toolbar-button.sync-button#sync-data-button.toolbar-button-spacer
          %span.toolbar-button-text Refresh Data
        %form#dispute_research_export_form{action: export_escalations_webrep_dispute_path(@dispute, format: :csv), method: 'get'}
          %button.toolbar-button.export-button
            %span.toolbar-button-text Export
        %button.toolbar-button.export-button.esc-tooltipped.toolbar-button-spacer{title: 'Export Selected to CSV', onclick: 'webrep_research_export_selected_rows();'}
          %span.toolbar-button-text Export Selected to CSV

        - if @entries.blank? && @dispute.bridge_packet.present?
          %button.toolbar-button.ping-button.esc-tooltipped{title: 'Entry Recovery - Ping bridge to grab missing Entry content', onclick: "dispute_entry_recovery(#{@dispute.id});"}
            %span.toolbar-button-text Dispute Entry Recovery

      .edit-button-wrapper.edit-entries-buttons.hidden
        %button.save-all-changes.panel-button.save-button.tooltipped{title: 'Save All Changes',
                                                                     onclick: 'save_dispute_entries();'}
        %button.cancel-changes.panel-button.cancel-button.tooltipped{title: 'Cancel'}

.row
  .col-xs-12
    %table#disputes-research-table.table.table-sm
      %tbody
        - @entries.each_with_index do |entry, index|
          %tr.research-table-row{'data-entry-id': "#{entry.id}", id: "entry-data-wrapper_#{entry.id}"}
            %td.research-table-row-wrapper
              %table
                %tr.research-first-row
                  %td.expandable-row-column.expandable-cell{rowspan: '2'}
                    %button.expand-row-button-inline{'data-entry-id': "#{entry.id}"}
                  %td.cb-cell{rowspan: '2'}
                    %input.dispute_check_box{type: 'checkbox', 'data-entry-id': "#{entry.id}", class: "dispute-entry-cb-#{entry.id}"}
                  -if entry[:is_important]
                    %td
                      %span.entry-important-flag
                  %td.dual-edit-field.url-cell{'data-id': entry.id, 'data-field': 'host'}
                    %span.entry-data.entry-data-content
                      = entry.hostlookup
                    %input.table-entry-input.wide{type:'text', value: "#{entry.hostlookup}"}

                  -# if entry = uri and there are no resolved ips
                  - if entry.uri? && entry[:web_ips].blank?
                    %td.single-button-col.no-padding{colspan: '2'}
                      %span.dropdown
                        %button.add-ip-button.inline-button.esc-tooltipped{id: "add_ip_button_#{entry.id}", title: 'Add host IP addresses', 'aria-expanded': 'false', 'aria-haspopup': 'true', 'data-toggle': 'dropdown'}
                        %div.dropdown-menu.toolbar-dropdown.add-ip-dropdown{id: "add_ip_dropdown_#{entry.id}", 'aria-labelledby': "add_ip_button_#{entry.id}"}
                          %form.add-host-ips
                            .inline-tool-content-wrapper
                              .row
                                .col-sm-12
                                  %label.content-label-sm IP Addresses
                                  %textarea.add-ip-input
                              .button-row-center
                                %button.primary.dropdown-submit-button{type: 'button', onclick: 'add_host_ips(this)', 'data-entry-id': "#{entry.id}"} Submit Query
                  - else
                    - if !entry[:is_important]
                      %td.no-padding
                    - if !entry[:hostname].nil?
                      %td.hostname-cell
                        %label Hostname
                        = entry[:hostname]

                  %td.platform-cell
                    %label Platform
                    - if @dispute.platform.present?
                      =(@dispute.platform.public_name rescue "No Data")
                    - else
                      - if entry.platform_id.present?
                        =(entry.product_platform.public_name rescue "No Data")
                      - elsif entry.platform.present?
                        =entry.platform
                      - else
                        %span.missing-data No platform

                  %td.dual-edit-field.status-cell{'data-id': entry.id, 'data-field': 'status', colspan: '2'}
                    %label Status
                    %span.entry-data.entry-data-status
                      - if entry[:status].nil?
                        NEW
                      - else
                        = entry[:status]
                    %span.dropdown
                      %button.inline-select-dropdown.dropdown-toggle.table-entry-input{id: "entry_status_button_#{entry.id}", title: 'Change Entry Status', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
                        - if entry[:status].nil?
                          NEW
                        - else
                          = entry[:status]
                      .dropdown-menu.inline-dropdown-menu{id: "entry_status_button_#{entry.id}", 'aria-labelledby':"entry_status_button_#{entry.id}"}
                        %ul
                          %li.status-radio-wrapper
                            %input.entry-status-radio{type: 'radio', name: 'entry-status', class: "RESEARCHING_#{entry.id}", id: "RESEARCHING", onclick: 'populate_status_selection();'}
                            %label.radio-label{for: "#{DisputeEntry::STATUS_RESEARCHING}"} Researching
                          %li.status-radio-wrapper
                            %input.entry-status-radio{type: 'radio', name: 'entry-status', class: "ESCALATED_#{entry.id}", id: "ESCALATED", onclick: 'populate_status_selection();'}
                            %label.radio-label{for: "#{DisputeEntry::STATUS_ESCALATED}"} Escalated
                          %li.status-radio-wrapper
                            %input.entry-status-radio{type: 'radio', name: 'entry-status', class: "CUSTOMER_PENDING_#{entry.id}", id: "CUSTOMER_PENDING", onclick: 'populate_status_selection();'}
                            %label.radio-label{for: "#{DisputeEntry::STATUS_CUSTOMER_PENDING}"} Customer Pending
                          %li.status-radio-wrapper
                            %input.entry-status-radio{type: 'radio', name: 'entry-status', class: "ON_HOLD_#{entry.id}", id: "ON_HOLD", onclick: 'populate_status_selection();'}
                            %label.radio-label{for: "#{DisputeEntry::STATUS_ESCALATED}"} On Hold
                          %li.status-radio-wrapper
                            %input.entry-status-radio.resolution-drodown-menu{type: 'radio', name: 'entry-status', class: "RESOLVED_CLOSED_#{entry.id}", id: "RESOLVED_CLOSED", onclick: 'populate_resolved_status_selection();'}
                            %label.radio-label{for: "#{DisputeEntry::STATUS_RESOLVED}"} Resolved / Closed
                            .dropdown-menu.ticket-resolution-submenu
                              .col-xs-6.submenu-left-wrapper#webrep-entry-resolution-selector
                                .submenu-header
                                  Ticket Resolution
                                = render 'escalations/shared/resolved_resolution_options', { dispute_resolution_name: 'entry-resolution' }
                              .col-xs-6.submenu-right-wrapper
                                .resolution-comment-wrapper
                                  %label.content-label-sm
                                    Comment
                                  %textarea#webrep-entry-resolution-comment{name: 'resolution-comment'}

                          %li.status-radio-wrapper
                            %input.entry-status-radio{type: 'radio', name: 'entry-status', class: "RE-OPENED_#{entry.id}", id: "RE-OPENED", onclick: 'populate_status_selection();'}
                            %label.radio-label{for: "#{DisputeEntry::STATUS_REOPENED}"} Re-Opened
                  %td.resolution-cell
                    - if entry.resolution.nil?
                      %label Resolution
                      %span.missing-data
                        Unresolved
                    - elsif entry.resolution_comment.nil? || entry.resolution_comment.empty?
                      %label Resolution
                      = entry.resolution
                    - else
                      %span.esc-tooltipped{title: "#{entry.resolution_comment}"}
                        %label Resolution
                        = entry.resolution

                  %td.date-time-cell
                    %label As of
                    = entry.dispute_entry_preload&.created_at&.strftime('%F %T')

                  %td.dispute_rep_tools.rep-tools-cell{rowpan: '2'}
                    - if (@dispute.resolution != Dispute::DUPLICATE) && (@dispute.status != Dispute::RESOLVED)
                      %button.dispute-inline-buttons.edit-button.inline-edit-entry-button.esc-tooltipped{'data-entry-id': "#{entry.id}", title: 'Edit this entry'}
                    %span.dropdown
                      - if (@dispute.resolution != Dispute::DUPLICATE) && (@dispute.status != Dispute::RESOLVED)
                        %button.dispute-inline-buttons.adjust-wlbl-button.bfrp-inline-wlbl-button.dropdown-toggle.esc-tooltipped{id: "wlbl_button_#{entry.id}", title: 'Adjust WL/BL', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false', onclick: 'get_current_wlbl(this);'}
                      .dropdown-menu{id: "wlbl_adjust_#{entry.id}", 'aria-labelledby': "wlbl_button_#{entry.id}"}
                        = form_for :wlbl, html: {class: 'adjust-wlbl-form inline-wlbl-form'} do |wlbl_form|
                          .dispute-wlbl-adjust-wrapper
                            %input.adjust-wlbl-input.dispute-entry-content{type: 'hidden', value: "#{entry.hostlookup}" }
                            %h3 Adjust WL/BL
                            %table.dispute_tool_current
                              %thead
                                %tr
                                  %th.content-label-sm.no-word-break Current WL/BL List
                                  %th.text-center.content-label-sm.no-word-break Current WBRS Score
                                  %th.text-center.content-label-sm.no-word-break Projected Score
                                  %th.content-label-sm.no-word-break.th-threat-cat Threat Category
                              %tbody
                                %tr
                                  %td.wlbl-entry-wlbl
                                  %td.wlbl-current-entry-wbrs
                                  %td.wlbl-projected-entry-wbrs.text-center
                                  %td.wlbl-threat-cat-inline

                            .inline-tool-content-wrapper
                              .row
                                .col-xs-12
                                  %label.content-label-sm{for: "wlbl-list-type-select"} Adjust WL/BL List
                              .row.lists-row
                                .col-xs-4
                                  %ul.wlbl-toggle-list
                                    %li
                                      %label.toggle-switch
                                        %input.wl-weak-checkbox{type: 'checkbox', name: 'wl-bl-list-inline', class: 'wl-bl-list-inline', value: 'WL-weak', onclick: 'prepare_for_wbrs_preview(this)'}
                                        %span.toggle-slider#wl-weak-slider
                                      WL - Weak
                                    %li
                                      %label.toggle-switch
