#resolution-message-template-form-wrapper
  %form.resolution-message-template-form{class: local_assigns[:action], 'data-ticket-type':'WebDispute'}
    #resolved-resolution-message-dialogue-form-information{class: local_assigns[:action]}

      - if local_assigns[:action] == :create
        %label.content-label-sm.resolution-modal-label Dispute Type
        - if current_user.has_role?('webrep manager') || current_user.has_role?('manager')
          %li.dispute-type-radio-wrapper#dispute-type-web-wrapper
            %input.ticket-status-radio.form-check-input.webrep-resolution-template-type{type: 'radio', name: 'dispute-type', id: 'dispute-type-web', value:'web', checked: 'checked' }
            %label.ticket-status-radio-label.radio-label.form-check-label{for: 'dispute-type-web'} Web
          %li.dispute-type-radio-wrapper
            %input.ticket-status-radio.webrep-resolution-template-type{type: 'radio', name: 'dispute-type', id: 'dispute-type-email', value: 'email'}
            %label.ticket-status-radio-label.radio-label{for: 'dispute-type-email'} Email
        -else
          %p.resolution-template-dispute-type.resolution-template-lesser-permission-text

        %label.content-label-sm.resolution-modal-label Resolution
        - if current_user.has_role?('webrep manager') || current_user.has_role?('manager')

          - if @check_for_footer_web == true
            = select "#{local_assigns[:action]}-form", 'resolution_type_web', options_for_select(['Fixed - FP', 'Fixed - FN', 'Unchanged', 'Invalid / Junk Mail', 'Test / Training', 'Other']),{}, {class: 'inline-select-dropdown resolved-resolution-message-template-input', name:'resolution_type_web'}
          -else
            = select "#{local_assigns[:action]}-form", 'resolution_type_web', options_for_select(['Fixed - FP', 'Fixed - FN', 'Unchanged', 'Invalid / Junk Mail', 'Test / Training', 'Other', 'Customer Footer']),{}, {class: 'inline-select-dropdown resolved-resolution-message-template-input', name:'resolution_type_web'}

          - if @check_for_footer_email == true
            = select "#{local_assigns[:action]}-form", 'resolution_type_email', options_for_select(['Fixed - FP', 'Fixed - FN', 'Unchanged', 'Invalid / Junk Mail', 'Test / Training', 'Other']),{}, {class: 'inline-select-dropdown resolved-resolution-message-template-input hide', name:'resolution_type_email'}
          -else
            = select "#{local_assigns[:action]}-form", 'resolution_type_email', options_for_select(['Fixed - FP', 'Fixed - FN', 'Unchanged', 'Invalid / Junk Mail', 'Test / Training', 'Other', 'Customer Footer']),{}, {class: 'inline-select-dropdown resolved-resolution-message-template-input hide', name:'resolution_type_email'}

        -else

      - if local_assigns[:action] == :update

        %label.content-label-sm.resolution-modal-label Dispute Type
        %p#resolution-template-dispute-type-text.resolution-template-lesser-permission-text

        %label.content-label-sm.resolution-modal-label Resolution
        - if current_user.has_role?('webrep manager') || current_user.has_role?('manager')
          = select "#{local_assigns[:action]}-form", 'resolution_type', options_for_select(['Fixed - FP', 'Fixed - FN', 'Unchanged', 'Invalid / Junk Mail', 'Test / Training', 'Other']),{}, {class: 'inline-select-dropdown resolved-resolution-message-template-input', name:'resolution_type'}
        -else
          %p.resolution-template-resolution-type.resolution-template-lesser-permission-text
        %p.resolution-template-footer-text.hide Customer Footer

      %label.content-label-sm.resolution-modal-label Template Name
      - if current_user.has_role?('webrep manager') || current_user.has_role?('manager')
        %input.resolved-resolution-message-template-input.form-control.white-bg{type: 'text', name: 'name', required: true}
      -else
        %p.resolution-template-name.resolution-template-lesser-permission-text

      %label.content-label-sm.resolution-modal-label Description (When should this be used?)
      - if current_user.has_role?('webrep manager') || current_user.has_role?('manager')
        %textarea.form-control.resolution-template-description.resolution-modal-textarea.white-bg{name: 'description', rows: 2}
      -else
        %p.resolution-template-description.resolution-template-lesser-permission-text

      %input.hidden{type: 'hidden', name: 'template-id'}
      %label.content-label-sm.resolution-modal-label Message to Customer
      - if current_user.has_role?('webrep manager') || current_user.has_role?('manager')
        %textarea.resolution-template-message.form-control.resolution-modal-textarea.white-bg{name: 'body', required: true, placeholder: 'Your Snort Rule Ticket...', rows: 9}
      - else
        %p.resolution-template-message.resolution-template-lesser-permission-text

  .col-xs-12.text-center.resolution-modal-button-wrapper
    - if current_user.has_role?('webrep manager') || current_user.has_role?('manager')
      - if local_assigns[:action] == :create
        %button#create-resolution-template-submit.primary{onclick: "create_webrep_resolution_message_template('webrep')", disabled: true}
          Create Template
      - else
        %button.primary{onclick: "update_webrep_resolved_resolution_message_template('webrep')"}
          Update Template

    - if current_user.has_role?('webrep manager') || current_user.has_role?('manager')
      %button.secondary{onclick: 'close_resolution_template_dialog()'}
        Cancel
    - else
      %button.secondary{onclick: "close_resolution_template_dialog()"}
        Close
