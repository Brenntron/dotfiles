.content-wrapper
  .row.top-margin
    #inline-webrep.webrep-loader-wrapper
      .gear-loader-wrapper
        = inline_svg 'icon_gears_loader.svg', class: 'gears-loader'
      %span.loader-msg Loading data...

  %h1#dispute-index-title All Tickets
  #dispute-advaced-search-selected-filters
  
  = render('index_toolbar')

  %input{type: 'hidden', name: 'token', value: "#{current_user.authentication_token}"}


  .row
    .col-xs-12
      %table.table.responsive#disputes-index{'data-bunhammer-host': Rails.configuration.bunhammer_host}
        %thead
          %tr
            %th
            -# Expand / Collapse Button
            %th
              %input#disputes_check_box{type: 'checkbox', onclick: 'disputes_select_all_check_box();'}
            %th.text-center#priority.esc-tooltipped{title: 'Priority'}
            -# Priority
            %th#case-id Case ID
            %th#status Status
            %th#resolution Resolution
            %th#submission-type.text-center.esc-tooltipped{title: 'Ticket Type'}
              -#Ticket Type
            %th#dispute Dispute
            %th#owner Assignee
            %th#time-submitted Time Submitted
            %th#age Age
            %th#case-origin Case Origin
            %th#platform Platform
            %th#submitter-type.esc-tooltipped{title: 'Submitter Type'} Submitter Type
            %th#submitter-org Submitter Org
            %th#submitter-domain Submitter Domain
            %th#contact-name Contact Name
            %th#contact-email Contact Email
            %th#status-comment Status Comment
            %th#updated-at Last Updated
            %th

