                                  %thead
                                    %tr
                                      %th Rule
                                      %th Rule Description
                                      %th Weight
                                  %tbody
                                    - entry.dispute_rule_hits.select{|rulehit| rulehit.rule_type == "SBRS"}.each do |sbrs_hit|
                                      %tr
                                        %td
                                          - unless RulehitResolutionMailerTemplate.select{|template| template.mnemonic == sbrs_hit.name}.count == 0
                                            %a.adhoc-email-trigger{href: '#', 'data-url': "#{entry.uri}", 'data-name': sbrs_hit.name}
                                              = sbrs_hit.name
                                          - else
                                            = sbrs_hit.name
                                        %td= sbrs_hit.mnemonic
                                        %td
                                          -#Put weight of rule here
                            .entry-details-table.virustotal-details-table{'data-entry-id': "#{entry.id}"}
                              %h5.entry-details-table-header
                                Virustotal Details
                                %span.nested-table-tally
                                  = entry.virustotals.count {|vt| vt[:result] != "clean site" && vt[:result] != "unrated site" }
                              - if entry.virustotals.empty?
                                %table
                                  %thead
                                    %tr
                                      %th
                                        %span.missing-data
                                          No Virustotal data available.
                              - else
                                %table.table-scrollable
                                  %thead
                                    %tr
                                      %th AV Vendor
                                      %th Results
                                  %tbody
                                    - entry.virustotals.each do |virustotal|
                                      %tr
                                        %td.data-table-emph= virustotal[:name]
                                        - if virustotal[:result] == 'clean site'
                                          %td.clean-site-result Clean
                                        - elsif virustotal[:result] == 'unrated site'
                                          %td.unrated-site-result Unrated
                                        - else
                                          %td.unclean-site-result= virustotal[:result]
                          .col-sm-9
                            .entry-details-table.xbrs-details-table{'data-entry-id': "#{entry.id}"}
                              %h5.entry-details-table-header
                                XBRS History
                                %span.nested-table-tally
                                  - unless entry.hostlookup.nil?
                                    = entry.find_xbrs[1]['data'].count
                              - if entry.find_xbrs[1]['data'].empty?
                                %table
                                  %thead
                                    %tr
                                      %th
                                        %span.missing-data
                                          No XBRS data available.
                              - else
                                %table


                            .entry-details-table.crosslisted-details-table{'data-entry-id': "#{entry.id}"}
                              %h5.entry-details-table-header
                                Cross-listed URLs
                                %span.nested-table-tally
                                  = entry.wbrs_xlist.count
                              - if entry.wbrs_xlist.empty?
                                %table
                                  %thead
                                    %tr
                                      %th
                                        %span.missing-data
                                          No cross-listed urls.
                              - elsif entry.wbrs_xlist.count < 8
                                %table
                                  %thead
                                    %tr
                                      %th ID
                                      %th URL
                                      %th List Type
                                      %th.text-center Current Score
                                      %th Username
                                      %th Last Update
                                      %th Created
                                  %tbody
                                    - entry.wbrs_xlist.each do |cross_listed|
                                      %tr
                                        %td= cross_listed.id
                                        %td.esc-tooltipped{:title => cross_listed.url}= truncate(cross_listed.url, :length=>20)
                                        %td= cross_listed.list_type
                                        %td -
                                        %td= cross_listed.username
                                        %td= cross_listed.mtime
                                        %td= cross_listed.ctime
                              - else
                                %table.table-scrollable
                                  %thead
                                    %tr
                                      %th ID
                                      %th URL
                                      %th List Type
                                      %th.text-center Current Score
                                      %th Username
                                      %th Last Update
                                      %th Created
                                  %tbody
                                    - entry.wbrs_xlist.each do |cross_listed|
                                      %tr
                                        %td= cross_listed.id
                                        %td.esc-tooltipped{:title => cross_listed.url}= truncate(cross_listed.url, :length=>20)
                                        %td= cross_listed.list_type
                                        %td -
                                        %td= cross_listed.username
                                        %td= cross_listed.mtime
                                        %td= cross_listed.ctime
                            .entry-details-table.reptool-details-table{'data-entry-id': "#{entry.id}"}
                              %h5.entry-details-table-header RepTool Details
                              - if entry.blacklist.nil?
                                %table
                                  %thead
                                    %tr
                                      %th
                                        %span.missing-data
                                          No blacklist data
                              - else
                                %table
                                  %thead
                                    %tr
                                      %th RepTool Class
                                      %th Status
                                      %th Expiration
                                      %th Comment
                                      %th Source
                                      %th First Seen
                                      %th Last Seen
                                  %tbody
                                    %tr
                                      %td= entry.classifications.first
                                      %td= entry.blacklist.status
                                      %td= entry.blacklist.expiration
                                      %td= entry.blacklist.metadata&.fetch('VRT', {})['comment']
                                      %td= entry.blacklist.primary_source
                                      %td= entry.blacklist.first_seen
                                      %td= entry.blacklist.last_seen

= render 'escalations/webrep/disputes/new_email_dialog'
%input{:name => "token", :type => "hidden", :value => "#{current_user.authentication_token}"}
%input{:name => "xml_token", :type => "hidden", :value => "#{xml_token}"}




