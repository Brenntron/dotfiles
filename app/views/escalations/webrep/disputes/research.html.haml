                                    %label.content-label-sm
                                      Comment
                                    %textarea
                                    %button.primary
                                      Submit

                            %li.status-radio-wrapper
                              %input.entry-status-radio{type: 'radio', name: 'entry-status', id: 'Re-Opened'}
                              %label.radio-label{for: 'Re-Opened'} Re-Opened


