.content-wrapper
  .reputation-research-search-wrapper
    .research-header-wrapper
      %span.icon-research.top-info-icon
      %h1 Reputation Research
      %ul#research-tabs{class:"nav nav-tabs", role:'tablist'}
        %li{role:"presentation", class: "active", data:"lookup-detail"}
          %a{href:'#lookup-detail','aria-controls':'lookup-detail', 'aria-label': 'Detail lookup tab','data-toggle':'tab', role:"tab"}
            %span.icon-lookup-detail.top-info-icon
            Detailed Lookup
        %li{role:'presentation'}
          %a{href:'#lookup-quick',class:'quick-lookup-tab', 'aria-controls':'lookup-quick','aria-label': 'Quick lookup tab','data-toggle':'tab', role:"tab"}
            %span.icon-lookup-quick.top-info-icon
            Quick Lookup
    .research-search-form.row.tab-content
      = form_for(:search, method: "get") do |search_form|
        .search-options-col.tab-pane.active#lookup-detail
          .col-xs-4.col-sm-3.col-md-2.col-lg-2.col-xl-1
            = search_form.radio_button(:scope, 'strict', id: 'research-search-strict', checked: params['search'] && params['search']['scope'].eql?("strict"))
            %label.esc-tooltipped{title: 'Strict Search returns the inputted URI/IP as an entry, in addition to all entries that match the URL pattern.', for: 'research-search-strict'} Strict Search
            = search_form.radio_button(:scope, 'broad', id: 'research-search-broad', checked: !params['search'] || params['search']['scope'].eql?("broad"))
            %label.esc-tooltipped{title: 'Broad Search returns all records matching the URL pattern.', for: 'research-search-broad'} Broad Search
            %hr.thin
            =search_form.submit(:Submit, id: 'submit-button rep-research', class: 'button_primary')
          .col-xs-8.col-sm-9.col-md-10.col-lg-10.col-xl-11
            = search_form.text_area(:uri, class: 'search-box', placeholder: 'URI or IP Address', autofocus: 'true')
        .search-options-col.tab-pane#lookup-quick{role:'tabpanel'}
          .ajax-message-div#lookup-quick-loader
            .loader-gears
              =inline_svg 'icon_gears_loader.svg'
            %span.loader-msg Loading data...
          .col-xs-12.toolbar-quicklookup
            %button.primary#get-rep-data{onclick: 'get_rep_data();return false;'} Get Reputation Data
            .toolbar.research-toolbar
              %div
                %label.toolbar-section-label Adjust Reputation
                %span.dropdown
                  %button#wlbl_entries_button.toolbar-button.toolbar-button-spacer.adjust-wlbl-button.dropdown-toggle.esc-tooltipped{title: 'Adjust WL/BL', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false', onclick:'open_wlbl();'}
                    %span.toolbar-button-text Adjust WL/BL
                  .dropdown-menu.toolbar-dropdown#wlbl_entries_dropdown{'aria-labelledby': 'wlbl_entries_button'}
                    .dropdown-tool-text-divider.secondary-text-divider
                      Adjust WL/BL
                    .col-xs-12
                      .inline-tool-content-wrapper
                        .row.nested-radio-row.reptool-class-radio-row
                          .col-xs-2
                            %label.content-label-sm.reptool-section-label{for: "reptool-class-type-select"} Action
                          .col-xs-5
                            %input{type: 'radio', class:'wlbl-radio-add', name: 'wlbl-radio', id: 'wlbl-add', value: 'add', checked: true}
                            %label.radio-label{for: 'wlbl-add'} Add to List
                          .col-xs-5
                            %input{type: 'radio', class:'wlbl-radio-add', name: 'wlbl-radio', id: 'wlbl-remove', value: 'remove'}
                            %label.radio-label{for: 'wlbl-remove'} Remove from List
                        .row.reptool-classifications-row
                          .col-xs-12
                            %label.content-label-sm.reptool-section-label{for: "reptool-class-type-select"} Lists
                            %ul.dropdown-wlbl-list
                            .row.dropdown-tool-grey-row.threat-cat-row.hidden
                              .threat-cat-note
                                %label.content-label-sm
                                  Threat Categories
                                  %span.threat-cat-required
                                    *Required for adding to any blacklist.
                                    %span.five-note Up to 5 can be selected
                              .threat-cat-area
                                - Wbrs::ThreatCategory.selections.each do |label, value|
                                  .threat-cat-cell
                                    %input{type: 'checkbox',id: "bulk-wlbl-thrtcat-#{value}", class: "wlbl_thrt_cat_id wlbl_thrt_cat_id_#{value}", value: value}
                                    %label{for: "bulk-wlbl-thrtcat-#{value}"} #{label}
                      .col-xs-12
                        .comment-wrapper
                          %label.col-x-3.reptool-section-label{required: true} WL/BL Comment
                          %textarea.dropdown-comment.adjust-reptool-bl-input.comment-input
                          .col-x-3
                          .col-x-6
                            %hr.thin
                          .button-row-center
                            %button.primary.dropdown-submit-button{type: 'button', onclick: '', disabled: true, onclick: 'set_action_wlbl_col();'}
                              Add Action to Entries


                %span.dropdown
                  %button#reptool_entries_button.toolbar-button.adjust-reptool-button.dropdown-toggle.esc-tooltipped{title: 'Adjust RepTool BL', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false', onclick: 'open_adjust_reptool();'}
                    %span.toolbar-button-text Adjust RepTool BL
                  .dropdown-menu.toolbar-dropdown#reptool_entries_bl_dropdown{'aria-labelledby': 'reptool_entries_button'}
                    .dropdown-tool-text-divider.secondary-text-divider
                      Adjust Reptool Classification
                    .inline-tool-content-wrapper
                      .row
                        .col-xs-12
                          .row
                            %input{type: 'radio', name: 'reptool-action-radio', class: 'status_bl', id: 'adjust-reptool-maintain', value: 'reptool-maintain', checked: true}
                            %label.radio-label{for: 'adjust-reptool-maintain'} Maintain current classifications
                          .row
                            %input{type: 'radio', name: 'reptool-action-radio', class: 'status_bl', id: 'adjust-reptool-override', value: 'reptool-override'}
                            %label.radio-label{for: 'adjust-reptool-override'} Replace current classifications
                          .row
                            %input{type: 'radio', name: 'reptool-action-radio', class: 'status_bl', id: 'adjust-reptool-drop', value: 'reptool-drop'}
                            %label.radio-label{for: 'adjust-reptool-drop'} Drop all classifications (set entry to EXPIRED)
                      %hr.thin.form-divider
                      .row.reptool-classifications-row
                        .col-xs-12
                          %label.content-label-sm.reptool-section-label{for: "reptool-class-type-select"} Classifications
                          .row.dropdown-tool-grey-row.nested-radio-row.reptool-class-radio-row
                            .col-xs-6
                              %input{type: 'radio', class:'reptool-add', name: 'reptool-classes-radio', id: 'reptool-classes-add', value: 'add', checked: true}
                              %label.radio-label{for: 'reptool-classes-add'} Add selected classifications
                            .col-xs-6
                              %input{type: 'radio', class:'reptool-add', name: 'reptool-classes-radio', id: 'reptool-classes-remove', value: 'remove'}
                              %label.radio-label{for: 'reptool-classes-remove'} Remove selected classifications
                          %ul.dropdown-reptool-list
                    .col-xs-12
                      .comment-wrapper
                        %label.col-x-3.reptool-section-label{required: true} RepTool Comment
                        %textarea.dropdown-comment.adjust-reptool-bl-input.comment-input
                        .col-x-3
                        .col-x-6
                          %hr.thin
                        .button-row-center
                          %button.primary.dropdown-submit-button#quick-lookup-reptool-submit{type: 'button', disabled: true, onclick: 'set_action_col();'}
                            Add Action to Entries
              %div
                %label.toolbar-section-label File
                %button.toolbar-button.export-button.esc-tooltipped{title: 'Export to CSV'}
                  %span.toolbar-button-text Export to CSV
              %div
                %label.toolbar-section-label Actions
                %button#clear-all-actions.toolbar-button.clear-button.esc-tooltipped{title: 'Clear all actions'}
                  %span.toolbar-button-text Clear All Actions

            %button.primary#submit-rep-changes{onclick:'submit_quick_lookup();return false;', disabled: true} Submit Reputation Changes
            %span.small.note-repsubmit
              * NOTE: Submitting reputation changes will automatically create a closed ticket


          #confirmation-modal.modal.fade{role:"dialog"}
            .modal-dialog
              .modal-content
                .modal-header
                  %h4.modal-title#commit-modal-title New Reputation Dispute Ticket
                .modal-body
                  %table
                    %thead
                      %tr
                        %td.bold Dispute
                        %td.bold Actions
                    %tbody
                  .comment-wrapper
                    %label.content-label-sm
                      Comment
                    %textarea#confirm-rep-input.dropdown-comment.confirm-rep-input.comment-input
                  .modal-footer
                    .button-group
                      %button.primary{id:'confirm-rep-changes', onclick: 'confirm_rep_changes(); return false;' } Confirm Reputation Changes
                      %button{title: "Cancel", class: "secondary", onclick: "close_modal(); return false;"} Cancel


          #error_modal.modal.error_modal{tabindex:"-1", role:"dialog"}
            .modal-header
              %h4.modal-title#commit-modal-title Duplicate Dispute Requests
            .modal-body


          %table#research-table.research-table
            %colgroup
              %col
              %col
              %col.alt-col{span:7}
              %col
              %col
            %thead
              %tr
                %th
                  %span.checkbox-wrapper
                    %input#select-all-bulk{ :type=>"checkbox", checked: "true" }
                %th Dispute
                %th WBRS
                %th WBRS Rule Hits
                %th WBRS Rules
                %th Category
                %th WL/BL
                %th Threat Categories
                %th Reptool Classification
                %th Actions
                %th
            %tbody
              %tr
                %td.col-select-all
                %td
                  %p.col-bulk-dispute{ contenteditable:"true", data:''}
                %td.col-wbrs
                %td.col-wbrs-rule-hits
                %td.col-wbrs-rules
                %td.col-category
                %td.col-wlbl
                %td.col-threat-cats
                %td.col-actions
                %td.col-clear-actions


  .row
    .col-xs-12.lookup-detail
      .ajax-message-div#lookup-detail-loader
        .loader-gears
          =inline_svg 'icon_gears_loader.svg'
        %span.loader-msg Loading data...
      - if params['search']
        %h4 Results for
        %span.searched-for-url #{params['search']['uri']}
        (#{@entries.count} found)
      #research-page-toolbar.toolbar
        %div
          %div.toolbar-select-wrapper
            %label.toolbar-section-label
            %input#select-all-entries.esc-tooltipped{type:'checkbox',title: 'Select All / Deselect All', 'onclick':'select_all_detailed(this)'}
              %span.toolbar-button-text.select-all-label Select All / Deselect All
        %div
          %label.toolbar-section-label Table View
          %button.toolbar-button.expand-row-button#expand-all-rows.esc-tooltipped{title: 'Expand All Rows'}
            %span.toolbar-button-text Expand All Rows
          %button.toolbar-button.collapse-button#collapse-all-rows.esc-tooltipped.hidden{title: 'Collapse All Rows'}
            %span.toolbar-button-text Collapse All Rows
        %div.adjust-container
          %label.toolbar-section-label Edit
          %span.dropdown
            %button.toolbar-button.add-to-ticket-button.toolbar-button-spacer#add-to-ticket-button.esc-tooltipped{title: 'Add to Ticket','data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false', 'disabled': 'disabled', onclick:'ips_textarea_toggle(this)'}
              %span.toolbar-button-text Add to Ticket
            .dropdown-menu.toolbar-dropdown#add_to_ticket_dropdown{'aria-labelledby': 'add-to-ticket-button'}
              .dispute-wlbl-adjust-wrapper
                .dropdown-tool-text-divider.primary-text-divider
                  New Dispute
                = render 'escalations/webrep/disputes/new'
          %span.dropdown
            %button#wlbl_entries_button.toolbar-button.adjust-wlbl-button.dropdown-toggle.esc-tooltipped.toolbar-button-spacer{title: 'Adjust WL/BL', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false', onclick: 'bulk_get_current_wlbl("research")'}
              %span.toolbar-button-text Adjust WBRS WL/BL
            .dropdown-menu.toolbar-dropdown#wlbl_adjust_entries{'aria-labelledby': 'wlbl_entries_button'}
              = form_for :wlbl, html: {class: 'adjust-wlbl-form bulk-wlbl-form'} do |wlbl_form|
                .dispute-wlbl-adjust-wrapper
                  .dropdown-tool-text-divider.primary-text-divider
                    Current WBRS Reputation
                  %table.dispute_tool_current
                    %thead
                      %tr
                        %th.content-label-sm Dispute
                        %th.content-label-sm.no-word-break Current WL/BL List
                        %th.text-center.content-label-sm.no-word-break Current WBRS Score
                        %th.content-label-sm.no-word-break.th-threat-cat Threat Category
                    %tbody
                  -# TODO Hook up ability to preview scores based on changes in WL/BL
                  .dropdown-tool-text-divider.secondary-text-divider
                    Adjust WBRS Reputation
                  .inline-tool-content-wrapper
                    .row
                      .col-xs-3
                        %input{type: 'radio', name: 'wlbl-action-radio', id: 'wlbl-add', value: 'wlbl-add', checked: true}
                        %label.radio-label{for: 'wlbl-add'} Add to list
                      .col-xs-4
                        %input{type: 'radio', name: 'wlbl-action-radio', id: 'wlbl-remove', value: 'wlbl-remove'}
                        %label.radio-label{for: 'wlbl-remove'} Remove from list
                    .row
                      .col-xs-5.replace-tc-radio.hidden
                        %input{type: 'radio', name: 'wlbl-action-radio', id: 'wlbl-replace', value: 'wlbl-replace'}
                        %label.radio-label{for: 'wlbl-replace'} Replace threat categories

                    .row.tc-replace-note.hidden
                      .col-xs-12
                        %span NOTE: Submitting zero threat categories removes associated blacklists too.

                    -# BEGIN: WL BL LISTS ROW + THREAT CATS ROW (place this 1 indent past 'inline-tool' above)
                    .row.lists-row
                      .col-xs-12
                        %label.content-label-sm{for: "wlbl-list-type-select"} Lists
                        .row.dropdown-tool-grey-row
                          .col-xs-4
                            %ul
                              %li
                                %input.wl-weak-checkbox.wl-bl-list-inline{type: 'checkbox', name: 'wl-bl-list-inline', value: "WL-weak"} WL - Weak
                              %li
                                %input.bl-weak-checkbox.wl-bl-list-inline{type: 'checkbox', name: 'wl-bl-list-inline', value: "BL-weak"} BL - Weak
                          .col-xs-4
                            %ul
                              %li
                                %input.wl-med-checkbox.wl-bl-list-inline{type: 'checkbox', name: 'wl-bl-list-inline', value: "WL-med"} WL - Medium
                              %li
                                %input.bl-med-checkbox.wl-bl-list-inline{type: 'checkbox', name: 'wl-bl-list-inline', value: "BL-med"} BL - Medium
                          .col-xs-4
                            %ul
                              %li
                                %input.wl-heavy-checkbox.wl-bl-list-inline{type: 'checkbox', name: 'wl-bl-list-inline', value: "WL-heavy"} WL - Heavy
                              %li
                                %input.bl-heavy-checkbox.wl-bl-list-inline{type: 'checkbox', name: 'wl-bl-list-inline', value: "BL-heavy"} BL - Heavy
                    .row.dropdown-tool-grey-row.threat-cat-row.hidden
                      .threat-cat-note
                        %label.content-label-sm
                          Threat Categories
                          %span.threat-cat-required
                            *Required for adding to any blacklist.
                            %span.five-note Up to 5 can be selected
                      .threat-cat-area
                        - Wbrs::ThreatCategory.selections.each do |label, value|
                          .threat-cat-cell
                            = wlbl_form.check_box(:thrt_cat_id, {id: nil, class: "wlbl_thrt_cat_id wlbl_thrt_cat_id_#{value}"}, value)
                            = label
                    -# END: WL BL LISTS ROW + THREAT CATS ROW


                    .comment-wrapper
                      %label.content-label-sm WL/BL Comment
                      %textarea.dropdown-comment.adjust-wlbl-input.note-input
                    .button-row-center
                      %button.primary.dropdown-submit-button{type: 'button', onclick:'submit_bulk_wlbl("research");', disabled: true}
                        Submit Reputation Changes
          %span.dropdown
            -##reptool_entries_button
            %button#reptool_entries_button_research.toolbar-button.adjust-reptool-button.dropdown-toggle.esc-tooltipped{title: 'Adjust RepTool BL', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false', onclick: 'bulk_get_current_reptool("research");'}
              %span.toolbar-button-text Adjust RepTool WL/BL
            .dropdown-menu.toolbar-dropdown#reptool_adjust_entries{'aria-labelledby': 'reptool_entries_button'}
              =form_for :reptool, html: {class: 'adjust-reptool-form'} do |rep_form|
                .dispute-reptool-adjust-wrapper
                  .dropdown-tool-text-divider.primary-text-divider
                    Current Reptool Classification
                  %table.dispute_tool_current
                    %thead
                      %tr
                        %th.content-label-sm.th-reptool-dispute Dispute
                        %th.content-label-sm.th-reptool-active-classes Active Classes
                        %th.content-label-sm.th-reptool-expiration Expiration
                        %th.content-label-sm.th-reptool-comment Comment
                    %tbody
                  -# Each checked entry will populate information here
                  .dropdown-tool-text-divider.secondary-text-divider
                    Adjust Reptool Classification
                  .inline-tool-content-wrapper
                    .row
                      .col-xs-12
                        %input{type: 'radio', name: 'reptool-action-radio', id: 'reptool-maintain', value: 'reptool-maintain', checked: true, onclick: 'reptool_form_prep(this, "bulk")'}
                        %label.radio-label{for: 'reptool-maintain'} Maintain current classifications
                        %input{type: 'radio', name: 'reptool-action-radio', id: 'reptool-override', value: 'reptool-override', onclick: 'reptool_form_prep(this, "bulk")'}
                        %label.radio-label{for: 'reptool-override'} Replace current classifications
                        %input{type: 'radio', name: 'reptool-action-radio', id: 'reptool-drop', value: 'reptool-drop', onclick: 'reptool_form_prep(this, "bulk")'}
                        %label.radio-label{for: 'reptool-drop'} Drop all classifications (set entry to EXPIRED)
                    %hr.thin.form-divider
                    .row.reptool-classifications-row
                      .col-xs-12
                        %label.content-label-sm{for: "reptool-class-type-select"} Classifications
                        .row.dropdown-tool-grey-row.nested-radio-row.reptool-class-radio-row
                          .col-xs-6
                            %input{type: 'radio', name: 'reptool-classes-radio', value: 'add', checked: true}
                            %label.radio-label{for: 'reptool-classes-add'} Add selected classifications
                          .col-xs-6
                            %input{type: 'radio', name: 'reptool-classes-radio', value: 'remove'}
                            %label.radio-label{for: 'reptool-classes-remove'} Remove selected classifications
                        %hr.thin.form-divider
                        .row.dropdown-tool-grey-row.checkbox-wrapper-row
                          .col-xs-4
                            %ul
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'attackers', onclick: 'reptool_form_prep(this, "bulk")'}
                                  attackers
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'banking_fraud', onclick: 'reptool_form_prep(this, "bulk")'}
                                  banking_fraud
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'bogon', onclick: 'reptool_form_prep(this, "bulk")'}
                                  bogon
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'bots', onclick: 'reptool_form_prep(this, "bulk")'}
                                  bots
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'cnc', onclick: 'reptool_form_prep(this, "bulk")'}
                                  cnc
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'cryptomining', onclick: 'reptool_form_prep(this, "bulk")'}
                                  cryptomining
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'dga', onclick: 'reptool_form_prep(this, "bulk")'}
                                  dga
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'exploitkit', onclick: 'reptool_form_prep(this, "bulk")'}
                                  exploitkit
                          .col-xs-4
                            %ul
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'high_risk', onclick: 'reptool_form_prep(this, "bulk")'}
                                  high_risk
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'ioc', onclick: 'reptool_form_prep(this, "bulk")'}
                                  ioc
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'link_sharing', onclick: 'reptool_form_prep(this, "bulk")'}
                                  link_sharing
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'malicious', onclick: 'reptool_form_prep(this, "bulk")'}
                                  malicious
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'malware', onclick: 'reptool_form_prep(this, "bulk")'}
                                  malware
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'newly_seen', onclick: 'reptool_form_prep(this, "bulk")'}
                                  newly_seen
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'open_proxy', onclick: 'reptool_form_prep(this, "bulk")'}
                                  open_proxy
                          .col-xs-4
                            %ul
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'open_relay', onclick: 'reptool_form_prep(this, "bulk")'}
                                  open_relay
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'phishing', onclick: 'reptool_form_prep(this, "bulk")'}
                                  phishing
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'response', onclick: 'reptool_form_prep(this, "bulk")'}
                                  response
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'spam', onclick: 'reptool_form_prep(this, "bulk")'}
                                  spam
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'spyware', onclick: 'reptool_form_prep(this, "bulk")'}
                                  spyware
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'suspicious', onclick: 'reptool_form_prep(this, "bulk")'}
                                  suspicious
                              %li
                                %input.reptool-class-cb{type: 'checkbox', name: 'classification', value: 'tor_exit_node', onclick: 'reptool_form_prep(this, "bulk")'}
                                  tor_exit_node
                    .comment-wrapper
                      %label.content-label-sm RepTool Comment
                      %textarea.dropdown-comment.adjust-reptool-bl-input.comment-input.typed-in-comment-bulk{placeholder: 'Reason behind this change...'}
                      .reptool-generated-comment
                    .button-row-center
                      %button.primary.dropdown-submit-button{type: 'button', onclick: 'submit_bulk_reptool();'}
                        Submit Changes
        %div
          %label.toolbar-section-label Type to filter results
          %input#research-page-filter{'type': "text", 'onKeyUp': "researchfilter(this)"}
        %button.primary#submit-strict-changes{onclick:'submit_quick_lookup();return false;', disabled: true} Submit Reputation Changes
        %span.small.note-repsubmit * NOTE: Submitting reputation changes will automatically create a closed ticket
  .row.research_results
    .col-xs-12

      %table#disputes-research-table.table.table-sm.bfrp-table
        %tbody
          - @entries.each_with_index do |entry, i|
            %tr.research-table-row{'data-entry-id': "#{entry.id}", class: "result-no-#{i}"}
              %td.research-table-row-wrapper
                %table
                  %tr.research-first-row
                    %td.expandable-row-column.expandable-cell
                      %button.expand-row-button-inline{'data-entry-id': "#{entry.id}"}
                    %td.cb-cell
                      %input.dispute_check_box{type: 'checkbox', class: "bfrp-checkbox-#{i}", 'data-entry-id': "#{entry.id}"}
                    %td.url-cell
                      - if entry[:is_important]
                        %span.entry-data.entry-data-content.entry-important-flag
                          = entry.hostlookup
                      - else
                        %span.entry-data.entry-data-content
                          = entry.hostlookup
                    %td.category-cell
                      %label Category
                      - if entry[:primary_category] != '{}' && !entry[:primary_category].nil?
                        = entry[:primary_category]
                      - else
                        %span.missing-data No assigned categories
                    %td.hostname-cell
                      %label Hostname
                      - unless entry[:hostname].nil?
                        = entry[:hostname]

                    %td.dispute_rep_tools.rep-tools-cell
