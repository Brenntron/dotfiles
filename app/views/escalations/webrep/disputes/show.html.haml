-#view single record
.content-wrapper.top-case-info

  .row
    .col-xs-4.col-with-divider
      .priority-col-wrapper
        %span.bug-state-info.bug-priority#dispute-priority-icon{class: "p-#{@dispute.priority}"}
        =select_tag(:'dispute-priority-select', options_for_select([["#{Dispute::PRIORITY_1}"], ["#{Dispute::PRIORITY_2}"], ["#{Dispute::PRIORITY_3}"], ["#{Dispute::PRIORITY_4}"], ["#{Dispute::PRIORITY_5}"]], @dispute.priority))
        %span.dispute-submission-type{class:"dispute-#{@dispute.submission_type}"}
      .case-id-wrapper
        %label.content-label-sm
          Case ID
        .bug-top-id
          %a.case-id-tag#dispute_id= @dispute.case_id_str


      .dispute-owner-wrapper
        %label.content-label-sm
          Owner
        %div
          - if @dispute.assignee == 'Unassigned'
            %span.missing-data#dispute-assignee= @dispute.assignee || "None"
          - else
            %span= @dispute.assignee || "None"
          .dispute-owner-buttons-wrapper
            - if @dispute.assignee == current_user.email
              %button.return-ticket-button{onclick: 'toolbar_unassign_dispute();'}
            - else
              %button.take-ticket-button#show_ticket_assign{title: "Assign to me", onclick: "take_single_dispute(#{@dispute.id});"}

            - if current_user.has_role?('manager')
              %span.dropdown
                %button#index_change_assign.dispute-inline-buttons.ticket-owner-button.dropdown-toggle{title: 'Change Assignee', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
                .dropdown-menu#show-change-assign-dropdown{'aria-labelledby': 'index_change_assign'}
                  .change-assignee-dropdown-wrapper
                    %h3 Change Assignee
                    .inline-tool-content-wrapper
                      .toolbar
                        %div
                          %label.toolbar-section-label Assignee
                          %select{name: 'index_target_assignee', id: 'index_target_assignee', class:'toolbar-select'}
                            - User.all.order('cvs_username ASC').each do |u|
                              %option{id: u.id, value: u.id, label: u.cvs_username}
                        %button{class: 'primary', type:'button', id: 'button_reassign', onclick:'toolbar_show_change_assignee();'}
                          Assign
                        %button{class: 'secondary', type: 'button', id: 'unassign-dispute-button', onclick: 'toolbar_unassign_dispute();'}
                          Unassign


    .col-xs-2.col-with-divider
      .dispute-status-col-wrapper
        -#%label.content-label-sm
        -#  Status
        -##bugzilla_popover_state
        -#  =select_tag(:status, options_for_select([["#{Dispute::NEW}"], ["#{Dispute::RESOLVED}"], ["#{Dispute::ASSIGNED}"], ["#{Dispute::DUPLICATE}"]], @dispute.status), class: 'inpage-select')
        %span.dropdown
      %button#show-edit-ticket-status-button.inpage-select.ticket-status-button.dropdown-toggle{title: 'Edit Ticket Status', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
        %span
          Status
      .dropdown-menu.toolbar-dropdown#edit-ticket-status-dropdown{'aria-labelledby': 'index_ticket_status'}
        %ul
          %li.status-radio-wrapper
            %input.entry-status-radio{type: 'radio', name: 'entry-status', id: 'Researching'}
            %label.radio-label{for: 'Researching'} Researching
          %li.status-radio-wrapper
            %input.entry-status-radio{type: 'radio', name: 'entry-status', id: 'Escalated'}
            %label.radio-label{for: 'Escalated'} Escalated
          %li.status-radio-wrapper
            %input.entry-status-radio{type: 'radio', name: 'entry-status', id: 'Customer-Pending'}
            %label.radio-label{for: 'Customer-Pending'} Customer Pending
          %li.status-radio-wrapper
            %input.entry-status-radio{type: 'radio', name: 'entry-status', id: 'On-Hold'}
            %label.radio-label{for: 'On-Hold'} On Hold
          %li.status-radio-wrapper
            %input.entry-status-radio.resolution-drodown-menu{type: 'radio', name: 'entry-status', id: 'Resolved-Closed'}
            %label.radio-label{for: 'Resolved-Closed'} Resolved / Closed
            .dropdown-menu.ticket-resolution-submenu
              .col-xs-6.submenu-left-wrapper
                .submenu-header
                  Ticket Resolution
                %ul
                  %li
                    %input.entry-resolution-radio{type: 'radio', name: 'entry-resolution', id: 'Fixed-FP'}
                    %label.radio-label{for: 'Fixed-FP'} Fixed - FP
                  %li
                    %input.entry-resolution-radio{type: 'radio', name: 'entry-resolution', id: 'Fixed-FN'}
                    %label.radio-label{for: 'Fixed-FN'} Fixed - FN
                  %li
                    %input.entry-resolution-radio{type: 'radio', name: 'entry-resolution', id: 'Unchanged'}
                    %label.radio-label{for: 'Unchanged'} Unchanged
                  %li
                    %input.entry-resolution-radio{type: 'radio', name: 'entry-resolution', id: 'Invalid'}
                    %label.radio-label{for: 'Invalid'} Invalid / Junk Mail
                  %li
                    %input.entry-resolution-radio{type: 'radio', name: 'entry-resolution', id: 'Test-Training'}
                    %label.radio-label{for: 'Test-Training'} Test / Training
                  %li
                    %input.entry-resolution-radio{type: 'radio', name: 'entry-resolution', id: 'Other'}
                    %label.radio-label{for: 'Other'} Other
              .col-xs-6.submenu-right-wrapper
                .resolution-comment-wrapper
                  %label.content-label-sm
                    Comment
                  %textarea
                  %button.primary
                    Submit

          %li.status-radio-wrapper
            %input.entry-status-radio{type: 'radio', name: 'entry-status', id: 'Re-Opened'}
            %label.radio-label{for: 'Re-Opened'} Re-Opened


      .disposition-wrapper
        %label.content-label-sm
          Suggested Disposition
        .disposition.disp-negative
          = @dispute.suggested_d
    .col-xs-3.col-with-divider
      %label.content-label-sm
        Dispute Entries
      %div
        = @entries.first.hostlookup
        -#- @entries.each do |entry|
        -#  = entry.hostlookup
      %span.dispute-entry-count
        = @entries.count

    .col-xs-3.col-with-divider
      .dispute-time-wrapper
        %label.content-label-sm
          Date/Time Submitted
        %div= @dispute.case_opened_at
        %br
        %label.content-label-sm
          Age
        %div= @dispute.case_opened_at && distance_of_time_in_words(Time.now, @dispute.case_opened_at)
      .top-info-buttons-wrapper
        %button.edit-button.dispute-top-buttons#edit-dispute-button
        %button.save-button.dispute-top-buttons#save-dispute-button.hidden{onclick: 'save_dispute();'}
        %button.cancel-button.dispute-top-buttons#cancel-dispute-button.hidden


  .row#top_bar_extended_info
    .col-xs-12
      %h3 Submitter Information
      .row
        .col-xs-2.col-with-divider
          %label.content-label-sm
            Submitter Type
          %p= @dispute.submitter_type
        .col-xs-2.col-with-divider
          %label.content-label-sm
            Submitter Organization
          %p= @dispute.customer.company.name
        .col-xs-3.col-with-divider
          %label.content-label-sm
            Submitter Domain
          %p= @dispute.customer.email.partition("@").last
        .col-xs-2.col-with-divider
          %label.content-label-sm
            Contact Name
          %p.dispute-edit-field#dispute-customer-name= @dispute.customer.name
          %input.dispute-edit-input#dispute-customer-name-input{type: 'text', value: "#{@dispute.customer.name}"}

        .col-xs-3.col-with-divider
          %label.content-label-sm
            Contact Email
          %p.dispute-edit-field#dispute-customer-email= @dispute.customer.email
          %input.dispute-edit-input#dispute-customer-email-input{type: 'text', value: "#{@dispute.customer.email}"}
      %h3 Case Management Information
      .row
        .col-xs-2.col-with-divider
          %label.content-label-sm
            First Accept Date
          %p= @dispute.case_accepted_at&.strftime('%F %T')
        .col-xs-2.col-with-divider
          %label.content-label-sm
            First Repsonse Date
          %p= @dispute.case_responded_at&.strftime('%F %T')
        .col-xs-1.col-with-divider
          %label.content-label-sm
            Minutes to Accept
          %p= @dispute.minutes_to_accept && '%.1f' % @dispute.minutes_to_accept
        .col-xs-1.col-with-divider
          %label.content-label-sm
            Minutes to Respond
          %p= @dispute.minutes_to_respond && '%.1f' % @dispute.minutes_to_respond
        .col-xs-1.col-with-divider
          %label.content-label-sm
            Days to Close
          %p= @dispute.days_to_close && '%.1f' % @dispute.days_to_close
        .col-xs-1.col-with-divider
          %label.content-label-sm
            Minutes to Close
          %p= @dispute.minutes_to_close && '%.1f' % @dispute.minutes_to_close
        .col-xs-1.col-with-divider
          %label.content-label-sm
            Email Count
          %p= @dispute.dispute_emails.count
        .col-xs-3
          %label.content-label-sm
            Last Updated By
          %p= @dispute.last_updated_by_username
      %h3 Related Cases
      %button#related-dispute-button
        Add Related Case
      .row
        .col-xs-2.col-with-divider
          %label.content-label-sm
            Case ID
        .col-xs-2.col-with-divider
          %label.content-label-sm
            Date/Time Submitted
      .row.hidden#related-dispute-input
        .col-xs-2.col-with-divider
          %input.dispute-edit-input#related-dispute-id{type: 'text'}
        .col-xs-2.col-with-divider
          -#Placeholder for now
      - @dispute.each_related do |dispute_dup|
        .row
          .col-xs-2.col-with-divider
            %label.content-label-sm
            %p= link_to(dispute_dup.case_id_str, escalations_webrep_dispute_path(dispute_dup.id), target: "_blank")
          .col-xs-2.col-with-divider
            %label.content-label-sm
            %p= dispute_dup.case_opened_at&.strftime('%F %T')
  .row
    .col-xs-12.text-center
      %button#top_bar_toggle{onClick: '$( "#top_bar_extended_info" ).slideToggle( ); $("#top_bar_toggle").toggleClass("top-info-open");'}

%ul.nav.nav-tabs#research-tab{role: 'tablist'}
  %li.nav-item{role:'presentation'}
    %a.nav-link#communication-tab-link{href: '#communication_tab', 'aria-controls': 'communication', role: 'tab', 'data-toggle': 'tab'}
      Communication
  %li.nav-item{role:'presentation'}
    %a.nav-link#research-tab-link{href: '#research_tab', 'aria-controls': 'research', role: 'tab', 'data-toggle': 'tab'}
      Research
  %li.nav-item{role:'presentation'}
    %a.nav-link#related-tab-link{href: '#related_tab', 'aria-controls': 'related', role: 'tab', 'data-toggle': 'tab'}
      Duplicate Cases

.tab-content.content-wrapper#bug-tab-content
  .tab-pane#communication_tab{role: 'tabpanel'}
    = render 'escalations/webrep/disputes/communication_tab'
  .tab-pane#research_tab{role: 'tabpanel'}
    = render 'escalations/webrep/disputes/research_tab'
  .tab-pane#related_tab{role: 'tabpanel'}
    .related-cases-button-div
      %button{type: 'button', onclick: 'show_set_duplicate_dispute();'} + Duplicate
      #set-related-dispute-div{style: 'display: none;'}
        %form#set-related-dispute-form{onsubmit: 'set_related_dispute(this);return false;', 'data-dispute-id': @dispute.id}
          %label
            Ticket ID:
            %input.dispute-id{type: 'text', name: 'dispute_id'}
      #set-duplicate-dispute-div{style: 'display: none;'}
        %form#set-duplicate-dispute-form{onsubmit: 'set_duplicate_dispute(this);return false;', 'data-dispute-id': @dispute.id}
          %label
            Ticket ID:
            %input.dispute-id{type: 'text', name: 'dispute_id'}
    .related-cases-display
      %table
        %caption Duplicate Cases
        %tbody
          - @dispute.each_duplicate do |dispute_dup|
            %tr
              %td= link_to(dispute_dup.case_id_str, escalations_webrep_dispute_path(dispute_dup.id), target: "_blank")
              %td= dispute_dup.case_opened_at.strftime('%F %T')
