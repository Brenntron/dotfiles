#sidenav-icons-div
  %input{id: 'nav-trigger', type: 'checkbox', hidden: 'hidden'}
  %label{for: 'nav-trigger', id: 'nav-trigger-label'}
    = image_tag('layout/ac_nav_icon.svg', class: 'sidenav-icon', alt: 'Menu')
  %ul{class: 'sidenav-icons'}
    %li{class: 'nav-item nav-ac static-nav-item'}
      = image_tag('layout/analyst_console_icon.svg', class: 'sidenav-icon', alt: 'Analyst Console')
    %li{class: 'nav-menu-spacer static-nav-item'}
    - if is_rule_user?
      %li{class: 'nav-bugs'}
        %a{class: 'static-nav-item', 'data-toggle': 'collapse', href:'.bugs-subnav', role:'button', 'aria-expanded':'false', 'aria-controls':'bugs-subnav bugs-subnav-icons'}
          = image_tag('layout/bugs_icon.svg', class: 'sidenav-icon', alt: 'Bugs')
        %ul{class: 'sub-nav collapse bugs-subnav', id: 'bugs-subnav-icons'}
          - if is_rule_user?
            %li{class: 'ips-link'}
              %a{href: '/bugs'}= inline_svg 'icon_snort.svg', class: 'sidenav-svg'

    - if is_rule_user? || can?(:index, any: [FileReputationDispute, Dispute, Complaint])
      %li{class: 'nav-escalations'}
        %a{class: 'static-nav-item', 'data-toggle': 'collapse', href:'.esc-subnav', role:'button', 'aria-expanded':'false', 'aria-controls':'esc-subnav esc-subnav-icons'}
          = image_tag('layout/icon_escalations.svg', class: 'sidenav-icon', alt: 'Escalations')
        %ul{class: 'sub-nav collapse esc-subnav', id: 'esc-subnav-icons'}
          - if is_rule_user?
            %li{class: 'ips-link'}
              %a{href: '/escalation_bugs'}
                =inline_svg 'icon_snort.svg', class: 'sidenav-svg'
          - if can?(:read, Admin)
            %li{class: 'clam-link disabled-link'}
              %a.disabled-link= inline_svg 'icon_clam.svg', class: 'sidenav-svg'
          - if can?(:index, FileReputationDispute)
            %li{class: 'amp-link'}
              %a{href: escalations_file_rep_disputes_path + "?f=open", id: 'amp-icon-link'}
                = inline_svg 'icon_filerep_tix_grey.svg', class: 'sidenav-svg'
          - if can?(:index, Dispute)
            %li{class: 'rep-link'}
              %a{href: escalations_webrep_disputes_path + "?f=unassigned", id: 'rep-icon-link'}
                =inline_svg 'icon_webrep_tix_grey.svg', class: 'sidenav-svg'
          - if can?(:index, SenderDomainReputationDispute)
            %li{class: 'sdr-link'}
              %a{href: escalations_sdr_disputes_path + "?f=unassigned", id: 'sdr-icon-link'}
                =inline_svg 'icon_sender_domain_tix.svg', class: 'sidenav-svg'
          - if can?(:index, Complaint)
            %li{class: 'cat-link'}
              %a{href: escalations_webcat_complaints_path, id: 'cat-icon-link'}
                =inline_svg 'icon_cat.svg', class: 'sidenav-svg'
    %li{class: 'nav-item nav-users'}
      %a{href: escalations_users_path}= image_tag('layout/users_icon.svg', class: 'sidenav-icon', alt: 'Users')

    - if can?(:read, Admin)
      %li{class: 'nav-admin'}
        %a{class: 'static-nav-item', 'data-toggle': 'collapse', href:'.admin-subnav', role:'button', 'aria-expanded':'false', 'aria-controls':'admin-subnav admin-subnav-icons'}
          = image_tag('layout/icon_admin.svg', class: 'sidenav-icon', alt: 'Admin')
        %ul#admin-subnav-icons.sub-nav.collapse.admin-subnav
          %li.acr-admin-link
            %a{href: '/admin'}
              =inline_svg 'icon_bug_grey.svg', class: 'sidenav-svg'
          %li.ace-admin-link
            %a{href: '/escalations/admin'}
              =inline_svg 'icon_escalations_grey.svg', class: 'sidenav-svg'

    %li{class: 'nav-docs'}
      %a{class: 'static-nav-item', 'data-toggle': 'collapse', href:'.doc-subnav', role:'button', 'aria-expanded':'false', 'aria-controls':'doc-subnav doc-subnav-icons'}
        = image_tag('layout/icon_documentation.svg', class: 'sidenav-icon', alt: 'Docs')
      %ul{class: 'sub-nav collapse doc-subnav', id: 'doc-subnav-icons'}
        %li{class: 'wiki-link'}
          %a{href: 'https://confluence.vrt.sourcefire.com/pages/viewpage.action?pageId=61384557', target: '_blank'}
            =inline_svg 'confluence-brands.svg', class: 'sidenav-svg'
        %li{class: 'release-link'}
          - if !@version.nil?
            %a{href: "https://confluence.vrt.sourcefire.com/display/OSDWE/ACE+v#{@version}", target: '_blank'}
              =inline_svg 'confluence-brands.svg', class: 'sidenav-svg'
          - else
            %a{href: "https://confluence.vrt.sourcefire.com/pages/viewpage.action?pageId=74714349", target: '_blank'}
              =inline_svg 'confluence-brands.svg', class: 'sidenav-svg'

  #sidenav-menu-div
    %ul{class: 'nav-container'}
      %li{class: 'nav-ac static-nav-item'}
        = image_tag('layout/ac_logo_text.svg', class: 'ac-logo-text', alt: 'Analyst Console')
      %li{class: 'static-nav-item'}
      - if is_rule_user?
        %li{class: 'nav-bugs'}
          %a{class: 'static-nav-item', 'data-toggle': 'collapse', href:'.bugs-subnav', role:'button', 'aria-expanded':'false', 'aria-controls':'bugs-subnav bugs-subnav-icons'}
            Snort Research Bugs

          %ul{class: 'sub-nav collapse bugs-subnav', id: 'bugs-subnav'}
            - if is_rule_user?
              %li{class: 'ips-link'}
                %a{href: '/bugs'} Snort Research Bugs
            - if can?(:read, Admin)
              %li{class: 'clam-link disabled-link'}
                %a.disabled-link Clam
            - if can?(:read, Admin)
              %li{class: 'amp-link disabled-link'}
                %a.disabled-link AMP
            - if can?(:read, Admin)
              %li{class: 'rep-link disabled-link'}
                %a.disabled-link Reputation
            - if can?(:read, Admin)
              %li{class: 'cat-link disabled-link'}
                %a.disabled-link Categorization

      - if is_rule_user? || can?(:index, any: [ FileReputationDispute, Dispute, Complaint ])
        %li{class: 'nav-escalations'}
          %a{class: 'static-nav-item', 'data-toggle': 'collapse', href:'.esc-subnav', role:'button', 'aria-expanded':'false', 'aria-controls':'esc-subnav esc-subnav-icons'}
            Snort Escalations
          %ul{class: 'sub-nav collapse esc-subnav', id: 'esc-subnav'}
            - if is_rule_user?
              %li{class: 'ips-link'}
                %a{href: '/escalation_bugs'} Snort Escalations
            - if can?(:read, Admin)
              %li{class: 'clam-link disabled-link'}
                %a.disabled-link Clam
            - if can?(:index, FileReputationDispute)
              %li{class: 'amp-link'}
                %a{href: escalations_file_rep_disputes_path + "?f=open", id: 'amp-link'} File Reputation
            - if can?(:index, Dispute)
              %li{class: 'rep-link'}
                %a{href: escalations_webrep_disputes_path + "?f=unassigned", id: 'rep-link'} Web Reputation
            - if can?(:index, SenderDomainReputationDispute)
              %li{class: 'sdr-link'}
                %a{href: escalations_sdr_disputes_path+ "?f=unassigned", id: 'sdr-icon-link'} Sender Domain Rep
            - if can?(:index, Complaint)
              %li{class: 'cat-link'}
                %a{href: escalations_webcat_complaints_path, id: 'cat-link'} Web Categorization
      %li{class: 'nav-users static-nav-item'}
        %a{href: escalations_users_path}
          Users
      - if can?(:read, Admin)
        %li{class: 'nav-admin'}
          %a{class: 'static-nav-item', 'data-toggle': 'collapse', href:'.admin-subnav', role:'button', 'aria-expanded':'false', 'aria-controls':'admin-subnav admin-subnav-icons'}
            Admin
          %ul.sub-nav.collapse.admin-subnav#admin-subnav
            %li.acr-admin-link
              %a{href: '/admin'}
                Research Admin
            %li.ace-admin-link
              %a{href: '/escalations/admin'}
                Escalations Admin

      %li{class: 'nav-docs'}
        %a{class: 'static-nav-item', 'data-toggle': 'collapse', href:'.doc-subnav', role:'button', 'aria-expanded':'false', 'aria-controls':'doc-subnav doc-subnav-icons'}
          Docs
        %ul{class: 'sub-nav collapse doc-subnav', id: 'doc-subnav'}
          %li{class: 'wiki-link'}
            %a{href: 'https://confluence.vrt.sourcefire.com/pages/viewpage.action?pageId=61384557', target: '_blank'} User Docs
          %li{class: 'release-link'}
            - if !@version.nil?
              %a{href: "https://confluence.vrt.sourcefire.com/display/OSDWE/ACE+v#{@version}", target: '_blank'} V #{@version}
            - else
              %a{href: "https://confluence.vrt.sourcefire.com/pages/viewpage.action?pageId=74714349", target: '_blank'} Release Notes


  .copyright-area
    = image_tag('logo_talos_white.svg', class: 'talos-logo', alt: 'Talos Logo')
    %p.copyright
      &copy #{ Date.today.year } Cisco Systems Inc. and/or its affiliates.
      %br
      All rights reserved.
