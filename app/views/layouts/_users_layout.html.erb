<div class="container-fluid users-page">
  <div class="col-xs-3 col-sm-3 col-md-2 col-lg-2 item-ids-column">
    <table class="right table index-table">
      <thead>
      <tr><td><strong>username</strong></td></tr>
      </thead>
      <tbody>
        <tr class="highlight <%= 'active' if current_user.id.to_s == params[:id] %>" id="show_<%= current_user.id %>">
          <td><%= link_to current_user.cvs_username, user_path(current_user) %></td>
        </tr>
        <% if current_user.has_role?('manager') %>
          <tr><td><strong>team</strong></td></tr>
          <% current_user.children.each do |user| %>
              <tr class="highlight <%= 'active' if user.id.to_s == params[:id] %>" id="show_<%= user.id %>">
                <td><%= link_to user.cvs_username, user_path(user) %></td>
              </tr>
          <% end %>
        <% end %>
        <tr><td><strong>co-workers</strong></td></tr>
        <% current_user.siblings.each do |user| %>
            <tr class="highlight <%= 'active' if user.id.to_s == params[:id] %>" id="show_<%= user.id %>">
              <td><%= link_to user.cvs_username, user_path(user) %></td>
            </tr>
        <% end %>
      </tbody>
    </table>
    <div class="col-pagination">

    </div>
  </div>
  <div class="col-xs-9 col-sm-9 col-md-10 col-lg-10 item-details-column">
    <div class="row header">
      <!-- action links -->
      <div class="col-xs-12 actions-bar">
        <%= form_for :user, url: results_users_path, method: :get do |form| %>
          <%= form.fields_for :search do |search_fields| %>
            <%= search_fields.label :name %>
            <%= search_fields.text_field :name %>
          <% end %>
          <%= form.submit 'Search' %>
        <% end %>

          <% if current_user.has_role?('manager') %>
          <%= link_to user_relationships_path(current_user) do %>
            <button class="btn btn-link icon-link custom-icon"><%= image_tag "tree-diagram-icon.png" %></button>
          <% end %>
        <%end%>
      </div>
      <% if current_user.has_role?('committer') %>
      <!-- committer specific links-->
      <% end %>
    </div>
    <%= render partial: "shared/flash_messages", flash: flash %>
    <%= yield %>
  </div>
</div>