!!! html
%html
  %head
    %title= content_for?(:title) ? content_for(:title) : 'Analyst Console'
    = stylesheet_link_tag("admin_redesign", media: "all", "data-turbolinks-track" => true)
    = javascript_include_tag("admin_redesign", "data-turbolinks-track" => true)
    = csrf_meta_tags

  %body{class: "rocket-layout #{controller_path.gsub('/', '--')}-controller #{action_name}-action"}
 
    #sidenav-icons-div
      %input{id: 'nav-trigger', type: 'checkbox', hidden: 'hidden'}
      %label{for: 'nav-trigger', id: 'nav-trigger-label'}
        = image_tag('layout/ac_nav_icon.svg', class: 'sidenav-icon', alt: 'Menu')
      %ul{class: 'sidenav-icons'}
        %li{class: 'nav-item nav-ac static-nav-item'}
          = image_tag('layout/analyst_console_icon.svg', class: 'sidenav-icon', alt: 'Analyst Console')
        %li{class: 'nav-menu-spacer static-nav-item'}
          -# Spacer for Menu Toggle
        - if can?(:list_research, Bug)
          %li{class: 'nav-bugs'}
            %a{class: 'static-nav-item', 'data-toggle': 'collapse', href:'.bugs-subnav', role:'button', 'aria-expanded':'false', 'aria-controls':'bugs-subnav bugs-subnav-icons'}
              = image_tag('layout/bugs_icon.svg', class: 'sidenav-icon', alt: 'Bugs')
            %ul{class: 'sub-nav collapse bugs-subnav', id: 'bugs-subnav-icons'}
              %li{class: 'ips-link'}
                %a{href: bugs_path}
                  =inline_svg 'icon_snort.svg'
              %li{class: 'clam-link'}
                %a
                  =inline_svg 'icon_clam.svg'
              %li{class: 'amp-link'}
                %a
                  =inline_svg 'icon_amp.svg'
              %li{class: 'rep-link'}
                %a
                  =inline_svg 'icon_rep.svg'
              %li{class: 'cat-link'}
                %a
                  =inline_svg 'icon_cat.svg'
        - if can?(:list_escalations, Bug)
          %li{class: 'nav-escalations'}
            %a{class: 'static-nav-item', 'data-toggle': 'collapse', href:'.esc-subnav', role:'button', 'aria-expanded':'false', 'aria-controls':'esc-subnav esc-subnav-icons'}
              = image_tag('layout/icon_escalations.svg', class: 'sidenav-icon', alt: 'Escalations')
            %ul{class: 'sub-nav collapse esc-subnav', id: 'esc-subnav-icons'}
              %li{class: 'ips-link'}
                %a{href: escalations_bugs_path}
                  =inline_svg 'icon_snort.svg'
              %li{class: 'clam-link'}
                %a
                  =inline_svg 'icon_clam.svg'
              %li{class: 'amp-link'}
                %a
                  =inline_svg 'icon_amp.svg'
              %li{class: 'rep-link'}
                %a
                  =inline_svg 'icon_rep.svg'
              %li{class: 'cat-link'}
                %a
                  =inline_svg 'icon_cat.svg'
        %li{class: 'nav-item nav-users'}
          %a{href: users_path}= image_tag('layout/users_icon.svg', class: 'sidenav-icon', alt: 'Users')

        - if can?(:read, Admin)
          %li{class: 'nav-item nav-admin'}
            %a{href: admin_root_path}= image_tag('layout/icon_admin.svg', class: 'sidenav-icon', alt: 'Admin')

        %li{class: 'nav-docs'}
          %a{class: 'static-nav-item', 'data-toggle': 'collapse', href:'.doc-subnav', role:'button', 'aria-expanded':'false', 'aria-controls':'doc-subnav doc-subnav-icons'}
            = image_tag('layout/icon_documentation.svg', class: 'sidenav-icon', alt: 'Docs')
          %ul{class: 'sub-nav collapse doc-subnav', id: 'doc-subnav-icons'}
            - if can?(:read, RuleDoc)
              %li{class: 'doc-link'}
                %a{href: rule_docs_path}
                  =inline_svg 'icon_snort.svg'
            %li{class: 'wiki-link'}
              %a{href: 'https://git.vrt.sourcefire.com/talosweb/Analyst-Console/wiki'}
                =inline_svg 'icon_wiki_grey.svg'

      #sidenav-menu-div
        %ul{class: 'nav-container'}
          %li{class: 'nav-ac static-nav-item'}
            = image_tag('layout/ac_logo_text.svg', class: 'ac-logo-text', alt: 'Analyst Console')
          %li{class: 'static-nav-item'}
          - if can?(:list_research, Bug)
            %li{class: 'nav-bugs'}
              %a{class: 'static-nav-item', 'data-toggle': 'collapse', href:'.bugs-subnav', role:'button', 'aria-expanded':'false', 'aria-controls':'bugs-subnav bugs-subnav-icons'}
                Bugs

              %ul{class: 'sub-nav collapse bugs-subnav', id: 'bugs-subnav'}
                %li{class: 'ips-link'}
                  %a{href: bugs_path} IPS
                %li{class: 'clam-link'}
                  %a Clam
                %li{class: 'amp-link'}
                  %a AMP
                %li{class: 'rep-link'}
                  %a Reputation
                %li{class: 'cat-link'}
                  %a Categorization

          - if can?(:list_escalations, Bug)
            %li{class: 'nav-escalations'}
              %a{class: 'static-nav-item', 'data-toggle': 'collapse', href:'.esc-subnav', role:'button', 'aria-expanded':'false', 'aria-controls':'esc-subnav esc-subnav-icons'}
                Escalations
              %ul{class: 'sub-nav collapse esc-subnav', id: 'esc-subnav'}
                %li{class: 'ips-link'}
                  %a{href: escalations_bugs_path} IPS
                %li{class: 'clam-link'}
                  %a Clam
                %li{class: 'amp-link'}
                  %a AMP
                %li{class: 'rep-link'}
                  %a Reputation
                %li{class: 'cat-link'}
                  %a Categorization
          %li{class: 'nav-users static-nav-item'}
            %a{href: users_path}
              Users
          - if can?(:read, Admin)
            %li{class: 'nav-admin static-nav-item'}
              %a{href: admin_root_path}
                Admin


          %li{class: 'nav-docs'}
            %a{class: 'static-nav-item', 'data-toggle': 'collapse', href:'.doc-subnav', role:'button', 'aria-expanded':'false', 'aria-controls':'doc-subnav doc-subnav-icons'}
              Docs
            %ul{class: 'sub-nav collapse doc-subnav', id: 'doc-subnav'}
              - if can?(:read, RuleDoc)
                %li{class: 'ruledocs-link'}
                  %a{href: rule_docs_path}
                    IPS Rules
              %li{class: 'wiki-link'}
                %a{href: 'https://git.vrt.sourcefire.com/talosweb/Analyst-Console/wiki'}
                  Wiki

    #page-wrapper

      -# move/adjust this? especially since "My Dashboard" has name &c.
      %nav{id: "nav-banner"}
        = content_for(:nav_banner) if content_for?(:nav_banner)
        = render "escalations/webcat/shared/rocket_nav"
        %div
        - if current_user
          #login-div
            %a{href: "/users/#{current_user[:id]}"}
              %strong
                =current_user[:display_name]

      #page-content-wrapper
        =yield
