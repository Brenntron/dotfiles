          -#%br/
          -#= text_field_tag 'regex_text', nil, placeholder: 'Add a URL regex...'
          -#= label_tag 'advanced_query_status', 'Status'
          -#= select_tag "Status", options_for_select([ "New", "Assigned", "Resolved"], "Assigned")
          -#%br/
          -#= label_tag 'advanced_query_resolution', 'Resolution'
          -#= select_tag "Resolution", options_for_select([ "Fixed", "Invalid", "WontFix"], "Fixed")
          -#%br/
          -#= label_tag 'advanced_query_tag', 'Tag'
          -#= text_field_tag 'tag_text', nil, placeholder: 'Add tag...'
          -#%br/
          -#= label_tag 'advanced_query_channel', 'Added Through Channel'
          -#%br/
          -#.checkbox
          -#  %label
          -#    %input{:type => "checkbox"}/
          -#    WBNP
          -#.checkbox
          -#  %label
          -#    %input{:type => "checkbox"}/
          -#    Submit URLS
          -#.checkbox
          -#  %label
          -#    %input{:type => "checkbox"}/
          -#    that other way

  - if current_user
    #login-div.nav-tool-block.col-sm-2.col-lg-2
      - if bugzilla_rest_logged_in?(bugzilla_rest_session) == true
        %span.bugzilla-status.bugzilla-logged-in.esc-tooltipped{title: 'Logged into Bugzilla'}
      - else
        %span.bugzilla-status.bugzilla-logged-out.esc-tooltipped{title: 'Not logged into Bugzilla'}
      %span.dropdown
        %button#user-settings-dropdown-button.dropdown-toggle{'data-toggle': 'dropdown', 'aria-expanded': 'false', 'aria-haspopup': 'true', type: 'button'}
        #user-settings-dropdown.dropdown-menu{'aria-labelledby': 'user-settings-dropdown-button'}
          -#    If user is logged into Bugzilla
          -#.message-text Log out of Bugzilla
          -# Logout button

          -#-#    Else
          .message-text Log into Bugzilla
          %form#top_banner_bugzilla_login_form
            .form-group.text-left
              %label.content-label-sm Username
              %input.form-control{name: 'username', autofocus: 'true'}
            .form-group.text-left
              %lable.content-label-sm Password
              %input.form-control{type: 'password', name: 'password'}
            .form-group.text-center
              %button#top_banner_bugzilla_login_button.panel-button.primary{'aria-label': 'Login', onclick: 'top_banner_bugzilla_login(); return false;'} Login

          %a{href: "/users/#{current_user[:id]}"}
            Login settings

      %a.nav-username{href: "/users/#{current_user[:id]}"}
        = current_user[:display_name]

    -##username= current_user.cvs_username


