- content_for(:title) do
  Escalations WebCat - Analyst Console

- content_for(:nav_banner) do
  .nav-tool-blocks.nav-page-button-wrapper.col-xs-1.col-sm-1.col-lg-1
    %a#complaints.nav-page-button{href: '/escalations/webcat/complaints/'}
      %span.nav-toolbar-icon-large.icon-queue

    %a#rules.nav-page-button{href: '/escalations/webcat/rules/'}
      %span.nav-toolbar-icon-large.icon-categories

    %a#reports.nav-page-button{href: '/escalations/webcat/reports/'}
      %span.nav-toolbar-icon-large.icon-reports




  .nav-tool-blocks.col-xs-2.col-sm-1.col-lg-1.dropdown
    %a{href: '#', class: 'dropdown-toggle', id: 'new-complaint', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
      %span{class: 'nav-toolbar-icon icon-new-white'}
      New
    .dropdown-menu.nav-tools-dropdown{'aria-labelledby': 'new-complaint'}
      %h3.nav-tool-dropdown-header.inverse
        New Complaint
      .nav-tool-content-wrapper
        = render 'new'
     
  .nav-tool-blocks.col-xs-2.col-sm-1.col-lg-1.dropdown
    %a{href: '#', class: 'dropdown-toggle', id: 'fetch', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
      %span{class: 'nav-toolbar-icon icon-new-white'}
      Fetch
    .dropdown-menu.nav-tools-dropdown{'aria-labelledby': 'fetch'} Fetch complaints   

  .nav-tool-blocks.col-xs-2.col-sm-1.col-lg-1.dropdown
    %a{href: '#', class: 'dropdown-toggle', id: 'group-cases', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
      %span{class: 'nav-toolbar-icon icon-filter-white'}
      Group By
    .dropdown-menu.nav-tools-dropdown#group-dropdown{'aria-labelledby': 'group-cases'}
      Group By

  .nav-tool-blocks.col-xs-2.col-sm-1.col-lg-1.dropdown
    %a{href: '#', class: 'dropdown-toggle', id: 'filter-cases', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
      %span{class: 'nav-toolbar-icon icon-filter-white'}
      Filter
    .dropdown-menu.nav-tools-dropdown#filter-dropdown{'aria-labelledby': 'filter-cases'}
      %ul#filter-cases-list
        %li
          %a{onclick: 'standard_webrep_index_table("recently_viewed");'}
            %span.nav-dropdown-icon.icon-recently-viewed
            Recently Viewed
        %li
          %a{onclick: 'standard_webrep_index_table("my_disputes");'}
            %span.nav-dropdown-icon.icon-my-bugs
            My Tickets
        %li
          %a{onclick: 'standard_webrep_index_table("my_open");'}
            %span.nav-dropdown-icon.icon-my-open-bugs
            My Open Tickets
        %li
          %a{onclick: 'standard_webrep_index_table("team_disputes");'}
            %span.nav-dropdown-icon.icon-team-bugs
            My Team Tickets
        %li
          %a{onclick: 'standard_webrep_index_table("open");'}
            %span.nav-dropdown-icon.icon-open-bugs
            Open Tickets
        %li
          %a{onclick: 'standard_webrep_index_table("closed");'}
            %span.nav-dropdown-icon.icon-fixed-bugs
            Closed Tickets
        %li
          %a{onclick: 'standard_webrep_index_table("all");'}
            %span.nav-dropdown-icon.icon-all-tickets
            All Tickets

      #saved-searches-wrapper.nav-tool-content-wrapper
        %h3.nav-tool-dropdown-header
          %span.nav-dropdown-content-icon.icon-saved-search
          My Saved Searches
        %table{class: 'table table-condensed small', id: 'saved-search'}
          %tbody
            - if current_user.named_searches.any?
              - current_user.named_searches.each do |named_search|
                %tr{id: "saved_search_#{named_search.id}"}
                  %td
                    %a.saved-search{onclick: "named_webrep_index_table('#{named_search.name}');"}
                      = named_search.name
                    %a.delete-search{title: 'Delete Saved Search', onclick: "delete_disputes_named_search(this, '#{named_search.name}');"}
                      = image_tag('icon_cancel_grey.svg')

  .nav-tool-blocks.col-xs-2.col-sm-4.col-lg-3.search-wrapper
    .input-group.search-group
      = form_tag('/tickets', method: :get) do
        = text_field_tag 'case[id]', "#{}", class: 'search-box', placeholder: 'Search'

      %button#advanced-search-button.btn.btn-default.nav-tool-button.dropdown-toggle{'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
        Advanced
      .dropdown-menu.nav-tools-dropdown#advanced-search-dropdown{'aria-labelledby': 'advanced-search-button'}
        %h3.nav-tool-dropdown-header.inverse
          Advanced Search
        #advanced-search-wrapper.nav-tool-content-wrapper
          = render 'advanced_search'

          -#= label_tag 'advanced_query_complaints', 'Complaint IDs'
          -#%br/
          -#= text_area_tag 'complaint_ids', nil, placeholder: 'Add some complaint IDs...'
          -#= label_tag 'advanced_query_urls', 'URLs/IPs/Domains'
          -#%br/
          -#= text_area_tag 'urls_ids', nil, placeholder: 'Add some urls/ips/domains...'
          -#= label_tag 'advanced_query_regex', 'URL regex'
          -#%br/
          -#= text_field_tag 'regex_text', nil, placeholder: 'Add a URL regex...'
          -#= label_tag 'advanced_query_status', 'Status'
          -#= select_tag "Status", options_for_select([ "New", "Assigned", "Resolved"], "Assigned")
          -#%br/
          -#= label_tag 'advanced_query_resolution', 'Resolution'
          -#= select_tag "Resolution", options_for_select([ "Fixed", "Invalid", "WontFix"], "Fixed")
          -#%br/
          -#= label_tag 'advanced_query_tag', 'Tag'
          -#= text_field_tag 'tag_text', nil, placeholder: 'Add tag...'
          -#%br/
          -#= label_tag 'advanced_query_channel', 'Added Through Channel'
          -#%br/
          -#.checkbox
          -#  %label
          -#    %input{:type => "checkbox"}/
          -#    WBNP
          -#.checkbox
          -#  %label
          -#    %input{:type => "checkbox"}/
          -#    Submit URLS
          -#.checkbox
          -#  %label
          -#    %input{:type => "checkbox"}/
          -#    that other way

= render template: "layouts/rocket"
