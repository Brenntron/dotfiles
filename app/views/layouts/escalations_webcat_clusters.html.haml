- content_for(:nav_banner) do
  %input{type:'hidden', name: 'token', value: "#{current_user.authentication_token}"}
  %input{type:'hidden', name: 'xml_token', value: "#{xml_token}"}
  %input{type:'hidden', name: 'current_user', value: "#{current_user.authentication_token}"}

  .nav-tool-blocks.nav-page-button-wrapper.col-xs-3.col-sm-4.col-md-4.col-lg-3
    %a#complaints.nav-page-button{href: '/escalations/webcat/complaints'}
      %span.nav-toolbar-icon-large.icon-queue
    %a#rules.nav-page-button{href: '/escalations/webcat/clusters', class: "active"}
      %span.nav-toolbar-icon-large.icon-categories
    %a#reports.nav-page-button{href: '/escalations/webcat/reports'}
      %span.nav-toolbar-icon-large.icon-reports-white
    %a#reports.nav-page-button{href: '/escalations/webcat/research'}
      %span.nav-toolbar-icon-large.icon-research
    %a#reports.nav-page-button{href: '/escalations/webcat/complaints/resolution_message_templates'}
      %span.nav-toolbar-icon-large.icon-resolution-manager-page

  =render 'escalations/webcat/shared/categorize_dropdown'

  .nav-tool-blocks.col-xs-3.col-sm-1.col-lg-1.dropdown#filter-clusters-nav
    %a{href: '#', class: 'dropdown-toggle', id: 'filter-clusters', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
      %span{class: 'nav-toolbar-icon icon-filter-white'}
      Filter
    .dropdown-menu.nav-tools-dropdown.webcat-filter-dropdown{'aria-labelledby': 'filter-cases'}
      %ul#filter-cases-list
        %li{class: ("selected" if params[:f] == "my")}
          %a{href: '?f=my'}
            %span.nav-dropdown-icon.icon-my-bugs
            My Clusters
        %li{class: ("selected" if params[:f] == "unassigned")}
          %a{href: '?f=unassigned'}
            %span.nav-dropdown-icon.icon-open-bugs
            Unassigned Clusters
        %li{class: ("selected" if params[:f] == "pending")}
          %a{href: '?f=pending'}
            %span.nav-dropdown-icon.icon-pending-bugs
            Waiting For Review
        %li{class: ("selected" if params[:f] == "all")}
          %a{href: '?f=all'}
            %span.nav-dropdown-icon.icon-recently-viewed
            All Clusters

      #saved-searches-wrapper.webcat-named-search-list.nav-tool-content-wrapper
        %h3.nav-tool-dropdown-header
          %span.nav-dropdown-content-icon.icon-saved-search
          My Saved Searches
        %table{class: 'table', id: 'saved-search'}
          %tbody#saved-search-tbody
            - current_user.named_searches.where_project_type('webcat_clusters_regex').order(:name).each do |named_search|
              %tr{id: "saved_search_#{named_search.id}"}
                %td
                  %a.input-truncate.saved-search.esc-tooltipped{onclick: "build_webcat_clusters_named_search(this);", title: named_search.name, name: named_search.name, :'data-search_conditions' => search_condition_json(named_search)}
                    = named_search.name
                  %a.delete-search{title: 'Delete Saved Search', name: named_search.name, onclick: "delete_clusters_named_search(this);"}
                    = image_tag('icon_cancel_grey.svg')

  .nav-tool-blocks.col-xs-3.col-sm-5.col-lg-4.search-wrapper.row#clusters-nav-regex-wrapper
    .input-group.search-group
      %input#cluster_filter_field.text_field.search-box{placeholder: 'Filter clusters via regex', autofocus: 'true'}
      %button#apply-regex-btn{onclick: 'apply_filter_to_table()'} Apply Regex
    .clusters-nav-regex-container
      %label
        Save Regex
      %input#saveRegex{type: 'checkbox'}


  #login-div.nav-tool-block.col-sm-2.col-lg-2
    - if current_user
      %a.nav-username{href: "/escalations/users/#{current_user[:id]}"}
        = current_user[:display_name]

= render template: "layouts/application"
