- content_for(:title) do
  Escalations - Analyst Console

- content_for(:nav_banner) do
  .nav-tool-blocks.nav-page-button-wrapper.col-xs-3.col-sm-3.col-lg-2
    %a#dashboard.nav-page-button{href: '/escalations/webrep/dashboard', class: ("active" if current_page?('/escalations/webrep/dashboard'))}
      %span.nav-toolbar-icon-large.icon-dashboard

    %a#queue.nav-page-button{href: escalations_webrep_disputes_path(params: {f: 'open'}), class: ("active" if current_page?('/escalations/webrep/disputes'))}
      %span.nav-toolbar-icon-large.icon-queue

    %a#research.nav-page-button{href: '/escalations/webrep/research', class: ("active" if current_page?('/escalations/webrep/research'))}
      %span.nav-toolbar-icon-large.icon-research

  .nav-tool-blocks.col-xs-1.col-sm-1.col-lg-1.dropdown
    %a{href: '#', class: 'dropdown-toggle', id: 'new-dispute', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
      %span{class: 'nav-toolbar-icon icon-new-white'}
      New
    .dropdown-menu.nav-tools-dropdown{'aria-labelledby': 'new-dispute'}
      %h3.nav-tool-dropdown-header.inverse
        New Dispute
      .nav-tool-content-wrapper#new-dispute-wrapper
        = render 'escalations/webrep/disputes/new'

  .nav-tool-blocks.col-xs-1.col-sm-1.col-lg-1.dropdown
    %a{href: '#', class: 'dropdown-toggle', id: 'filter-cases', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
      %span{class: 'nav-toolbar-icon icon-filter-white'}
      Filter
    .dropdown-menu.nav-tools-dropdown#filter-dropdown{'aria-labelledby': 'filter-cases'}
      %ul#filter-cases-list
        %li{class: ("selected" if params[:f] == "recently_viewed")}
          %a{href: "#{escalations_webrep_disputes_path}?f=recently_viewed"}
            %span.nav-dropdown-icon.icon-recently-viewed
            Recently Viewed
        %li{class: ("selected" if params[:f] == "my_disputes")}
          %a{href: "#{escalations_webrep_disputes_path}f=my_disputes"}
            %span.nav-dropdown-icon.icon-my-bugs
            My Tickets
        %li{class: ("selected" if params[:f] == "my_open")}
          %a{href: "#{escalations_webrep_disputes_path}?f=my_open"}
            %span.nav-dropdown-icon.icon-my-open-bugs
            My Open Tickets
        %li{class: ("selected" if params[:f] == "team_disputes")}
          %a{href: "#{escalations_webrep_disputes_path}?f=team_disputes"}
            %span.nav-dropdown-icon.icon-team-bugs
            My Team Tickets
        %li{class: ("selected" if params[:f] == "unassigned")}
          %a{href: "#{escalations_webrep_disputes_path}?f=unassigned"}
            %span.nav-dropdown-icon.icon-unassigned-bugs
            Unassigned Tickets
        %li{class: ("selected" if params[:f] == "open")}
          %a{href: "#{escalations_webrep_disputes_path}?f=open"}
            %span.nav-dropdown-icon.icon-open-bugs
            Open Tickets
        %li{class: ("selected" if params[:f] == "open_email")}
          %a{href: "#{escalations_webrep_disputes_path}?f=open_email"}
            %span.nav-dropdown-icon.icon-email-tix
            Open Email Tickets
        %li{class: ("selected" if params[:f] == "open_web")}
          %a{href: "#{escalations_webrep_disputes_path}?f=open_web"}
            %span.nav-dropdown-icon.icon-web-tix
            Open Web Tickets
        %li{class: ("selected" if params[:f] == "closed")}
          %a{href: "#{escalations_webrep_disputes_path}?f=closed"}
            %span.nav-dropdown-icon.icon-fixed-bugs
            Closed Tickets
        %li{class: ("selected" if params[:f] == "all")}
          %a{href: "#{escalations_webrep_disputes_path}?f=all"}
            %span.nav-dropdown-icon.icon-all-tickets
            All Tickets

      #saved-searches-wrapper.nav-tool-content-wrapper
        %h3.nav-tool-dropdown-header
          %span.nav-dropdown-content-icon.icon-saved-search
          My Saved Searches
        %table#saved-search.table
          %tbody#saved-search-tbody
            - if current_user.named_searches.any?
              - current_user.named_searches.where('project_type = ? OR project_type IS ?', 'Dispute', nil).order(:id).each do |named_search|
                %tr{id: "saved_search_#{named_search.id}"}
                  %td
                    %a.input-truncate.saved-search.esc-tooltipped{onclick: "named_webrep_index_table('#{named_search.name}');", title: named_search.name}
                      = named_search.name
                    %a.delete-search{title: 'Delete Saved Search', onclick: "delete_disputes_named_search(this, '#{named_search.name}');"}
                      = image_tag('icon_cancel_grey.svg')

  .nav-tool-blocks.col-xs-4.col-sm-4.col-lg-5.search-wrapper
    .input-group.search-group#web-rep-search
      = form_tag('/tickets', method: :get, onsubmit: 'call_contains_search(this);return false;') do
        = text_field_tag 'case[id]', "#{}", class: 'search-box', placeholder: 'Search by Substring'

      %button#advanced-search-button.btn.btn-default.nav-tool-button.dropdown-toggle{'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
        Advanced
      .dropdown-menu.nav-tools-dropdown#advanced-search-dropdown{'aria-labelledby': 'advanced-search-button'}
        %h3.nav-tool-dropdown-header.inverse
          Advanced Search
        #advanced-search-wrapper.nav-tool-content-wrapper
          = render 'escalations/webrep/disputes/advanced_search'

  - if current_user
    #login-div.nav-tool-block.col-sm-3.col-lg-3
      = bugzilla_rest_login_icon(bugzilla_rest_session)
      %span.dropdown
        %span#user-settings-dropdown-button.dropdown-toggle.esc-tooltipped{'title': 'Login to Bugzilla', 'data-toggle': 'dropdown', 'aria-expanded': 'false', 'aria-haspopup': 'true', type: 'button'}
        #user-settings-dropdown.dropdown-menu{'aria-labelledby': 'user-settings-dropdown-button'}
          -#    If user is logged into Bugzilla
          -#.message-text Log out of Bugzilla
          -# Logout button
          
          -#-#    Else
          .message-text Log into Bugzilla
          %form#top_banner_bugzilla_login_form
            .form-group.text-left
              %label.content-label-sm Username
              %input.form-control{name: 'username', autofocus: 'true'}
            .form-group.text-left
              %lable.content-label-sm Password
              %input.form-control{type: 'password', name: 'password'}
            .form-group.text-center
              %button#top_banner_bugzilla_login_button.panel-button.primary{'aria-label': 'Login', onclick: 'top_banner_bugzilla_login(); return false;'} Login

          %a{href: "/users/#{current_user[:id]}"}
            Login settings

      %a.nav-username{href: "/users/#{current_user[:id]}"}
        = current_user[:display_name]


    -##username= current_user.cvs_username

= render template: "layouts/rocket"

- if params[:f]
  :javascript
    $(document).ready(function(){
      window.filter_param = "#{params[:f]}";
      standard_webrep_index_table("#{params[:f]}")
    })
