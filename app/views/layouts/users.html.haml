- content_for(:title) do
  Users - Analyst Console

- content_for(:nav_banner) do
  .nav-tool-blocks.nav-page-button-wrapper.col-xs-3.col-sm-3.col-lg-2
    %a#userpage.nav-page-button{href: "/escalations/users/#{current_user[:id]}", class: ("active" if current_page?("/escalations/users/#{current_user[:id]}"))}
      %span.nav-toolbar-icon-large.icon-user-page

    %a#related-users.nav-page-button{href: '/escalations/users', class: ("active" if current_page?('/escalations/users'))}
      %span.nav-toolbar-icon-large.icon-related-users

    %a#all-users.nav-page-button{href: '/escalations/users/all', class: ("active" if current_page?('/escalations/users/all'))}
      %span.nav-toolbar-icon-large.icon-queue

  .nav-tool-blocks.search-wrapper.col-xs-6.col-lg-8
    .input-group.search-group
      = form_for :user, url: results_escalations_users_path, method: :get do |form|
        = form.fields_for :search do |search_fields|
          = search_fields.text_field :name, class: 'search-box', placeholder: 'Search for Users'
  -#= text_field_tag 'bug[id]', "#{@bug_search_id}", class: 'search-box', placeholder: 'Search by bug ID'


  - if current_user
    #login-div.nav-tool-block.col-xs-3.col-lg-2
      %a{href: "/escalations/users/#{current_user[:id]}"}
        = current_user[:display_name]

  %input{:name => "token", :type => "hidden", :value => "#{current_user.authentication_token}"}

= render template: "layouts/rocket"


- if params[:f]
  :javascript
    $(document).ready(function(){
      filterByStatus("#{params[:f]}")
    })
