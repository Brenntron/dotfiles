<div class="jumbotron">
  <div class="col-sm-offset-2">
    <p class="tagline">
      Please wait while we sign you in.
    </p>
  </div>
</div>

<script>
  function signIn(){
    $.ajax({
      url: "/sessions/create",
      method: 'POST',
    }).done(function(response) {
      window.location.replace("/");
    });
  };
  window.onload = signIn;
</script>