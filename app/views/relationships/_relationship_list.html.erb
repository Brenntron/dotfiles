<tr data-id="<%=user.id%>" data-parent="<%=user.parent.try(:id)%>" data-level="<%=level%>">
  <td data-column="name">
    <%= link_to user.cvs_username, escalations_user_path(user) %>
  </td>
  <td class="text-muted small">
    <%= user.roles.map(&:role).join(', ') %>
  </td>
  <td>
    <a type="button" class="glyphicon glyphicon-pencil" data-target='<%= "#roleModal_#{user.id}" %>' data-toggle="modal"></a>
    <div class="modal fade" id= '<%= "roleModal_#{user.id}" %>' tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidde="true">
      <div class="modal-dialog" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
            <h4 class="modal-title" id="myModalLabel">Update Role(s) for <%=user.cvs_username%></h4>
          </div>
          <div class="modal-body">
            <%=render 'shared/role_form', user: user %>
          </div>
        </div>
      </div>
    </div>
  </td>
  <td><%= link_to '<i class="glyphicon glyphicon-remove-circle"></i>'.html_safe, user_remove_from_team_path(user_id: user.id), method: :patch, data: {confirm: "Remove #{user.display_name} from team?"}%></td>
  <% if user.has_role?('manager') %>
    <td>
      <a type="button" class="glyphicon glyphicon-plus-sign" data-target='<%= "#teamModal_#{user.id}" %>' data-toggle="modal"></a>
      <div class="modal fade" id= '<%= "teamModal_#{user.id}" %>' tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidde="true">
        <div class="modal-dialog" role="document">
          <div class="modal-content">
            <div class="modal-header">
              <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
              <h4 class="modal-title" id="myModalLabel">Add to <%=user.cvs_username%>'s team</h4>
            </div>
            <div class="modal-body">
              <%=render 'relationships/form', user: user %>
            </div>
          </div>
        </div>
      </div>
    </td>
  <% end %>
</tr>