<div class='row item-info'>
  <div class='col-lg-11 col-md-11'>
    <div class="row">
      <div class="col-xs-12 col-sm-4">
        <h2 class="subtitle"> <%="#{current_user.display_name}'s Team"%>
          <span class="email-link"><%= image_tag "tree-diagram-icon.png" %></span>
        </h2>
      </div>
    </div>
    <div class='row top-space'>
      <div class="col-xs-11">
        <div class="col-xs-6 col-sm-4">
          <% if @user.team_members.any? %>
              <table class="table table-hover table-sm table-borderless">
                <tbody>
                  <% @user.team_member_relationships.each do |member| %>
                    <tr>
                      <th><%= link_to member.team_member.cvs_username, user_path(member.team_member) %></th>
                      <th><%= link_to '<i class="glyphicon glyphicon-remove-circle"></i>'.html_safe, user_relationship_path(id: member.id), method: :delete, data: {confirm: "Remove #{member.team_member.display_name} from your team?"}%></th>
                    </tr>
                  <%end%>
                </tbody>
              </table>
          <% else %>
              <p class="text-muted small"><em><strong><%= @user.cvs_username %></strong> is a lone wolf!</em></p>
          <% end %>
          <br>
          <%=form_for :relationship, url: user_relationships_path(@user), method: :post do |f|%>
            <div class="form-group"><div class="form-inline">
              <%= f.select :team_member_id, options_for_select(@users.map{|u| ["#{u.display_name} (#{u.cvs_username})", u.id]}), {prompt: "Choose Team Member"}, class: "form-control", required: "true"%>
              <%= f.hidden_field :user_id, value: @user.id %>
              <%= f.submit 'Add', class: 'btn btn-primary' %>
            </div>
            </div>
          <%end%>
        </div>
      </div>
    </div>
  </div>
</div>