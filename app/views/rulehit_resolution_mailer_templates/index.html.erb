<p id="notice"><%= notice %></p>

<h1>Rulehit Resolution Mailer Templates</h1>

<table>
  <thead>
    <tr>
      <th>Mnemonic</th>
      <th>To</th>
      <th>Cc</th>
      <th>Subject</th>
      <th>Body</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @rulehit_resolution_mailer_templates.each do |rulehit_resolution_mailer_template| %>
      <tr>
        <td><%= rulehit_resolution_mailer_template.mnemonic %></td>
        <td><%= rulehit_resolution_mailer_template.to %></td>
        <td><%= rulehit_resolution_mailer_template.cc %></td>
        <td><%= rulehit_resolution_mailer_template.subject %></td>
        <td><%= rulehit_resolution_mailer_template.body %></td>
        <td><%= link_to 'Show', rulehit_resolution_mailer_template %></td>
        <td><%= link_to 'Edit', edit_rulehit_resolution_mailer_template_path(rulehit_resolution_mailer_template) %></td>
        <td><%= link_to 'Destroy', rulehit_resolution_mailer_template, method: :delete, data: { confirm: 'Are you sure?' }, id: 'delete-'+rulehit_resolution_mailer_template.id.to_s  %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Rulehit Resolution Mailer Template', new_rulehit_resolution_mailer_template_path %>
<script>
  $('body').addClass('escalations--webrep--disputes-controller')
</script>