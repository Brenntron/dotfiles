

<%= form_tag "login" do %>
    <div class="field">
      <%= label_tag 'Bugzilla User' %>
      <br/>
      <%= text_field_tag 'user', params[:user] %>
    </div>
    <div class="field">
      <%= label_tag 'Bugzilla Password' %>
      <br/>
      <%= password_field_tag 'password' %>
    </div>
    <div class="actions">
      <%= submit_tag "login" %>
    </div>
<% end %>