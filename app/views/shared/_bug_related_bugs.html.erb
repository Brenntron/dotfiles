<% (@bug.snort_related_bugs(related_type)).each do |related_bug| %>
  <div class="row">
    <div class="col-xs-1">
      <% if related_bug.snort_blocker_bugs.pluck(:id).include?(@bug.id) %>
        <span class="icon-blocks bug-blocker" rel="popover" data-placement="top" data-original-title="Currently blocking" data-trigger="hover" data-toggle="tooltip"></span>
      <% end %>
      <% if related_bug.snort_blocked_bugs.pluck(:id).include?(@bug.id) %>
        <span class="icon-blocks blocked-bug" rel="popover" data-placement="top" data-original-title="Blocked by " data-trigger="hover" data-toggle="tooltip"></span>
      <% end %>
    </div>
    <div class="col-xs-11">
      <div class="row">
        <div class="col-xs-2">
          <h4><%= related_bug_link(related_bug, related_bug.id) %></h4>
        </div>
        <div class="col-xs-10 text-right">
          <button class='btn btn-sm btn-default' onclick="AC.Bugs.removeRelatedBug(<%= @bug.id %>, <%= related_bug.id %>)">Remove</button>
          <% if ['PENDING', 'FIXED', 'WONTFIX', 'LATER', 'RESOLVED'].include? related_bug.state %>
            <button class='btn btn-sm btn-default' onclick="AC.Bugs.reopenBug(<%= @bug.id %>, <%= related_bug.id %>, <%=related_bug.user.id%>, <%=related_bug.committer.id%>, '<%=related_bug.summary%>' )" >Re-open</button>
          <% end %>
          <!--<button class='btn btn-sm btn-default' >button3</button>-->
        </div>
      </div>
      <div class="row">
        <div class="col-xs-7">
          <%= related_bug_link(related_bug, related_bug.summary) %>
        </div>
        <div class="col-xs-5">
          <div class="row">
            <div class="col-xs-12">
              <table class="rule-status-table">
                <tbody>
                <tr>
                  <th>
                    State
                  </th>
                  <td>
                    <%= related_bug.state %>
                  </td>
                </tr>
                <tr>
                  <th>
                    Assignee
                  </th>
                  <td>
                    <%= related_bug.user.display_name %>
                  </td>
                </tr>
                <tr>
                  <th>
                    Last Updated
                  </th>
                  <td>
                    <%= related_bug.updated_at.strftime("%b %d, %Y") %>
                  </td>
                </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <hr>
<% end %>