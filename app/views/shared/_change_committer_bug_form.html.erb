<form id="change_committer_form" style="display:none;" class="form-inline top-space">
  <div class="form-group row">
    <div class="col-xs-12 col-lg-10">
      <%=select_tag :committer_id, options_for_select(Bug.allowed_committers(@bug).pluck(:cvs_username,:id), selected: @bug.committer_id), id: 'bug_committer', class: 'form-control input-sm'%>
      <button class="btn btn-xs btn-default" value="submit" type="submit">change committer</button>
    </div>
  </div>
</form>