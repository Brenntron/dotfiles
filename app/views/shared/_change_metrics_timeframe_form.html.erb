<form id="change_metrics_timeframe_form" style="display:none;" class="form-inline top-space">
  <div class="form-group row">
    <div class="col-xs-12 col-lg-10">
      <select class="form-control input-sm" id="user_metrics_timeframe">
        <option value="" disabled selected>select timeframe</option>
        <option value='7'>7 days</option>
        <option value='30'>30 days</option>
        <option value='90'>90 days</option>
        <option value='180'>6 months</option>
        <option value='365'>1 year</option>
      </select>
      <button class="btn btn-xs btn-default" value="submit" type="submit">done</button>
    </div>
  </div>
</form>