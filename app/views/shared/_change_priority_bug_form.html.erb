<div class="col-sm-12">
  <form id="change_priority_form" style="display:none;" class="form-inline top-space">
    <div class="form-group row">
      <div class="col-xs-12">
        <%=select_tag :priority, options_for_select(['Unspecified', 'P1', 'P2', 'P3', 'P4', 'P5'], selected: @bug.priority), id: 'bug_priority', class: 'form-control input-sm'%>
      </div>
      <div class="col-sm-7">
        <button class="btn btn-xs btn-default" value="submit" type="submit">change priority</button>
      </div>
      <div class="col-sm-1">
        <span class="glyphicon glyphicon-remove cancel-button" style="display:none;"id="cancel_priority"></span>
      </div>
    </div>
  </form>
</div>
