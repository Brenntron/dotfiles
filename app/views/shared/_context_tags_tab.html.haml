-# context tags tab exists on both webrep and filerep
.row
  .col-sm-12
    %h1 Context Tags
    %h2 Tag Management Interface

    .toolbar.context-tags-toolbar
      %div
        %label.toolbar-section-label
          Show
        %span.dropdown
          %button#tmi-columns-button.toolbar-button.show-col-context-tags.dropdown-toggle{title: 'Show/Hide Columns', 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
            %span.toolbar-button-text
              Show/Hide Columns

          .dropdown-menu.toolbar-dropdown.tmi-columns-dropdown{'aria-labelledby': 'tmi-columns-button'}
            %ul
              %li.toggle-vis
                %input{type: 'checkbox', checked: true} Observable
              %li.toggle-vis
                %input{type: 'checkbox', checked: true} Tag Name
              %li.toggle-vis
                %input{type: 'checkbox', checked: true} Mnemonic
              %li.toggle-vis
                %input{type: 'checkbox', checked: true} Tag Type
              %li.toggle-vis
                %input{type: 'checkbox', checked: true} Taxonomy
              %li.toggle-vis
                %input{type: 'checkbox', checked: true} Source
            %ul
              %li.toggle-vis
                %input{type: 'checkbox', checked: true} Processor
              %li.toggle-vis
                %input{type: 'checkbox', checked: true} Creation Date
              %li.toggle-vis
                %input{type: 'checkbox', checked: true} Suppressed?
              %li.toggle-vis
                %input{type: 'checkbox', checked: true} Suppression Source
              %li.toggle-vis
                %input{type: 'checkbox', checked: true} Suppression Platform
              %li.toggle-vis
                %input{type: 'checkbox', checked: true} Suppression Date

      %div
        %label.toolbar-section-label View
        %span.context-tags-toggle.suppressed-context-tags-toggle
          %input.cb-suppressed-tags{type:'checkbox', checked: true}
          %span.toggle-label Suppressed Tags
        %span.context-tags-toggle.unsuppressed-context-tags-toggle
          %input.cb-suppressed-tags{type:'checkbox', checked: true}
          %span.toggle-label Unsuppressed Tags

      %div
        %label.toolbar-section-label Actions
        %button.toolbar-button.add-context-tag-button
          %span.toolbar-button-text Add Tag
        %button.toolbar-button.suppress-context-tag-button
          %span.toolbar-button-text Suppress Tag
        %button.toolbar-button.unsuppress-context-tag-button
          %span.toolbar-button-text Unsuppress Tag
        %button.toolbar-button.remove-context-tag-button
          %span.toolbar-button-text Remove Tag

    -# tag management interface datatable used on both webrep and filerep
    %table.context-tags-table#tmi-dt
      %thead
        %tr
          %th
            %input.cb-tmi-select-all{type:'checkbox'}
          %th Observable
          %th Tag Name
          %th Mnemonic
          %th Tag Type
          %th Taxonomy
          %th Source
          %th Processor
          %th Creation Date
          %th Suppressed?
          %th Suppression Source
          %th Suppression Platform
          %th Suppression Date
      %tbody
        %tr
          %td.tmi-cell-cb
            %input.cb-tmi{type:'checkbox'}
          %td.tmi-cell-observable example.com
          %td.tmi-cell-tag-name Internet Accessible Device
          %td.tmi-cell-mnemonic Testing
          %td.tmi-cell-tag-type Techniques
          %td.tmi-cell-taxonomy MITRE ATT&CK
          %td.tmi-cell-source test_name
          %td.tmi-cell-processor Testing
          %td.tmi-cell-creation-date 2023-03-03 12:39:32 UTC
          %td.tmi-cell-suppressed.tmi-red-cell NO
          %td.tmi-cell-suppression-source.tmi-gray-cell
          %td.tmi-cell-suppression-platform.tmi-gray-cell
          %td.tmi-cell-suppression-date.tmi-gray-cell
        %tr
          %td.tmi-cell-cb
            %input.cb-tmi{type:'checkbox'}
          %td.tmi-cell-observable example.com
          %td.tmi-cell-tag-name Questionable
          %td.tmi-cell-mnemonic Example
          %td.tmi-cell-tag-type Techniques
          %td.tmi-cell-taxonomy MITRE ATT&CK
          %td.tmi-cell-source test_name
          %td.tmi-cell-processor Example
          %td.tmi-cell-creation-date 2023-03-03 12:39:32 UTC
          %td.tmi-cell-suppressed YES
          %td.tmi-cell-suppression-source Example
          %td.tmi-cell-suppression-platform Example
          %td.tmi-cell-suppression-date 2023-02-16 18:39:43 UTC


    -# enrich and prevalence areas below are used by webrep and filerep context tags tab
    %h2 Enrichment Service
    .enrichment-area
      %p.enrichment-loader.loading-message
        Loading...
      %p.enrichment-missing.missing-data.hidden
        No enrichment data found.
      %p.enrichment-error.missing-data.hidden
        Error gathering enrichment data.

      %table#enrichment-webrep-dt.enrich-webrep-table.context-tags-table.hidden
        %thead
          %th Context
          %th Taxonomy
          %th Name
          %th Description
          %th External References
        %tbody


    %h2 Prevalence
    .prevalence-area
      %p.prevalence-loader.loading-message
        Loading...
      %p.prevalence-missing.missing-data.hidden
        No prevalence data found.
      %p.prevalence-error.missing-data.hidden
        Error gathering prevalence data.

      %table#prevalence-webrep-dt.prevalence-webrep-table.context-tags-table.hidden
        %thead
          %th Dataset
          %th Count
          %th First Seen
          %th Last Seen
        %tbody
