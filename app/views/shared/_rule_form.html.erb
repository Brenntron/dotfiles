<div class="rule_form_id">
  <div class="new_rule_form">
    <div class="col-xs-8">
      <h4>New Rule</h4>
    </div>
    <div class="col-xs-4 top-space">
      <form role="form" class="form-inline pull-right prepopulate-form" id="duplicate_rule">
        <div class="form-group">
          <label class="sr-only">Duplicate: </label>
          <input class="form-control select-sm input-extra-narrow" name="rule_id" placeholder="rule SID" required>
          <button class="btn btn-default select-sm" value="submit">duplicate</button>
        </div>
      </form>
    </div>

  <form role="form" class="legacy_form">
    <div class="form-group">
      <div class="col-xs-12">
        <label>Rule content</label>
        <textarea class="form-control code select-sm" placeholder="Enter rule content" name="rule[rule_content]" rows="13" required></textarea>
      </div>
    </div>
    <div class="form-group center">
      <div class="col-xs-12">
        <button class="btn btn-warning save-rule-btn" type="submit" value="submit">Create Rule</button>
        &nbsp;&nbsp;<a class="btn btn-danger remove-rule">Discard</a>
      </div>
    </div>
  </form>

  <form role="form" class="standard_form">
    <div class="rule_form">
    <div class="form-group">
      <div class="col-xs-12">
        <h5>Message</h5>
        <div class="entry-type-switch">
        </div>
        <div class="col-xs-10">
          <input class="form-control create-input select-sm code" name="rule[message]" placeholder="enter a message" required="true">
        </div>
      </div>
    </div>
    <div class="col-xs-12">
      <h5>Connection</h5>
    </div>
    <div class="form-group">
      <div class="col-xs-12">
        <div class="entry-type-switch">
          <div class="radio">
            <label>
              <input type="radio" class='connection' name="connectionForm" checked value="true">
              <span class="sr-only">Select connection options</span>
            </label>
          </div>
        </div>
        <div class="col-xs-10 col-sm-11">
          <label for="connectionText" class="control-label sr-only">Connection</label>
          <div class="form-inline code">
            <select class="form-control select-sm connectionForm" name="rule[connection][]">
              <% ['alert', 'drop'].each do |type| %>
                  <option value="<%= type %>"><%= type %></option>
              <% end %>
            </select>
            <select class="form-control select-sm connectionForm" name="rule[connection][]">
              <% ['tcp','udp','ip','icmp'].each do |type| %>
                  <option value="<%= type %>"><%= type %></option>
              <% end %>
            </select>
            <select class="form-control select-sm connectionForm" name="rule[connection][]">
              <% ['$EXTERNAL_NET', '$HOME_NET', '$DNS_SERVERS', '$SMTP_SERVERS', '$HTTP_SERVERS', '$SQL_SERVERS',
                  '$TELNET_SERVERS', '$SSH_SERVERS', '$FTP_SERVERS','$SIP_SERVERS', '$AIM_SERVERS'].each do |dstsrc| %>
                  <option value=<%= dstsrc %>><%= dstsrc %></option>
              <% end %>
            </select>
            <div class="input-group">
              <input type="text" class="form-control input-select connectionForm" name="rule[connection][]" id="flow_src_ports" size="14" style="height:28px;">
              <div class="input-group-btn">
                <select class="form-control input-select-include" data-toggle="dropdown" style="height:28px;"><span class="caret"></span></select>
                <ul class="dropdown-menu">
                  <% ['$HTTP_PORTS','$SHELLCODE_PORTS', '$ORACLE_PORTS', '$SSH_PORTS', '$FTP_PORTS', '$SIP_PORTS', '$FILE_DATA_PORTS'].each do |srcport| %>
                    <li><a class="select-sm flow_src_ports" href="#"><%= srcport %></a></li>
                  <% end %>
                </ul>
              </div>
            </div>
            <select class="form-control select-sm connectionForm" name="rule[connection][]">
              <% ["->","<->"].each do |direction| %>
                  <option value="<%= direction %>"><%= direction %></option>
              <% end %>
            </select>
            <div class="input-group">
              <input type="text" class="form-control input-select connectionForm" name="rule[connection][]" id="flow_dst_server" size="14" style="height:28px;">
              <div class="input-group-btn">
                <select class="form-control input-select-include" data-toggle="dropdown" style="height:28px;"><span class="caret"></span></select>
                <ul class="dropdown-menu">
                  <% ['$HOME_NET', '$EXTERNAL_NET', '$DNS_SERVERS', '$SMTP_SERVERS', '$HTTP_SERVERS', '$SQL_SERVERS',
                      '$TELNET_SERVERS', '$SSH_SERVERS', '$FTP_SERVERS','$SIP_SERVERS', '$AIM_SERVERS'].each do |srcport| %>
                      <li><a class="select-sm flow_dst_server" href="#"><%= srcport %></a></li>
                  <% end %>
                </ul>
              </div>
            </div>
            <select class="form-control select-sm connectionForm" name="rule[connection][]">
              <% ['$HOME_NET', '$EXTERNAL_NET', '$DNS_SERVERS', '$SMTP_SERVERS', '$HTTP_SERVERS', '$SQL_SERVERS',
                  '$TELNET_SERVERS', '$SSH_SERVERS', '$FTP_SERVERS','$SIP_SERVERS', '$AIM_SERVERS'].each do |dstsrc| %>
                  <option value="<%= dstsrc %>"><%= dstsrc %></option>
              <% end %>
            </select>
            <input class="form-control select-sm dst-prt connectionForm" name="rule[connection][]" value="any">
          </div>
        </div>
      </div>
      <div class="col-xs-12">
        <div class="entry-type-switch">
          <div class="radio">
            <label>
              <input type="radio" class='scratch_connection' name="connectionForm" value="false">
              <span class="sr-only">Write Connection from scratch</span>
            </label>
          </div>
        </div>
        <div class="col-xs-10">
          <input type='text' class="form-control create-input select-sm code scratch_connection_text" name="rule[connection][]" placeholder="write connection from scratch" disabled>
        </div>
      </div>
    </div>
    <div class="form-group">
      <div class="col-xs-12">
        <h5>Flow</h5>
        <div class="entry-type-switch">
          <div class="radio">
            <label>
              <input type="radio" name="flowForm" class="flow" checked>
              <span class="sr-only">Select flow options</span>
            </label>
          </div>
        </div>
        <div class="col-xs-10 form-inline">
          <select class="form-control select-sm code flow_form" name="rule[flow][]" id="new-rule-flow">
            <% ['to_client', 'to_server'].each do |flow| %>
                <option value=<%= flow %>><%= flow %></option>
            <% end %>
          </select>
          <div class="checkbox left-space">
            <label>
              <input type="checkbox" name="rule[flow][]" class="flow_form" value="established" checked>
              established
            </label>
          </div>
        </div>
      </div>
      <div class="col-xs-12">
        <div class="entry-type-switch">
          <div class="radio">
            <label>
              <input type="radio" name="flowForm" class="scratch_flow" value="false">
              <span class="sr-only">Write flow from scratch</span>
            </label>
          </div>
        </div>
        <div class="col-xs-10">
          <input class="form-control create-input select-sm code scratch_flow_text" name="rule[flow][]" placeholder="write flow from scratch" disabled>
        </div>
      </div>
    </div>
    <div class="form-group">
      <div class="col-xs-12">
        <h5>Detection</h5>
        <div class="entry-type-switch">
        </div>
        <div class="col-xs-10">
          <textarea class="form-control create-input select-sm code" rows=10 name="rule[detection]" placeholder="enter detection" required="true"></textarea>
        </div>
      </div>
    </div>
    <div class="form-group">
      <div class="col-xs-12">
        <h5>Metadata</h5>
      </div>
      <div class="col-xs-12">
        <div class="entry-type-switch">
          <div class="radio">
            <label>
              <input type="radio" name="metadataForm" class='metadata' checked>
              <span class="sr-only">Select metadata options</span>
            </label>
          </div>
        </div>
        <div class="col-xs-10 form-inline">
          <label for="metadata-policy">Policy:&nbsp;&nbsp;</label>
          <select class="form-control select-sm code metadata_form" name="rule[metadata][]" id="new-rule-metadata-policy">
            <% ['security-ips', 'balanced-ips, security-ips','connectivity-ips, balanced-ips, security-ips'].each do |policy| %>
                <option value="<%= policy %>" <%= "selected" if policy == 'balanced-ips, security-ips' %>><%= policy %></option>
            <% end %>
          </select>
          &nbsp;
          <input type="checkbox" name="rule[metadata][]" class="metadata_form" value="max-detect">&nbsp;max-detect
          &nbsp;
          <select class="form-control select-sm code metadata_form" name="rule[metadata][]">
            <option value="drop" selected>drop</option>
            <option value="alert">alert</option>
          </select>
        </div>
      </div>
      <div class="col-xs-12">
        <div class="entry-type-switch"></div>
        <div class="col-xs-2 col-sm-1">
          <label for="metadata-services">Service:</label>
        </div>
        <div class="col-xs-8 col-sm-9">
          <% ['dns', 'ftp-data','http', 'imap', 'netbios-ssn', 'pop3', 'smtp'].each do |service| %>
              <input type="checkbox" name="rule[metadata][]" class="metadata_form" value=<%= service %> <%= "checked" if service == 'ftp-data' || service == 'http' || service == 'imap' || service == 'pop3' %>>&nbsp;<%= service %>&nbsp;&nbsp;
          <% end %>
        </div>
      </div>
      <div class="col-xs-12">
        <div class="entry-type-switch"></div>
        <div class="form-inline col-xs-10">
          <div class="form-group">
            <label for="metadata-flag">Impact Flag:&nbsp;&nbsp;</label>
            <select class="form-control select-sm code metadata_form" name="rule[metadata][]" id="new-rule-metadata-flag">
              <option value=""> -- </option>
              <option value="red">red</option>
            </select>
          </div>
          <div class="form-group">
            <label for="metadata-ruleset">Ruleset:&nbsp;&nbsp;</label>
            <select class="form-control select-sm code metadata_form" name="rule[metadata][]" id="new-rule-metadata-ruleset">
              <option value=""> -- </option>
              <option value="community">community</option>
            </select>
          </div>
        </div>
      </div>
      <div class="col-xs-12 top-space">
        <div class="entry-type-switch">
          <div class="radio">
            <label>
              <input type="radio" name="metadataForm" class="scratch_metadata" value="false">
              <span class="sr-only">Write metadata from scratch</span>
            </label>
          </div>
        </div>
        <div class="col-xs-10">
          <input type="text" class="form-control create-input select-sm code scratch_metadata_text" name="rule[metadata][]" placeholder="write metadata from scratch" disabled>
        </div>
      </div>
    </div>
    <div class="form-group">
      <div class="col-xs-12">
        <h5>ClassType</h5>
        <div class="entry-type-switch">
        </div>
        <div class="col-xs-10">
          <select class="form-control select-sm code" name="rule[class_type]" id="new-rule-classtype-form" required>
            <% ['attempted-user', 'attempted-admin', 'attempted-recon','policy-violation','shellcode-detect','trojan-activity','web-application-attack','misc-activity','bad-unknown'].each do |clas| %>
                <option value="<%= clas %>"><%= clas %></option>
            <% end %>
          </select>
        </div>
      </div>
    </div>
    <div class="form-group">
      <div class="col-xs-12 references_add">
        <h5>References&nbsp;&nbsp;<a class="top-space add-reference-btn blue"><i class="glyphicon glyphicon-plus"></i> add reference</a></h5>
        <% if @bug.references.any? %>
          <% @bug.references.each do |ref| %>
            <div class="col-xs-10"><div class="form-inline" style="padding:0 20px 10px 40px;">
              <div class="form-group">
                <input class="form-control select-sm code" name="rule[reference][][reference_type_id]" size=8 value="<%= ref.reference_type.name %>">
              </div>
              <div class="form-group">
                <input class="form-control select-sm code" name="rule[reference][][reference_data]" value="<%= ref.reference_data %>">
              </div>
              <div class="form-group"> <button class="btn select-sm btn-link remove-ref">remove</button> </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
    </div>
    <div class="form-group right">
      <div class="col-xs-12 center top-space">
        <button class="btn btn-warning save-rule-btn" type="submit" value="submit">Create Rule</button>
        &nbsp;&nbsp;<a class="btn btn-danger remove-rule">Discard</a>
      </div>
    </div>
  </form>
  </div>
</div>

<script>

  $(document).on('click', '.add-reference-btn', function() {
      var reference_form = '<div class="col-xs-10"><div class="form-inline" style="padding:0 20px 10px 40px;">'+
          '<div class="form-group">'+
          '<select type="text" name="rule[reference][][reference_type_id]" class="form-control select-sm code">'+
          '<option class="text-muted" value="" selected> - </option>'+
          '"<% @ref_types.each do |ref| %> <option value="<%= ref.name %>"><%= ref.name %></option><% end %>"'+
          '</select>'+
          '</div>'+
          '<div class="form-group">'+
          '<input class="form-control select-sm code" placeholder="reference data" name="rule[reference][][reference_data]" required="true">'+
          '</div>'+
          '<div class="form-group"> <button class="btn select-sm btn-link remove-ref">remove</button> </div>'+
          '</div></div>';
    var reference = $(this).parents('.references_add');
    $(reference_form).appendTo(reference);
  });

  $(document).on('click', '.remove-ref', function(e) {
    e.preventDefault();
    $(this).parents('.form-inline').remove();
  });

  $('#duplicate_rule').on("submit", function(e) {
    var data, form, headers, id;
    e.preventDefault();
    form = $(this).serializeArray();
    headers = {'Token': $('input[name="token"]').val(), 'Xmlrpc-Token': $('input[name="xml_token"]').val()};
    data = {api_key: 'h93hq@hwo9%@ah!jsh'};
    id = form[0].value;
    return $.ajax({
      url: "/api/v1/rules/" + id,
      method: 'GET',
      data: data,
      headers: headers,
      success: function(response) {
        if(response == null){
          alert('No rule id exists');
        }else{
          var reference, references, rule, standard_form;
          rule = response.rule;
          references = response.references;
          $('.legacy_form').find('textarea[name="rule[rule_content]"]').val(rule.rule_content);
          standard_form = $('.standard_form');
          standard_form.find('input[name="rule[message]"]').val(rule.message);
          standard_form.find('.scratch_connection, .scratch_flow, .scratch_metadata').trigger("click");
          standard_form.find('.scratch_connection_text').val(rule.connection);
          standard_form.find('textarea[name="rule[detection]"]').val(rule.detection);
          standard_form.find('.scratch_flow_text').val(rule.flow);
          standard_form.find('.scratch_metadata_text').val(rule.metadata);
          standard_form.find('select[name="rule[class_type]"]').val(rule.class_type);
          reference = standard_form.find('.references_add');
          $.each(references, function(i, v) {
            var ref_form = $(reference_form).appendTo(reference);
            ref_form.find('input[name="rule[reference][][reference_data]"]').val(v.reference_data);
            ref_form.find('select[name="rule[reference][][reference_type_id]"]').val(v.type);
          });
        }
      }
    });
  });

  $('.flow_src_ports, .flow_dst_server').on("click", function(e){
    e.preventDefault();
    var id = $(this).attr('class');
    id = id.substr(id.indexOf(' ')+1, id.length);
    $('#'+id).val($(this).text());
  });

</script>

<style>
  .input-select{
    height:28px;font-size:12px; border-right:0px;
    margin: 0;
    padding: 5px 10px;
  }
  .input-select-include{
    height:28px;font-size:12px;
    top: 0;
    bottom: 0;
    margin-left: -2px;
    padding: 0;
  }

    .dropdown-menu{
      font-size: 12px;
    }
    .dropdown-menu > li > a{
      padding: 3px 2px 2px 6px;
    }
</style>