<div class='row item-info'>
  <div class='col-lg-10 col-sm-11'>
    <div class="row">
      <div class="col-xs-12">
        <h2 class="subtitle">Search for Users</h2>
        <p>Use this form to find users.</p>
      </div>
    </div>
    <div class="row">
      <div class="col-xs-12">
        <div class="spacer"></div>

        <%= form_for :user_search, url: user_searches_path do |form| %>
          <div class="row">
            <div class="col-sm-12 form-group">
              <%= form.label :name %>
              <%= form.text_field :name, class: "form-control create-input", required: true %>
            </div>
          </div>
          <div class="row">
            <div class="col-sm-12 form-group">
              <%= form.submit "Search", class: "btn btn-success" %>
            </div>
          </div>
          <div class="spacer"></div>
        <% end %>

      </div>
    </div>
  </div>
</div>
