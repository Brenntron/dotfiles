= simple_form_for user do |f|

  - if current_user.has_role?('admin')
    -# Add the user form stuff here
    .row
      .col-sm-4
        .form-group
          %label.content-label-sm{for: "user_#{user.id}_cvs"} Talos Username (CVS)
          %input.form-control{type: 'text', name: 'user[cvs_username]', id: "user_#{user.id}_cvs", value: "#{user.cvs_username}"}

      .col-sm-4
        .form-group
          %label.content-label-sm{for: "user_#{user.id}_cec"} Cisco Username (CEC)
          %input.form-control{type: 'text', name: 'user[cec_username]', id: "user_#{user.id}_cec", value: "#{user.cec_username}"}

      .col-sm-4
        .form-group
          %label.content-label-sm{for: "user_#{user.id}_kerberos"} Kerberos Login
          %input.form-control{type: 'text', name: 'user[kerberos_login]', id: "user_#{user.id}_kerberos", value: "#{user.kerberos_login}"}

    .row
      .col-sm-4
        .form-group
          %label.content-label-sm{for: "user_#{user.id}_name"} Display Name
          %input.form-control{type: 'text', name: 'user[display_name]', id: "user_#{user.id}_name", value: "#{user.display_name}"}

      .col-sm-4
        .form-group
          %label.content-label-sm{for: "user_#{user.id}_email"} Email
          %input.form-control{type: 'email', name: 'user[email]', id: "user_#{user.id}_email", value: "#{user.email}"}

      .col-sm-4.form-group
  -#    spacer


  - if current_user == user || current_user.has_role?('admin')
    %hr.thin.extra-bottom-marg
    .row
      .col-sm-12
        .form-group
          %a.regenerate-key.secondary.esc-tooltipped{onclick: "generate_user_api_key(#{user.id}, '#{user.kerberos_login}')", title: 'Generate API Key'}
          %label.content-label-sm{for: "user_#{user.id}_api"} Analyst Console User API Key
          %input.form-control.code{type: 'text', name: 'user[user_api_key][api_key]', id: "user_#{user.id}_api", value: "#{user.user_api_key&.api_key}"}

    .row
      .col-sm-6
        .form-group
          %label.content-label-sm{for: "user_#{user.id}_tg_api"} Threatgrid API Key
          %input.form-control.code{type: 'text', name: 'user[threatgrid_api_key]', id: "user_#{user.id}_tg_api", value: "#{user.threatgrid_api_key}"}

      .col-sm-6
        .form-group
          %label.content-label-sm{for: "user_#{user.id}_sb_api"} Sandbox API Key
          %input.form-control.code{type: 'text', name: 'user[sandbox_api_key]', id: "user_#{user.id}_sb_api", value: "#{user.sandbox_api_key}"}
    %hr.thin


  .row
    .col-xs-12
      .multi-col
        %ul.role-list
          = f.collection_check_boxes(:role_ids, role_options_for(current_user), :id, :role) do |r|
            %li
              = r.label(for: "user_#{user.id}_role_#{r.value}") { r.check_box(id: "user_#{user.id}_role_#{r.value}") + ' ' + r.text }

  - if current_user.has_role?('admin')
    .row
      .col-xs-12
        =link_to admin_roles_path do
          .secondary.edit-roles-button Edit User Roles (admin)

  %hr.thin
  .row
    .col-xs-12.text-center
      %button.primary{name: 'submit', 'aria-label': 'Save Roles', onlick: 'update_user()'} Save
      %button.secondary{'data-dismiss': 'modal', 'aria-label': 'Cancel'} Cancel
