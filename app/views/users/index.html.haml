.content-wrapper.team-index
  %h1.index-table-header Related Users
  .users-flash-wrapper.team-flash-wrapper
    = render partial: 'users_flash_messages', flash: flash

  %table.table.responsive.index-table
    %thead
      %tr
        %th
        -# User group
        %th Name
        %th Username
        %th Direct Reports
        %th Total Reports
        %th Roles
        %th
        -# Edit / Delete Row
    %tbody
      - if @user.parent.present?
        %tr.manager
          %td.user-group Manager
          %td.alt-col.user-col-divider.user-displayname-col= @user.parent.display_name
          %td.alt-col.user-col-divider.user-name-col.current-user= link_to @user.parent.cvs_username, escalations_user_path(@user.parent)
          %td.alt-col.user-col-divider=@user.parent.children.length
          %td.alt-col=@user.parent.descendants.length
          %td.data_small_emphasis= @user.parent.roles.map(&:role).join(', ')
          - if current_user.has_role?('admin') || current_user.has_role?('super admin')
            %td.text-right.table-button-row
              %button.edit-button.table-row-button.tooltipped{title: "Edit #{@user.parent.cvs_username}'s roles", 'data-toggle': 'modal', 'data-target': "#roleModal_#{@user.parent.id}"}
              %span.dropdown
                %button.add-user-button.table-row-button.tooltipped{title: "Add user to #{@user.parent.display_name}'s team'", id: "add_user_button_#{@user.parent.id}", 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
                .dropdown-menu{id: "add_user_dropdown_#{@user.parent.id}", 'aria-labelledby': "add_user_button_#{@user.parent.id}"}
                  .user-select-wrapper
                    %h3
                      Add members to
                      = @user.parent.display_name
                      \'s team
                    .inline-tool-content-wrapper
                      =form_tag escalations_user_add_to_team_path(@user.parent), method: :patch do
                        .toolbar
                          %div.select-wrapper
                            %label.toolbar-section-label{for: 'users-selection'} Users
                            = select_tag "users_for_#{@user.id}", options_for_select(nested_set_options(@user.parent.available_users.sort_by(&:display_name)) {|i| "#{'-' * i.level} #{i.display_name} (#{i.cvs_username})"} ), {prompt: "Choose Team Member", class: "toolbar-select select-team-members", name: 'child_id'}
                          = hidden_field_tag "manager_id_#{@user.parent.id}", @user.id
                        .button-row-center
                          %button.primary.dropdown-submit-button{type: 'submit'} Add User

            .modal.fade.user-form-modal{id: "roleModal_#{@user.parent.id}", tabindex: '-1', role: 'dialog', 'aria-hidden': 'true'}
              .modal-dialog{role: 'document'}
                .modal-content
                  .modal-header
                    %button.close{type: 'button', 'data-dismiss': 'modal', 'aria-label': 'Close'}
                    %h3.modal-title
                      Edit User
                      = @user.parent.cvs_username.capitalize
                  .modal-body
                    =render 'edit_user_form', user: @user.parent

          - else
            %td

      - if @user.has_role?('manager')
        - team_total = @user.descendants.length + @user.siblings.length + 1
        %tr.self
          %td#team-cell.user-group{rowspan: "#{team_total}", 'data-rowspan': "#{team_total}"} Team
          %td.alt-col.user-col-divider.user-displayname-col= @user.display_name
          %td.alt-col.user-col-divider.user-name-col.current-user= link_to @user.cvs_username, escalations_user_path(@user)
          %td.alt-col.user-col-divider=@user.children.length
          %td.alt-col=@user.descendants.length
          %td.data_small_emphasis=@user.roles.map(&:role).join(', ')
          %td.text-right.table-button-row
            %button.edit-button.table-row-button.tooltipped{title: "Edit #{@user.cvs_username}'s roles", 'data-toggle': 'modal', 'data-target': "#roleModal_#{@user.id}"}
            %span.dropdown
              %button.add-user-button.table-row-button.tooltipped{title: "Add user to #{@user.display_name}'s team'", id: "add_user_button_#{@user.id}", 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
              .dropdown-menu{id: "add_user_dropdown_#{@user.id}", 'aria-labelledby': "add_user_button_#{@user.id}"}
                .user-select-wrapper
                  %h3
                    Add members to
                    = @user.display_name
                    \'s team
                  .inline-tool-content-wrapper
                    =form_tag escalations_user_add_to_team_path(@user), method: :patch do
                      .toolbar
                        %div.select-wrapper
                          %label.toolbar-section-label{for: 'users-selection'} Users
                          = select_tag "users_for_#{@user.id}", options_for_select(nested_set_options(@user.available_users.sort_by(&:display_name)) {|i| "#{'-' * i.level} #{i.display_name} (#{i.cvs_username})"} ), {prompt: "Choose Team Member", class: "toolbar-select select-team-members", name: 'child_id'}
                        = hidden_field_tag "manager_id_#{@user.id}", @user.id
                      .button-row-center
                        %button.primary.dropdown-submit-button{type: 'submit'} Add User

        - @user.children.each do |user|
          - if @user.has_role?('manager')
            %tr.first-child
              - if user.children.length > 0
                %td.alt-col.user-col-divider.user-displayname-col.manager-row-indicator
                  %span= user.display_name
                  %button.expand-manager-row-button.up{'data-user-manager': "#{user.id}"}
                %td.alt-col.user-col-divider.user-name-col= link_to user.cvs_username, escalations_user_path(user)
                %td.alt-col.user-col-divider=user.children.length
                %td.alt-col=user.descendants.length
                %td.data_small_emphasis=user.roles.map(&:role).join(', ')
                %td.text-right.table-button-row
                  %button.edit-button.table-row-button.tooltipped{title: "Edit #{user.cvs_username}'s roles", 'data-toggle': 'modal', 'data-target': "#roleModal_#{user.id}"}
                  = link_to escalations_user_remove_from_team_path(user_id: user.id), method: :patch, data: {confirm: "Remove #{user.display_name} from team?"} do
                    %button.remove-button.table-row-button.tooltipped{title: "Remove #{user.cvs_username} from this team"}
                  - if user.has_role?('manager')
                    %span.dropdown
                      %button.add-user-button.table-row-button.tooltipped{title: "Add user to #{user.display_name}'s team'", id: "add_user_button_#{user.id}", 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
                      .dropdown-menu{id: "add_user_dropdown_#{user.id}", 'aria-labelledby': "add_user_button_#{user.id}"}
                        .user-select-wrapper
                          %h3
                            Add members to
                            = user.display_name
                            \'s team
                          .inline-tool-content-wrapper
                            =form_tag escalations_user_add_to_team_path(user), method: :patch do
                              .toolbar
                                %div.select-wrapper
                                  %label.toolbar-section-label{for: 'users-selection'} Users
                                  = select_tag "users_for_#{user.id}", options_for_select(nested_set_options(user.available_users.sort_by(&:display_name)) {|i| "#{'-' * i.level} #{i.display_name} (#{i.cvs_username})"} ), {prompt: "Choose Team Member", class: "toolbar-select select-team-members", name: 'child_id'}
                                = hidden_field_tag "manager_id_#{user.id}", user.id
                              .button-row-center
                                %button.primary.dropdown-submit-button{type: 'submit'} Add User
              - else
                %td.alt-col.user-col-divider.user-displayname-col= user.display_name
                %td.alt-col.user-col-divider.user-name-col= link_to user.cvs_username, escalations_user_path(user)
                %td.alt-col.user-col-divider=user.children.length
                %td.alt-col=user.descendants.length
                %td.data_small_emphasis=user.roles.map(&:role).join(', ')
                %td.text-right.table-button-row
                  %button.edit-button.table-row-button.tooltipped{title: "Edit #{user.cvs_username}'s roles", 'data-toggle': 'modal', 'data-target': "#roleModal_#{user.id}"}
                  = link_to escalations_user_remove_from_team_path(user_id: user.id), method: :patch, data: {confirm: "Remove #{user.display_name} from team?"} do
                    %button.remove-button.table-row-button.tooltipped{title: "Remove #{user.cvs_username} from this team"}
                  - if user.has_role?('manager')
                    %span.dropdown
                      %button.add-user-button.table-row-button.tooltipped{title: "Add user to #{user.display_name}'s team'", id: "add_user_button_#{user.id}", 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
                      .dropdown-menu{id: "add_user_dropdown_#{user.id}", 'aria-labelledby': "add_user_button_#{user.id}"}
                        .user-select-wrapper
                          %h3
                            Add members to
                            = user.display_name
                            \'s team
                          .inline-tool-content-wrapper
                            =form_tag escalations_user_add_to_team_path(user), method: :patch do
                              .toolbar
                                %div.select-wrapper
                                  %label.toolbar-section-label{for: 'users-selection'} Users
                                  = select_tag "users_for_#{user.id}", options_for_select(nested_set_options(user.available_users.sort_by(&:display_name)) {|i| "#{'-' * i.level} #{i.display_name} (#{i.cvs_username})"} ), {prompt: "Choose Team Member", class: "toolbar-select select-team-members", name: 'child_id'}
                                = hidden_field_tag "manager_id_#{user.id}", user.id
                              .button-row-center
                                %button.primary.dropdown-submit-button{type: 'submit'} Add User


            - user.children.each do |child|
              - if child.has_role?('manager')
                - if child.children.length > 0
                  %tr.second-child.manage-child-row{'data-user-child': "#{user.id}", 'data-whatever': 'at least one child'}
                    %td.alt-col.lighter-alt-col.user-col-divider.user-displayname-col.manager-row-indicator
                      %span= child.display_name
                      %button.expand-manager-row-button.up{'data-user-manager': "#{child.id}"}
                    %td.alt-col.user-col-divider.user-name-col.lighter-alt-col= link_to child.cvs_username, escalations_user_path(child)
                    %td.alt-col.user-col-divider.lighter-alt-col=child.children.length
                    %td.alt-col.lighter-alt-col=child.descendants.length
                    %td.data_small_emphasis=child.roles.map(&:role).join(', ')
                    %td.text-right.table-button-row
                      %button.edit-button.table-row-button.tooltipped{title: "Edit #{child.cvs_username}'s roles", 'data-toggle': 'modal', 'data-target': "#roleModal_#{child.id}"}
                      = link_to escalations_user_remove_from_team_path(user_id: child.id), method: :patch, data: {confirm: "Remove #{child.display_name} from team?"} do
                        %button.remove-button.table-row-button.tooltipped{title: "Remove #{child.cvs_username} from this team"}
                      - if child.has_role?('manager')
                        %span.dropdown
                          %button.add-user-button.table-row-button.tooltipped{title: "Add user to #{child.display_name}'s team'", id: "add_user_button_#{child.id}", 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
                          .dropdown-menu{id: "add_user_dropdown_#{child.id}", 'aria-labelledby': "add_user_button_#{child.id}"}
                            .user-select-wrapper
                              %h3
                                Add members to
                                = child.display_name
                                \'s team
                              .inline-tool-content-wrapper
                                =form_tag escalations_user_add_to_team_path(child), method: :patch do
                                  .toolbar
                                    %div.select-wrapper
                                      %label.toolbar-section-label{for: 'users-selection'} Users
                                      = select_tag "users_for_#{child.id}", options_for_select(nested_set_options(child.available_users.sort_by(&:display_name)) {|i| "#{'-' * i.level} #{i.display_name} (#{i.cvs_username})"} ), {prompt: "Choose Team Member", class: "toolbar-select select-team-members", name: 'child_id'}
                                    = hidden_field_tag "manager_id_#{child.id}", child.id
                                  .button-row-center
                                    %button.primary.dropdown-submit-button{type: 'submit'} Add User

                  - child.children.each do |grandchild|
                    %tr.third-child.manage-child-row.manage-grandchild-row{'data-user-child': "#{user.id} #{child.id}"}
                      %td.alt-col.user-col-divider.user-displayname-col.lighter-alt-col= grandchild.display_name
                      %td.alt-col.user-col-divider.user-name-col.lighter-alt-col= link_to grandchild.cvs_username, escalations_user_path(grandchild)
                      %td.alt-col.user-col-divider.lighter-alt-col=grandchild.children.length
                      %td.alt-col.lighter-alt-col=grandchild.descendants.length
                      %td.data_small_emphasis=grandchild.roles.map(&:role).join(', ')
                      %td.text-right.table-button-row
                        %button.edit-button.table-row-button.tooltipped{title: "Edit #{grandchild.cvs_username}'s roles", 'data-toggle': 'modal', 'data-target': "#roleModal_#{grandchild.id}"}
                        = link_to escalations_user_remove_from_team_path(user_id: grandchild.id), method: :patch, data: {confirm: "Remove #{grandchild.display_name} from team?"} do
                          %button.remove-button.table-row-button.tooltipped{title: "Remove #{grandchild.cvs_username} from this team"}
                - else
                  %tr.manage-child-row{'data-user-child': "#{user.id}", 'data-whatever': 'no children yet'}
                    %td.alt-col.user-col-divider.user-displayname-col.lighter-alt-col= child.display_name
                    %td.alt-col.user-col-divider.user-name-col.lighter-alt-col= link_to child.cvs_username, escalations_user_path(child)
                    %td.alt-col.user-col-divider.lighter-alt-col=child.children.length
                    %td.alt-col.lighter-alt-col=child.descendants.length
                    %td.data_small_emphasis=child.roles.map(&:role).join(', ')
                    %td.text-right.table-button-row
                      %button.edit-button.table-row-button.tooltipped{title: "Edit #{child.cvs_username}'s roles", 'data-toggle': 'modal', 'data-target': "#roleModal_#{child.id}"}
                      = link_to escalations_user_remove_from_team_path(user_id: child.id), method: :patch, data: {confirm: "Remove #{child.display_name} from team?"} do
                        %button.remove-button.table-row-button.tooltipped{title: "Remove #{child.cvs_username} from this team"}
                      - if child.has_role?('manager')
                        %span.dropdown
                          %button.add-user-button.table-row-button.tooltipped{title: "Add user to #{child.display_name}'s team'", id: "add_user_button_#{child.id}", 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
                          .dropdown-menu{id: "add_user_dropdown_#{child.id}", 'aria-labelledby': "add_user_button_#{child.id}"}
                            .user-select-wrapper
                              %h3
                                Add members to
                                = child.display_name
                                \'s team
                              .inline-tool-content-wrapper
                                =form_tag escalations_user_add_to_team_path(child), method: :patch do
                                  .toolbar
                                    %div.select-wrapper
                                      %label.toolbar-section-label{for: 'users-selection'} Users
                                      = select_tag "users_for_#{child.id}", options_for_select(nested_set_options(child.available_users.sort_by(&:display_name)) {|i| "#{'-' * i.level} #{i.display_name} (#{i.cvs_username})"} ), {prompt: "Choose Team Member", class: "toolbar-select select-team-members", name: 'child_id'}
                                    = hidden_field_tag "manager_id_#{child.id}", child.id
                                  .button-row-center
                                    %button.primary.dropdown-submit-button{type: 'submit'} Add User

              - else
                %tr.second-child.manage-child-row{'data-user-child': "#{user.id}"}
                  %td.alt-col.user-col-divider.user-displayname-col.lighter-alt-col= child.display_name
                  %td.alt-col.user-col-divider.user-name-col.lighter-alt-col= link_to child.cvs_username, escalations_user_path(child)
                  %td.alt-col.user-col-divider.lighter-alt-col=child.children.length
                  %td.alt-col.lighter-alt-col=child.descendants.length
                  %td.data_small_emphasis=child.roles.map(&:role).join(', ')
                  %td.text-right.table-button-row
                    %button.edit-button.table-row-button.tooltipped{title: "Edit #{child.cvs_username}'s roles", 'data-toggle': 'modal', 'data-target': "#roleModal_#{child.id}"}
                    = link_to escalations_user_remove_from_team_path(user_id: child.id), method: :patch, data: {confirm: "Remove #{child.display_name} from team?"} do
                      %button.remove-button.table-row-button.tooltipped{title: "Remove #{child.cvs_username} from this team"}

              .modal.fade.user-form-modal{id: "roleModal_#{child.id}", tabindex: '-1', role: 'dialog', 'aria-hidden': 'true'}
                .modal-dialog{role: 'document'}
                  .modal-content
                    .modal-header
                      %button.close{type: 'button', 'data-dismiss': 'modal', 'aria-label': 'Close'}
                      %h3.modal-title
                        Edit User
                        = child.cvs_username.capitalize
                    .modal-body
                      =render 'edit_user_form', user: child

          - else
            %tr.first-child
              %td.alt-col.user-col-divider.user-displayname-col= user.display_name
              %td.alt-col.user-col-divider.user-name-col= link_to user.cvs_username, escalations_user_path(user)
              %td.alt-col.user-col-divider=user.children.length
              %td.alt-col=user.descendants.length
              %td.data_small_emphasis=user.roles.map(&:role).join(', ')
              %td.text-right.table-button-row
                %button.edit-button.table-row-button.tooltipped{title: "Edit #{user.cvs_username}'s roles", 'data-toggle': 'modal', 'data-target': "#roleModal_#{user.id}"}
                = link_to escalations_user_remove_from_team_path(user_id: user.id), method: :patch, data: {confirm: "Remove #{user.display_name} from team?"} do
                  %button.remove-button.table-row-button.tooltipped{title: "Remove #{user.cvs_username} from this team"}


          .modal.fade.user-form-modal{id: "roleModal_#{user.id}", tabindex: '-1', role: 'dialog', 'aria-hidden': 'true'}
            .modal-dialog{role: 'document'}
              .modal-content
                .modal-header
                  %button.close{type: 'button', 'data-dismiss': 'modal', 'aria-label': 'Close'}
                  %h3.modal-title
                    Edit User
                    = user.cvs_username.capitalize
                .modal-body
                  =render 'edit_user_form', user: user

      - else
        %tr.self
          %td.user-group
          %td.alt-col.user-col-divider.user-displayname-col= @user.display_name
          %td.alt-col.user-col-divider.user-name-col.current-user= link_to @user.cvs_username, escalations_user_path(@user)
          %td.alt-col.user-col-divider=@user.children.length
          %td.alt-col=@user.descendants.length
          %td.data_small_emphasis=@user.roles.map(&:role).join(', ')
          %td

      - if @user.child?
        - @user.siblings.each_with_index do |user, index|
          %tr.peer
            %td.alt-col.user-col-divider.user-displayname-col= user.display_name
            %td.alt-col.user-col-divider.user-name-col= link_to user.cvs_username, escalations_user_path(user)
            %td.alt-col.user-col-divider=user.children.length
            %td.alt-col=user.descendants.length
            %td.data_small_emphasis= user.roles.map(&:role).join(', ')
            - if @user.has_role?('admin')
              %td.text-right.table-button-row
                %button.edit-button.table-row-button.tooltipped{title: "Edit #{user.cvs_username}'s roles", 'data-toggle': 'modal', 'data-target': "#roleModal_#{user.id}"}
                = link_to escalations_user_remove_from_team_path(user_id: user.id), method: :patch, data: {confirm: "Remove #{user.display_name} from team?"} do
                  %button.remove-button.table-row-button.tooltipped{title: "Remove #{user.cvs_username} from this team"}
                - if user.has_role?('manager')
                  %span.dropdown
                    %button.add-user-button.table-row-button.tooltipped{title: "Add user to #{user.display_name}'s team'", id: "add_user_button_#{user.id}", 'data-toggle': 'dropdown', 'aria-haspopup': 'true', 'aria-expanded': 'false'}
                    .dropdown-menu{id: "add_user_dropdown_#{user.id}", 'aria-labelledby': "add_user_button_#{user.id}"}
                      .user-select-wrapper
                        %h3
                          Add members to
                          = user.display_name
                          \'s team
                        .inline-tool-content-wrapper
                          =form_tag escalations_user_add_to_team_path(user), method: :patch do
                            .toolbar
                              %div.select-wrapper
                                %label.toolbar-section-label{for: 'users-selection'} Users
                                = select_tag "users_for_#{user.id}", options_for_select(nested_set_options(user.available_users.sort_by(&:display_name)){|i| "#{'-' * i.level} #{i.display_name} (#{i.cvs_username})"} ), {prompt: "Choose Team Member", class: "toolbar-select select-team-members", name: 'child_id'}
                              = hidden_field_tag "manager_id_#{user.id}", user.id
                            .button-row-center
                              %button.primary.dropdown-submit-button{type: 'submit'} Add User

              .modal.fade.user-form-modal{id: "roleModal_#{user.id}", tabindex: '-1', role: 'dialog', 'aria-hidden': 'true'}
                .modal-dialog{role: 'document'}
                  .modal-content
                    .modal-header
                      %button.close{type: 'button', 'data-dismiss': 'modal', 'aria-label': 'Close'}
                      %h3.modal-title
                        Edit User
                        = user.cvs_username.capitalize
                    .modal-body
                      =render 'edit_user_form', user: user
            - else
              %td

  .modal.fade.user-form-modal{id: "roleModal_#{@user.id}", tabindex: '-1', role: 'dialog', 'aria-hidden': 'true'}
    .modal-dialog{role: 'document'}
      .modal-content
        .modal-header
          %button.close{type: 'button', 'data-dismiss': 'modal', 'aria-label': 'Close'}
          %h3.modal-title
            Edit User
            = @user.cvs_username.capitalize
        .modal-body
          =render 'edit_user_form', user: @user

:javascript
  window.setupSelectBoxes()
