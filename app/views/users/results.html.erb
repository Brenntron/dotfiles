<table class="table index-table">
  <thead>
  <tr>
    <th>Name</th>
    <th>email</th>
    <th>CVS Username</th>
    <th>CEC Username</th>
    <th>Kerberos login</th>
  </tr>
  </thead>
  <tbody>
  <% @users.each do |user| %>
    <tr>
      <% if current_user.has_role?('admin') %>
        <td><%= link_to user.display_name, user_path(user) %></td>
      <% else %>
        <td><%= user.display_name %></td>
      <% end %>
      <td><%= user.email %></td>
      <td><%= user.cvs_username %></td>
      <td><%= user.cec_username %></td>
      <td><%= user.kerberos_login %></td>
    </tr>
  <% end %>
  </tbody>
</table>
