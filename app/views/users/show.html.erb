<div class='row item-info'>
  <div class="row subheading">
    <button class="btn back_btn_user pull-right">
      <i class="glyphicon glyphicon-th-list"></i> <strong class="hidden-xs">user list</strong>
    </button>
  </div>
  <div class='col-lg-11 col-md-11'>
    <div class="row">
      <div class="col-xs-12 col-sm-4">
        <h2 class="subtitle"><%= @user.cvs_username %>&nbsp;&nbsp;
          <span class="email-link">
            <% if @user.ancestors.include?(current_user) || current_user.has_role?('admin') %>
              <span data-toggle="modal" data-target='<%= "#roleModal_#{@user.id}" %>'>
                <a type="button" class="glyphicon glyphicon-pencil" data-toggle="tooltip" data-placement="top" title="edit roles"></a>
              </span>
            <% end %>
            <a href="mailto:<%= @user.email %>" data-toggle="tooltip" data-placement="top" title="send mail"><i class="glyphicon glyphicon-envelope"></i></a>
            <% if @user == current_user %>
              <a type="button" class="glyphicon glyphicon-cloud-download" id="user-bugs" value="<%=@user.id%>" data-toggle="tooltip" data-placement="top" title="import <%=@user.cvs_username%>'s bugs from bugzilla"></a>
              <button class="select-sm btn btn-default hidden" id="importing_image"><span class="glyphicon glyphicon-refresh glyphicon-refresh-animate"></span> coffee break</button>
            <% end %>
          </span>
        </h2>
        <p class="text-muted"><em><strong><%=@user.roles.map(&:role).join(', ')%></strong></em></p>
      </div>
    </div>
    <div class='row top-space'>
      <div class="col-xs-11">
        <% if @user == current_user %>
          <div class="col-xs-12">
            <h4>Team</h4>
          </div>
          <div class="col-xs-6 col-sm-4">
            <h6 class="text-muted">managers</h6>
            <% if @user.parent.present? %>
              <ul class="compact-list">
                <li><%= link_to @user.parent.cvs_username, user_path(@user.parent) %></li>
              </ul>
            <% else %>
              <p class="text-muted small"><em><strong><%= @user.cvs_username %></strong> answers to no one!</em></p>
            <% end %>
          </div>
          <div class="col-xs-6 col-sm-4">
            <h6 class="text-muted">team</h6>
            <% if @user.children.any? %>
              <ul class="compact-list">
                <% @user.children.each do |member| %>
                <li><%= link_to member.cvs_username, user_path(member) %></li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-muted small"><em><strong><%= @user.cvs_username %></strong> is a lone wolf!</em></p>
            <% end %>
          </div>
          <div class="col-xs-6 col-sm-4">
            <h6 class="text-muted">co-workers</h6>
            <% if @user.siblings.any?  && @user.child? %>
                <ul class="compact-list">
                  <% @user.siblings.each do |co| %>
                      <li><%= link_to co.cvs_username, user_path(co) %></li>
                  <% end %>
                </ul>
            <% else %>
                <p class="text-muted small"><em><strong><%= @user.cvs_username %></strong> works alone!</em></p>
            <% end %>
          </div>
        <%end%>
        </div>
      </div>
    <div class="row">
      <div class="col-xs-11"><hr/></div>
      <div class='col-xs-12'>
        <div class='col-xs-11'>
          <h4>Assignments</h4>
        </div>
      </div>
      <div class='col-sm-11'>
        <ul class="nav nav-tabs" role="tablist">
          <li role="presentation" class="user-tab active" id="open-tab"><a href="#open" aria-controls="open" role="tab" data-toggle="tab">open (<%= @user.bugs.open_bugs.count %>)</a></li>
          <li role="presentation" class="user-tab" id="pending-tab"><a href="#pending" aria-controls="pending" role="tab" data-toggle="tab">pending (<%= @user.bugs.pending.count %>)</a></li>
          <li role="presentation" class="user-tab" id="closed-tab"><a href="#closed" aria-controls="closed" role="tab" data-toggle="tab">closed (<%= @user.bugs.closed.count %>)</a></li>
        </ul>
        <div class="tab-content">
          <div role="tabpanel" class="tab-pane active" id="open">
            <table class="table table-hover table-borderless">
              <% if @user.bugs.open_bugs.any? %>
                <% @user.bugs.open_bugs.sort_by{ |b| b.priority_sort }.each do |bug| %>
                  <tr>
                    <td>
                      <p><strong><%=bug.priority%></strong></p>
                    </td>
                    <td>
                      <p><strong><%= link_to bug.bugzilla_id, bug_path(bug) %></strong></p>
                    </td>
                    <td>
                      <p><%= bug.summary %>
                      <button class="btn btn-default tiny-button text-muted return-bug" data-id="<%=bug.id%>">return</button>
                      </p>
                    </td>
                  </tr>

                <% end %>
              <% else %>
                <div class="col-xs-12">
                  <p class="text-muted"><em>No open bugs at this time.</em></p>
                </div>
              <% end %>
            </table>
          </div>
          <div role="tabpanel" class="tab-pane" id="pending">
            <table class="table table-hover table-borderless">
              <% if @user.bugs.pending.any? %>
                <% @user.bugs.pending.each do |bug| %>
                  <tr>
                    <td>
                      <strong><%= link_to bug.bugzilla_id, bug_path(bug) %></strong>
                    </td>
                    <td>
                      <%= bug.summary %>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <div class="col-xs-12">
                  <p class="text-muted"><em>No pending bugs at this time.</em></p>
                </div>
              <% end %>
            </table>
          </div>
          <div role="tabpanel" class="tab-pane" id="closed">
            <table class="table table-hover table-borderless">
              <% if @user.bugs.closed.any? %>
                <% @user.bugs.closed.each do |bug| %>
                  <tr>
                    <td>
                      <strong><%= link_to bug.bugzilla_id, bug_path(bug) %></strong>
                    </td>
                    <td>
                      <%= bug.summary %>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <div class="col-xs-12">
                  <p class="text-muted"><em>No closed bugs at this time.</em></p>
                </div>
              <% end %>
            </table>
          </div>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-xs-11"><hr/></div>
      <div class='col-xs-12'>
        <div class='col-xs-11'>
          <h4>Metrics</h4>
          <div id="msg"></div>
        </div>
      </div>
      <div class="col-lg-5 col-md-6">
        <div class="user-metrics" id='<%=@user.id%>'></div>
        <p>Bug status changes last <%=current_user.chart_timeframe_preference%> days <a href="#" class="tiny text-muted change_metrics_timeframe"><em>change</em></a></p>
        <%= render 'shared/change_metrics_timeframe_form' %>
        <canvas id="statusChart"></canvas>
      </div>
      <div class="col-lg-5 col-md-6">
        <p>Work Time Averages</p>
        <canvas id="timeChart"></canvas>
        <br>
        <div class="col-xs-12">
          <p class="text-muted small"><em>* Averages rounded to the nearest whole number.</em></p>
        </div>
      </div>

    </div>
    <div class="footer-spacer"></div>

  </div>
</div>
<div class="spacer"></div>
<input type="hidden" name="token" value="<%= current_user.authentication_token %>">
<input type="hidden" name="xml_token" value="<%= xml_token %>">
<input type="hidden" name="current_user" value="<%= current_user.id%>">


<div class="modal fade" id= '<%= "roleModal_#{@user.id}" %>' tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidde="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
        <h4 class="modal-title" id="myModalLabel">Update Role(s) for <%=@user.cvs_username%></h4>
      </div>
      <div class="modal-body">
        <%=render 'shared/role_form', user: @user %>
      </div>
    </div>
  </div>
</div>