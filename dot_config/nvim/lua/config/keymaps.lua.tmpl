-- Sidekick NES (Next Edit Suggestion)
map({ "i", "n" }, "<tab>", function()
  if require("sidekick").nes_jump_or_apply() then
    return
  end
  if vim.lsp.inline_completion.get() then
    return
  end
  return "<tab>"
end, { expr = true, desc = "Goto/Apply Next Edit Suggestion" })

