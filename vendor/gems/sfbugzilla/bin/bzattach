#!/usr/bin/env ruby

require 'sfbugzilla'

me = File.basename($0)

abort "Usage: #{me} <bugid> <file1> <file2> ..." if ARGV.size < 2

bid = ARGV.shift

xmlrpc = Bugzilla::XMLRPC.new(BUGZILLA_HOST)
xmlrpc.login(Bugzilla::User.new(xmlrpc))
bug = Bugzilla::Bug.new(xmlrpc)

ARGV.each do |file|
	if bug.attach_file(bid, file)
		puts "#{file} attached to bug #{bid}"
	end
end
