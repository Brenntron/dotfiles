#!/usr/bin/env ruby

require 'sfbugzilla'

# Check for the required environment variables
checks = {
   'export BUGZILLA_HOST=bugzilla.vrt.sourcefire.com' => (ENV['BUGZILLA_HOST'] == nil ? 1 : 0),
   'export BUGZILLA_USER=cisco_user # Without the domain' => (ENV['BUGZILLA_USER'] == nil ? 1 : 0),
   'export BUGZILLA_DIR=$HOME/bugs # Where you store your bug directories' => (ENV['BUGZILLA_DIR'] == nil ? 1 : 0),
}

# See if any failed
checks.delete_if {|k,v| v == 0}

# Print any that failed
if checks.size > 0
   puts "Add the following lines to your ~/.bash_profile:"
   checks.each {|k,v| puts k}
   puts
   puts "Reload your environment and run #{File.basename($0)} again."
end

puts "Testing your bugzilla session status."

xmlrpc = Bugzilla::XMLRPC.new(BUGZILLA_HOST)
xmlrpc.login(Bugzilla::User.new(xmlrpc))
bz = Bugzilla::Bug.new(xmlrpc)
