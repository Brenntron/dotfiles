#!/usr/bin/env ruby

require 'sfbugzilla'

# If you are using McBee's environment and want Clam to Snort bug symlinking
# upon duplication, set this to true.
MCBEE_ENV = true

me = File.basename($0)
abort "Usage: #{me} <bugid>" if ARGV.size == 0

xmlrpc = Bugzilla::XMLRPC.new(BUGZILLA_HOST)
xmlrpc.login(Bugzilla::User.new(xmlrpc))
bugs = Bugzilla::Bug.new(xmlrpc)

bid = ARGV[0] # Bug ID

# Pull the bug first bug
bug = bugs.get(:ids => bid)['bugs'].first

# Pull the first comment from the bug specified on the command line
comment = bugs.comments(:ids => [bid])['bugs'][bid]['comments'][0]['text']

# We used to block the original bug on the clam bug, but rulesUI and our present workflow makes this unwieldy as snort bugs get closed and committed before
# clam bugs therefore making the clam bug depends on the snort bug now
(bug['component'] =~ /^ClamAV/i) ? depends = '' : depends = bug['id']

# Create the duplicate bug, with the intial first comment of the original bug.
clam_bug = bugs.create(
   {
      :product     => 'Research',
      :component   => 'ClamAV Signatures',
      :summary     => "[CLAMAV] #{bug['summary']}",
      :version     =>	'No Version Specified',
      :description =>	"+++ This bug was initially created as a clone of Bug \##{bid} +++\n\n#{comment}",
      :depends_on  =>	 depends,
      :assigned_to => ENV['BUGZILLA_USER'] + "@cisco.com",
      :groups => bug['groups'],
   },
)

puts "ClamAV bug created: https://#{BUGZILLA_HOST}/show_bug.cgi?id=#{clam_bug['id']}"

# If depends isn't empty and we are using the McBee environment, then do the symlinking.  Otherwise, don't.
if depends.is_a? Integer and MCBEE_ENV
  bdir = ENV['BUGZILLA_DIR'] + "/#{bid}"
  sdir = ENV['BUGZILLA_DIR'] + "/#{clam_bug['id']}"

  begin
    File.symlink(bdir, sdir) if File.directory? bdir
  rescue => e
    abort "ERROR: #{e.message}"
  end
  puts "Created symlink: #{bdir} -> #{sdir}"
end
