#!/usr/bin/env ruby

require 'pp'
require 'yaml'
require 'cgi'
require 'sfbugzilla'
require 'term/ansicolor'
include Term::ANSIColor

# If it's a TTY default to colorized output.  If it's not, don't colorize anything.
Term::ANSIColor::coloring = STDOUT.isatty

class String
  def hline
    tty_size = ( %x{stty size | cut -d" " -f2}.to_i - 2 )
    print "+"
    print self.bold * tty_size
    puts "+"
  end
end
  
me = File.basename($0)
begin
  @@conf = YAML::load(File.read("#{ENV['HOME']}/.rbug.conf"))
  #@@cookie = File.read "#{ENV['HOME']}/.ruby-bugzilla-cookie.yaml"
  #@@cookie = YAML.load(File.open("#{ENV['HOME']}/.ruby-bugzilla-cookie.yaml").read)
  #pp @@cookie
rescue => e
  abort "ERROR: #{e.message}"
end
  
module BZTools
  class BZTools::BZComments

    attr_accessor :initialize, :bz, :xmlrpc, :bug, :bug_id, :comments, :info, :collect_comment

    def initialize bids, options
      begin
        #@@cookie = YAML::load(File.read("#{ENV['HOME']}/.rbug.conf"))[:bz][:cookie].each_with_value{|host,cookie| puts "YAY: #{cookie}" }
        @bzconf = YAML::load(File.read("#{ENV['HOME']}/.rbug.conf"))[:bz]
      rescue => e
        abort "ERROR: #{e.message}"
      end

      count       = 1          # Bug count in Bugzilla starts at 1
      @@options   = options    # Globalize our options
      @@ycomments = Array.new  # For storing YAML comments
      @@esids     = Array.new  # For storing Snort sids found with --sids
      @@erules    = Array.new  # For storing Snort rules found with --rules
      @@standard  = true       # If this is true, then we will do a normal list.  If --find, --sids, --rules are run this will be false.
      @@comments  = {
        :yaml   => Array.new,
        :find   => Array.new,
        :sids   => Array.new,
        :last   => Array.new,
        :rules  => Array.new,
        :first  => Array.new,
        :stdout => Array.new,
      }

      if @bzconf.key? :cookies and @bzconf[:cookies].key? BUGZILLA_HOST
        @@cookie = @bzconf[:cookies][BUGZILLA_HOST]
      else
        @@cookie = nil
      end

      begin
        # XMLRPC Cookie from .ruby-bugzilla-cookie.yml:
        #
        # bugzilla.sourcefire.com: "Bugzilla_login=416; Bugzilla_logincookie=OBkGb76dt7"
        #user, pass = @@cookie[BUGZILLA_HOST].scan(/Bugzilla_login=(\d+);\s+Bugzilla_logincookie=(\w+)/i)[0]
        #user, pass = @@conf[:cookie][BUGZILLA_HOST].scan(/Bugzilla_login=(\d+);\s+Bugzilla_logincookie=(\w+)/i)[0]

        self.xmlrpc = Bugzilla::XMLRPC.new BUGZILLA_HOST

        self.xmlrpc.instance_variable_get(:@xmlrpc).instance_variable_set(:@cookie, @@cookie)
        self.xmlrpc.login(Bugzilla::User.new(self.xmlrpc))
        self.bz = Bugzilla::Bug.new(self.xmlrpc)

      rescue => e
        abort "ERROR(xmlrpc): #{e.message}"
      end

      bids.each{|bid|

        @bug_id     = bid 
        self.bug_id = bid # Set this for internal usage

        begin
          self.info = self.bz.get_bugs([ bid ])[0] or raise "unable to fetch bug '#{bid}'"
          self.comments = self.bz.comments({ :ids => [ bid ] })["bugs"][bid]["comments"] or raise "bug '#{bid}' has no comments?"
        rescue => e
          abort "ERROR: #{e.message}"
        end
  
        if options[:extract_sids]
            # No consistency .. awesome:
            #
            #  05319: [SID] 24304,24305 THC IPv6 alive6 coverage
            # 105330: [SID] 24295-24300 THC IPv6 exploit6 coverage
            # 105335: [SID] 24301-24303 THC IPv6 fake_mld6 coverage
            # 105763: [SID] 23614 25006 Alexander
          #self.info["summary"].scan(/\[SID\]\s*?[^a-z\x5b\x5d\r\n]+?/i).each{|sid|
          #self.info["summary"].scan(/\[SID\]\s*?(\d+[^a-z\x5b\x5d\r\n]+?)+?\b[a-z\x5b\x5d\r\n]*?/i).each{|sid|
          #self.info["summary"].scan(/\[SID\]\s*?(\d+[,\s\x2d\-]*?\d*?)+?\s[a-z\x5b\x5d\r\n]*?/i).each{|sid|

          #foo = '[SID] 24304, 24305 1234-1239 8912 - 8917 [MSF] CVE-1234-5678 THC IPv6 alive6 coverage'
          #self.info["summary"].scan(/\[SID\]\s*?(\d.+?)\s[^\d]/i).each{|sid|
          #!#foo.scan(/\[SID\]\s*?((\d.+?)\s+?[^,\d\-\]]+?)+/i).each{|sid|

          # Scan the summary line for [SID] ....
          self.info["summary"].scan(/\[SID\]\s*?((\d.+?)\s+?[^,\d\-\]]+?)+/i).each{|sid|
            
            # Lazy cleanup.
            sid[0].gsub! /,\s+?/, ','
            sid[0].gsub! /\s+?\-\s+?/, '-'
            sid[0].gsub! /\s+?/, ','
            sid[0].gsub! /[^\d,\-]/, ''

            #sid[0].gsub(/\s*?\-\s*?/, '-').gsub!(/[,]?\s+/, ',')
            #sids = sid[0].split /,/
            sids = sid[0].split /,/

            sids.each{|i|
              #puts "DOING: #{i}"
              if i.include? '-'
                a, b = i.scan(/(\d+)[^\d]+?(\d+)/)[0]
                a = a.to_i
                b = b.to_i
                #puts "A: #{a} B: #{b}"
                if a < b
                  a.upto(b){|c| @@comments[:sids] << c.to_i unless @@comments[:sids].include? c}
                end
              else
                #@@esids << i.to_i unless @@esids.include? i.to_i
                @@comments[:sids] << i.to_i unless @@comments[:sids].include? i.to_i
              end
            }
            #puts "SIDS: #{sid[0].gsub /\s+/, ','}#" unless @@esids.include? sid
            #@@esids << sid[0] unless @@esids.include? sid
          }
          #print "[SID] "
          #puts @@esids.flatten.sort.uniq.join ','
          #puts @@esids.compact.flatten.uniq.join(',').split.sort.uniq
        end

        #if not options[:first].nil?
        if options[:first]
          collect_comment self.comments.first, :first
        end
  
        # Only print the comment if that number exists in the comments array.
        #if not options[:comments].nil?
        if options[:comments]
          options[:comments].each{|c| collect_comment(self.comments[c], c) if not self.comments[c].nil? }
        end
  
        #if not options[:last].nil?
        #puts "LAST(#{bid}): #{options[:last]}"

        if options[:last]
          #puts "STANDARD(#{@@standard}) -> VERBOSE(#{@@options[:verbose]}) -> LINE(#{__LINE__})"
          collect_comment self.comments.last, :last
        end
  
        # No other specific comments options were specified, so print them all.
        #if options[:first].nil? and options[:last].nil? and options[:comments].nil?
        #if options[:first].nil? and options[:last].nil? and options[:comments].nil?
        if not options[:first] or not options[:last] or not options[:comments]

          # If we called any of the options that print to a file, disable stdout unless --verbose was issued
          #next if not @@standard or not @@standard and @@options[:verbose]
          next if not @@standard or @@options[:verbose]

          self.comments.each_with_index {|c,i|
            #puts "STANDARD(#{@@standard}) -> VERBOSE(#{@@options[:verbose]}) -> LINE(#{__LINE__})"
            self.collect_comment c, i
          }
        end

        #if @@standard or not @@standard and @@options[:verbose]
        if @@standard or @@options[:verbose]
          #puts "PUTS: standard(#{@@standard}) verbose(#{@@options[:verbose]})"
          puts "\n"
          "#".hline
          puts "\n"
        end

        next # --------------------> BREAK OUT -------------------->
        
        #puts @@options[:output]
        #puts "COMMENTS: #{@@ycomments}"

        if @@options[:output] and not @@ycomments.empty?
          output = @@options[:output]

          #puts "DOING OUTPUT: #{output}"
          begin
            File.open(output + "/#{@bug_id}.comments.yml", "w") do |f|
              @@ycomments.each{|c| f.write c }
            end
          rescue => e
            abort "ERROR: #{e.message}"
          end
        end

        next # BREAK OUT

        if not @@ycomments.size and not @@extracted.size
          puts "\n"
          "#".hline
          puts "\n"
        else
          if @@ycomments.size
            puts @@ycomments.to_yaml
            return 0
          elsif @@extracted.size
            puts @@extracted
          end
        end
      }

      #puts "END OF COMMENT LOOP"
      print_comments
    end

    def print_first_now comments
      return if comments.empty?

      pp comments

      bug_id  = self.bug_id
      output  = @@options[:output]
      verbose = @@options[:verbose]

      print_stdout comments

      return

      #puts "PRINT_RULES"
      comments.each{|c|
        cnum = c[:number] # Comment number
        data = "#\n" + "# COMMENT #{c[:number].to_s.rjust(3)}: #{c[:creator]}" + "\n#\n" + c[:comment]

        if output
          #comment_store "#{output}/#{bug_id}-rules.#{cnum}", c[:rules]
          comment_store "#{output}/#{bug_id}-comment-#{cnum}.txt", data

        elsif not verbose
          puts data
        end
      }
    end

    def print_last_now comments
      return if comments.empty?

      bug_id  = self.bug_id
      output  = @@options[:output]
      verbose = @@options[:verbose]

      #puts "PRINT_RULES"
      comments.each{|c|
        cnum = c[:number] # Comment number
        data = "#\n" + "# COMMENT #{c[:number].to_s.rjust(3)}: #{c[:creator]}" + "\n#\n" + c[:comment]

        if output
          #comment_store "#{output}/#{bug_id}-rules.#{cnum}", c[:rules]
          comment_store "#{output}/#{bug_id}-comment-#{cnum}.txt", data

        elsif not verbose
          puts data
        end
      }
    end

    def print_find comments
      return if comments.empty?
      #puts "FIND"

      bug_id  = self.bug_id
      yaml    = @@options[:yaml]
      output  = @@options[:output]
      verbose = @@options[:verbose]

      #puts "PRINT_RULES"
      comments.each{|c|
        cnum = c[:number] # Comment number
        data = "#\n" + "# COMMENT #{c[:number].to_s.rjust(3)}: #{c[:creator]}" + "\n#\n#{c[:comment]}\n\n"

        if output
          #comment_store "#{output}/#{bug_id}-rules.#{cnum}", c[:rules]
          comment_store "#{output}/#{bug_id}-comment-#{cnum}.rules", data
        else
          puts data 
        end
      }
      # If --yaml store this result in YAML
      if yaml
        @@comments.keys.each{|key|
          next if key == :yaml
          #puts "PROCESSING: #{key}"
          @@comments[key].each{|c|
            puts c.eval
          }
        }
      end
      #@@comments[:yaml][:find] << c if yaml

      #if not verbose
        # Enable verbose output real quick to print this comment out
      #  @@options[:verbose] = true
      #  print_stdout comments
      #  @@options[:verbose] = false
      #end
    end

    def print_sids comments
      #puts "PRINT_SIDS"
      return if comments.empty?

      bug_id  = self.bug_id
      output  = @@options[:output]
      verbose = @@options[:verbose]
      sids    = @@comments[:sids]

      sids = sids.map{|sid| sid.to_i if sid.to_i != 0}.sort.compact.uniq.join ','
      #puts "SIDS: #{sids}"
    end

    def print_rules comments
      return if comments.empty?

      bug_id  = self.bug_id
      output  = @@options[:output]
      verbose = @@options[:verbose]

      #puts "PRINT_RULES"
      comments.each{|c|
        cnum = c[:number] # Comment number
        data = "#\n" + "# COMMENT #{c[:number].to_s.rjust(3)}: #{c[:creator]}" + "\n#\n" + c[:rules]

        if output
          #comment_store "#{output}/#{bug_id}-rules.#{cnum}", c[:rules]
          comment_store "#{output}/#{bug_id}-comment-#{cnum}.rules", data

        elsif not verbose
          puts data
        end
      }
    end

    def print_yaml
      bug_id  = self.bug_id
      output  = @@options[:output]
      verbose = @@options[:verbose]
      yaml    = @@comments[:yaml].flatten.to_yaml

      if output
        comment_store "#{output}/#{bug_id}-comments.yml", yaml

      elsif not verbose
        puts yaml.to_yaml
      end
    end

    def comment_store file, data
      begin
        File.open(file, "w").write data
      rescue => e
        abort "ERROR(comment_store): #{e.message}"
      end
      return 0
    end

    def print_stdout comments, type=:stdout
      #return unless @@standard or not @@standard and @@options[:verbose]
      
      #puts "## print_stdout #{@@standard}, #{@@options[:verbose]}, #{type}"

      unless [ :first, :last, :comment ].include? type
        return unless @@standard or @@options[:verbose]
      end

      #puts "## PRINT_STDOUT"
      #self.comments.each{|c|
      # h.sort_by {|k,v| v}.reverse
      @@comments[type].each_with_index{|c,i|
        if type == :last
          count = self.comments.size - 1
        elsif type == :first
          count = 1
        else
          count = i
        end
        #count = self.comments.size if type == :last
        #count = 1 if type == :first
        
        creator = c["creator"]
        time    = c["time"].to_time.localtime.to_s
        text    = c["text"]
        bid     = c["bug_id"].to_s
  
        "-".hline
        print "|".ljust(4).bold
        print bid.green.ljust(25)
        print creator.yellow.ljust(45).red
        print time.green.ljust(35).red
        puts "Comment #{count}".rjust(15).red
        "-".hline
      
        print "|".ljust(4).bold
        puts self.info["summary"].bold
        "-".hline
      
        puts "\n\n"
        puts " ".ljust(2) + text.gsub(/\n/, "\n\s\s") + "\n\n\n"
        "-".hline
        puts "\n"
      } 
      #count += 1
    end

    alias print_first print_stdout
    alias print_last  print_stdout

    def print_comments
      @@comments.keys.each{|key|
        next unless @@comments[key].size  # Empty, skip it.
        next if key == :yaml              # Don't process :yaml, we are about to store stuff there.

        # If --yaml, process every type of comment that was stored and convert it to YAML
        @@comments[:yaml] << @@comments[key] if @@options[:yaml]

        #puts "KEY: #{key} -> #{key.class} -> #{@@comments[key].class} -> #{@@comments[key].size}"

        if [ :first, :last, :comment ].include? key
          self.send("print_#{key.to_s}", @@comments[key], key)
        else
          self.send("print_#{key.to_s}", @@comments[key])
        end

        #print_find  @@comments[key] if key == :find
        #print_sids  @@comments[key] if key == :sids
        #print_yaml  @@comments[key] if key == :yaml
        #print_rules @@comments[key] if key == :rules
        #pp @@comments[key]
        #puts "-"*50
      }

      print_yaml if @@options[:yaml]

      #pp @@comments

      return

      @@comments.each{|key|
        pp key
        puts key.class
        next
        next if @@comments[key].blank?

        puts "#{key}: #{@@comments[key].size}"
        if key == :sids
          puts @@comments[key].flatten.sort.uniq.join ','
        elsif key == :sids
          puts @@comments[key]
        elsif key == :rules
          puts @@comments[key]
        end
      }
    end

    def collect_yaml
      return unless @@options[:yaml]
      @@comments[:yaml] << c.to_yaml
    end

    def collect_comment c, count

      # Types we want to group together as far as handling, default is nil
#      types = [ :first, :last ]
#      type  = nil
#
#
#      # Set up some things to handle the --first and --last options
#      if count == :first
#        @@standard = false
#        
#        # So we can reference if count was --first or --last later.
#        type = :first
#
#        # Set up the proper comment index number for the --first
#        count = 1
#
#      elsif count == :last
#        @@standard = false
#
#        # So we can reference if count was --first or --last later.
#        type = :last
#
#        # Set up the proper comment index number for the --last
#        count = self.comments.size
#      end
#      
      # Set up some convenient variables to make the processing easier
      creator = c["creator"]
      time    = c["time"].to_time.localtime.to_s
      text    = c["text"]
      bid     = c["bug_id"].to_s

      # These will be true if their related --argument was issued
      skip    = @@options[:skip]
      mine    = @@options[:mine]
      find    = @@options[:find]
      yaml    = @@options[:yaml]
      last    = @@options[:last]
      first   = @@options[:first]
      output  = @@options[:output]
      verbose = @@options[:verbose]

      extract_sids  = @@options[:extract_sids]
      extract_rules = @@options[:extract_rules]

      # Lets do some checks to see if we need to print out this comment or skip it for some reason.
      #
      # If :mine is false, the user doesn't want their comments.
      # If creator and BUGZILLA_USER match, that's our queue to bail out.
      #if not @@options[:mine] and not ENV["BUGZILLA_USER"].empty? and c["creator"] == ENV["BUGZILLA_USER"]
      return if not mine and not ENV["BUGZILLA_USER"].empty? and creator == ENV["BUGZILLA_USER"]

      # If the Regexp matchs on creator or the in the comment body, skip it.
      return if creator =~ skip or text =~ skip


      # Since --first and --last are pretty easy to figure out, we'll handle them
      # the same way.
      if [ :first, :last ].include? count
        @@standard = false
        (count == :first) ? number = 1 : number = self.comments.size - 1
        @@comments[count] << c
        #@@comments[count] << { :creator => creator, :number => number, :comment => text }
      # FIX THIS --comment crap
      #elsif count.is_a? Integer
      #  @@comments[count] << c
      end

      # YAML stuffs goes right cheer
      if yaml
        @@standard = false
      end

      # See if we can find any Snort rules in the comment body and join it together on one line.
      # This should hopefully make the committer's job easier when combined with automatically
      # generating output files with the rules found in each comment.
      if extract_rules
        @@standard = false

        #erules = Array.new
        # Try and gobble up any Snort rules out of the comment body.
        text.scan(/((alert|drop)\s+?(tcp|udp|icmp|ip)\s[^(].+?\([^(]+?\s*?\x3b\s*?\))+?/i).each{|rule|
          data = { :creator => creator, :number => count, :rules => rule[0] }
          @@comments[:rules] << data

          # Collect a YAML version of this comment if this is set.
          #collect_yaml data
        }

        #erules.each{|match|
        #  puts "#\n" + "# COMMENT #{match[:comment].to_s.rjust(3)}: #{match[:creator]}" + "\n#\n"
        #  puts match[:match] + "\n\n"
        #}

        #@@erules << erules
        #erules.each{|rule| puts "#{rule}\n\n" } unless erules.empty?
        #puts "#{erules[0]}\n\n" unless erules.empty?
      end

      # Were there any previous committer rule commits/sids generated?
      if extract_sids
        @@standard = false
        esids = Array.new

        #
        # sid(rev) msg:
        # 24446(1) "EXPLOIT EMC NetWorker SunRPC format string attempt"
        text.scan(/sid\(rev\)\s+msg:[^\d]*?(\d+)\(\d+\)\s+\x22[^\x22]+?\x22/i).each{|sid|
          #@@extracted << { :type => :sids, :comment => count, :match => sids[0] }
          #puts "SIDS: #{sid[0]}!" unless @@esids.include? sid[0]
          #esids << sid[0] unless @@esids.include? sid[0]
          @@comments[:sids] << sid[0] unless @@comments[:sids].include? sid[0]
          
          # Collect a YAML version of this comment if this is set.
          #collect_yaml sid[0]
        }

        #puts esids.sort.uniq.join(",") unless esids.empty?
        #@@esids << esids.sort.uniq.join(",") unless esids.empty?
        #@@esids << esids.sort.uniq unless esids.empty?
        #pp esids if not esids.empty?
      end


      # If the user specified --find REGEX see if we can find a match in:
      #   1. creator (user@sourcefire.com)
      #   2. comment body
      if find
        @@standard = false
        efind = Array.new
        found = false

        begin
          #puts "FIND: #{creator} -> #{find}"
          creator.scan(find).each{|match|
            @@comments[:find] << { :creator => creator, :number => count, :comment => text }
            found = true
          }

          # We didn't match on the 
          if not found
            text.scan(find).each{|match|
              #puts "FIND: text -> #{find}"
              #@@extracted << { :type => :find, :comment => count, :match => match[0] }
              @@comments[:find] << { :creator => creator, :number => count, :comment => text }
              #efind << match[0]
            }
            #pp efind if efind
          end
        rescue => e
          abort "ERROR(find): #{e.message}"
        end
      end

      @@comments[:stdout] << c # Collect all comments in case we do a stdout print

      return # BREAK OUT

      return unless @@standard or @@options[:verbose]

      "-".hline
      print "|".ljust(4).bold
      print bid.green.ljust(25)
      print creator.yellow.ljust(45).red
      print time.green.ljust(35).red
      puts "Comment #{count}".rjust(15).red
      "-".hline
    
      print "|".ljust(4).bold
      puts self.info["summary"].bold
      "-".hline
    
      puts "\n\n"
      puts " ".ljust(2) + text.gsub(/\n/, "\n\s\s") + "\n\n\n"
      "-".hline
      puts "\n"
    
      #count += 1
    end
    
    # EOF
    #{"bugs"=>
    #  {"106403"=>
    #    {"comments"=>
    #      [{"is_private"=>false,
    #        "creator"=>"alwilliams@sourcefire.com",
    #        "attachment_id"=>77016,
    #        "time"=>
    #         #<XMLRPC::DateTime:0x00000001785bf8
    #          @day=13,
    #          @hour=12,
    #          @min=59,
    #          @month=7,
    #          @sec=39,
    #          @year=2012>,
    #        "bug_id"=>106403,
    #        "author"=>"alwilliams@sourcefire.com",
    #        "text"=>
    #         "Created attachment 77016\nFalse Positive PCAP provided from customer.\n\nCustomer submitted a ticket to a review a false positive for SID 23222. \n\n\"It like the signature is designed to detect an embedded java applet with 5 digits as the name, but it also catches on embedded applets that just happen to end in 5 numbers like \"SWApplet_v15_20110804.jar\"\n\nWe did notice a true positive match that was a link to http://v081479.home [dot] net.pl/33256.jar\n\nIt seems like it should be reasonable to request that the signature is revised to match on a \"/\" before the 5 numbers, to ensure its the full file name and not just the ending.\"\n\nSEU: 664",
    #        "id"=>811395},
    #
    
    #
    # [{"status"=>"ASSIGNED",
    #  "summary"=>
    #   "[CLAMAV] CVE-2011-2110 FSC20110614-30 Adobe Flash Player Code Execution",
    #  "id"=>107522,
    #  "severity"=>"normal",
    #  "component"=>"ClamAV Signatures",
    #  "product"=>"Research"}]
    #
    #bug_info = bug.get_bugs([ bid ])
    #comments = bug.comments({ :ids => [ bid ] })["bugs"][bid]["comments"]
    
  end
end

options = {
  :last          => nil,    # Wait for --last
  :first         => nil,    # Wait for --first
  :find          => nil,    # Wait for --find
  :mine          => true,   # By default, print out comments by the user
  :yaml          => false,  # By default turn YAML output off.
  :colors        => true,   # By default turn colors on.
  :output        => false,  # By default turn YAML output off.
  :verbose       => false,  # No comments to start.
  :comments      => nil,    # No comments to start.
  :extract_sids  => false,  # Wait for the user to supply something to find and extract.
  :extract_rules => false,  # Wait for the user to supply something to find and extract.
}
# :mine - If true, print out comments by the user running the script.  Useful with: --extract, --rules, --sids
#options = Hash.new(:comments => nil, :mine => true)
cli = OptionParser.new do |opts|
  opts.banner = "Usage: #{me} <bug number>       # Defaults to using $PWD if no bug number was specified.\n\n"

  #/^(\d+)[,:]?(-?\d+)?[,:]?(\d+)?/
  #opts.on("-c", "--comment N[,N,N,N]", /^[\d,:]+$/, "Print out comment numbers specified by N.  You can specifiy multiple comments separated by commas: --comments 1,2,4,8,16") do |numbers|
  opts.on("-c", "--comment N[,N,N,N]", /^[\d,:]+$/, "Comment numbers separated by commas.") do |numbers|
    #abort "ERROR: --comment can't be used in combination with --first or --last" if not options[:first].nil? or not options[:last].nil?
    options[:comments] = numbers.split(/,/).collect{|n| n.to_i if n.to_i > 0 }
  end

  opts.on("-f", "--first", "Print out the first comment.") do
    options[:first] = true
  end

  opts.on("-l", "--last", "Print out the last comment.") do
    options[:last] = true
  end

  opts.on("-m", "--[no-]mine", "Print out your comments (or not).") do |mine|
    options[:mine] = mine
  end

  opts.separator ""

  opts.on("-F", "--find REGEX", Regexp, "Find comment data matching REGEX. Honors -c, -f, -l") do |find|
    begin
      options[:find] = Regexp.new find
    rescue => e
      abort "ERROR: #{e.message}"
    end
  end

  opts.on("-r", "--rules", "Attempts to extract Snort rules from comments. Honors -c, -f, -l") do
    options[:extract_rules] = true
  end

  opts.on("-s", "--sids", "Attempts to extract Snort sids from comments. Honors -c, -f, -l") do
    options[:extract_sids] = true
  end

  opts.on("-S", "--skip REGEX", Regexp, "Skips comments that REGEX matches in: author, summary, or body.") do |skip|
    begin
      options[:skip] = Regexp.new skip
    rescue => e
      abort "ERROR: #{e.message}"
    end
  end

  opts.separator ""

  opts.on("-n", "--no-colors", "Disable colorized output. See :colors: in .rbug.conf") do
    options[:colors] = false
    Term::ANSIColor::coloring = false
  end

  opts.on("-o DIR", "--output-dir DIR", "Print the resulting output to DIR/COMMENT.TYPE ; TYPES: rules, sids, yaml") do |output|
    begin
      File.stat output
      options[:output] = output
    rescue => e
      abort "ERROR: --output-dir: #{e.message}"
    end
  end

  opts.on("-y", "--yaml", "Print out the comments in YAML format.") do
    options[:yaml] = true
  end

  opts.on_tail("-v", "--verbose", "Prints to STDOUT as well if you used --output-dir") do
    options[:verbose] = true
  end

  opts.on_tail("-h", "--help", "This is it .. you are probably hosed.") do
    $stderr.puts opts
    #$stderr.puts "\n#{me}: Parses YAML files generated by 'bzcomments --yaml' and attempts to extract Snort rules out of comments.\n\n"
    exit 1
  end

end

# Some optparse error catching
begin
  cli.parse!
rescue => e
  $stderr.puts "\nERROR: #{e.message}\n\n"
  ARGV << "--help"
  cli.parse!
  exit 1
end

# If we don't have ARGV[0], try and use the $PWD instead.
begin
  (ARGV[0].nil?) ? bids = [ File.basename(ENV['PWD']) ] : bids = ARGV
rescue => e
  abort "ERROR: #{e.message}"
end


# If :colors: is set in the configuration and --no-colors was not called, set the colorization
# output based on if it's a TTY or not.  If it's a TTY we are already configured for that earlier.
if not @@conf[:bz][:colors].nil? and options[:colors].nil?
  if [ "0", false ].include? @@conf[:bz][:colors]
    Term::ANSIColor::coloring = false
  end
end

abort "ERROR: '#{bids[0]}' does not appear to be a Bugzilla bug directory.  You can specifiy a bug number as the first argument if you'd like: #{me} <bug number>" if bids[0].to_i == 0 and ARGV[0].nil?

bug = BZTools::BZComments.new bids, options

