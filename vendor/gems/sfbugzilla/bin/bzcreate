#!/usr/bin/env ruby

require 'sfbugzilla'
require 'optparse'

options = {
	:product => 'Research',
	:component => 'Snort Rules',
	:version => 'No Version Specified',
   :groups => []
}

attachments = Array.new
comments = Array.new

o = OptionParser.new do |opts|
	opts.on("-p", "--product product", "The bug product.") do |v|
		options[:product] = v
	end
	opts.on("-o", "--component component", "The bug component.") do |v|
		options[:component] = v
	end
	opts.on("-s", "--summary summary", "The bug summary.") do |v|
		options[:summary] = v
	end
	opts.on("-q", "--qa-contact contact", "The QA contact for the bug.") do |v|
		options[:qa_contact] = v
	end
	opts.on("-S", "--assigned_to contact", "The assignee of the bug.") do |v|
		options[:assigned_to] = v
	end
	opts.on("-d", "--description description", "The initial bug description.") do |v|
		options[:description] = v
	end
	opts.on("-w", "--whiteboard whiteboard", "The whiteboard entry for the bug.") do |v|
		options[:status_whiteboard] = v
	end
   opts.on("-V", "--vrt", "Set the VRT Security Bugs group.") do |v|
      options[:groups] << 'Restriction:VRT Security Bugs'
   end
   opts.on("-g", "--group group", "Assign a group to this bug.") do |v|
      options[:groups] << v
   end
	opts.on("-D", "--description-file file", "Use this file for the description.") do |v|
		if File.exists?(v)
			options[:description] = File.read(v)
		else
			puts "The description file #{v} was not found."
		end
	end
	opts.on("-a", "--attachment attachment", "Add file as attachment.") do |v|
		if File.exists?(v)
			attachments << v
		else
			puts "The attachment file #{v} was not found."
		end
	end
	opts.on("-c", "--comment comment", "Add a comment.") do |v|
		comments << v
	end
	opts.on("-C", "--comment-file file", "Add file as comment.") do |v|
		if File.exists?(v)
			comments << File.read(v)
		else
			puts "The comment file #{v} was not found."
		end
	end
   opts.on("-P", "--priority priority", "Set the priority of this bug") do |v|
      options[:priority] = v
   end
end
o.parse!


abort("Summary is required.\n\n#{o}") if options[:summary].nil?

xmlrpc = Bugzilla::XMLRPC.new(BUGZILLA_HOST)
xmlrpc.login(Bugzilla::User.new(xmlrpc))
bug = Bugzilla::Bug.new(xmlrpc)

new_bug = bug.create(options)
puts "Bug created: https://#{BUGZILLA_HOST}/show_bug.cgi?id=#{new_bug['id']}"

attachments.each do |file|
	if bug.attach_file(new_bug['id'], file)
    	puts "#{file} attached to bug #{new_bug['id']}"
    end
end

comments.each do |comment|
	bug.add_comment(:id => new_bug['id'], :comment => comment)
end
