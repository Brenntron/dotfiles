#!/usr/bin/env ruby

require 'sfbugzilla'
require 'optparse'
require 'term/ansicolor'

# If it's a TTY default to colorized output.  If it's not, don't colorize anything.
Term::ANSIColor::coloring = STDOUT.isatty

class String
  include Term::ANSIColor
end

options = {
	'exclude_pcaps'	=> false,
	'filter' => /.*/,
	'output_path' => '.',
	'quiet' => false
}

o = OptionParser.new do |opts|
	opts.on("-o", "--output output_path", "Path to write the downloaded files.") do |v|
		options['output_path'] = v
	end
	opts.on("-p", "--pcaps", "Only download pcaps.") do |v|
		options['filter'] = /\.pcap$/
	end
	opts.on("-e", "--exclude-pcaps", "Do not download pcaps") do |v|
		options['filter'] = /\.(?!pcap).*$/
	end
	opts.on("-f", "--filter filter", "Only download attachments with this file extension") do |v|
		options['filter'] = /\.#{v}$/
	end
  opts.on("-n", "--no-colors", "Disable colorized output.") do
    Term::ANSIColor::coloring = false
  end
	opts.on("-q", "--quiet", "Do not show file messages.") do |v|
		options['quiet'] = v
	end
end
o.parse!
abort("You must specify a bug id.\n\n#{o}") if ARGV.size == 0

xmlrpc = Bugzilla::XMLRPC.new(BUGZILLA_HOST)
xmlrpc.login(Bugzilla::User.new(xmlrpc))
bug = Bugzilla::Bug.new(xmlrpc)

begin
  attachments = bug.attachments(:ids => ARGV, :include_fields => ['file_name', 'id', 'last_change_time', 'is_obsolete'])['bugs'].map do |bugid, attachments|
     	attachments.map do |attachment|
     		file_path = "#{options['output_path']}/#{attachment['file_name']}" 
  
        	if attachment['is_obsolete'] == 1
        		puts "Skipping obsolete file #{attachment['file_name']}".red unless options['quiet']
        	elsif attachment['file_name'] !~ /#{options['filter']}/
        		puts "Skipping filtered #{attachment['file_name']}".yellow unless options['quiet']
        	elsif File.exists?(file_path) && (attachment['last_change_time'].to_time < File.ctime(file_path))
        		puts "Skipping existing file #{attachment['file_name']}".red unless options['quiet']
        	else
        		puts "Fetching #{attachment['file_name']}".green unless options['quiet']
        		attachment
        	end
     	end
  end
  
  if attachments.flatten.compact.size > 0
  	begin
  		Dir.mkdir(options['output_path'])
  	rescue Errno::EEXIST => e
  		# Ignore
  	end
  	
  	bug.fetch_attachments(attachments.flatten.compact, options['output_path'])
  end
rescue => e
  abort "ERROR: #{e.message}"
end
