#!/usr/bin/env ruby

require 'pp'
require 'sfbugzilla'
require 'term/ansicolor'

me = File.basename($0)
(ARGV[0].to_i == 0) ? bid = File.basename(ENV['PWD']) : bid = ARGV[0]

abort "ERROR: '#{bid}' does not appear to be a Bugzilla bug directory.  You can specifiy a bug number as the first argument if you'd like: #{me} <bug number>" if bid.to_i == 0

xmlrpc = Bugzilla::XMLRPC.new(BUGZILLA_HOST)
xmlrpc.login(Bugzilla::User.new(xmlrpc))
bz = Bugzilla::Bug.new(xmlrpc)

bug = bz.get(bid)["bugs"][0]
bug_comments = bz.comments({ :ids => [ bid ] })["bugs"][bid]["comments"]
bug_attachments = bz.attachments({ :ids => [ bid ] })["bugs"][bid]

summary = bug["summary"]
status = bug["status"]
status += " -> " + bug["resolution"] unless bug["resolution"].empty?
assigned_to = bug["assigned_to"]
qa_contact = bug["qa_contact"]
dupe_of = bug["dupe_of"].to_s unless bug["dupe_of"].nil?
blocks = bug["blocks"].join(", ") unless bug["blocks"].empty?
depends_on = bug["depends_on"].join(", ") unless bug["depends_on"].empty?
product = bug["product"] unless bug["product"].nil?
component = bug["component"] unless bug["component"].nil?

puts "\n\n"
puts "Summary: ".rjust(15) + summary
puts "Status: ".rjust(15) + status
puts "Product: ".rjust(15) + product unless product.nil?
puts "Component: ".rjust(15) + component unless component.nil?
puts "Assigned to: ".rjust(15) + assigned_to
puts "QA contact: ".rjust(15) + qa_contact
puts "Duplicate of: ".rjust(15) + dupe_of unless dupe_of.nil?
puts "Depends on: ".rjust(15) + depends_on unless depends_on.nil?
puts "Blocks: ".rjust(15) + blocks unless blocks.nil?
puts "Comments: ".rjust(15) + bug_comments.size.to_s + " (Last comment: #{bug_comments[-1]['time'].to_time.localtime.to_s})"

if bug_attachments.size > 0
  count = 1
  # Display the attachment
  puts "Attachments: ".rjust(15) + bug_attachments.select {|a| a["is_obsolete"].to_i == 0 }.size.to_s + " (total: " + bug_attachments.size.to_s + ", obsolete: " + bug_attachments.select {|a| a["is_obsolete"].to_i == 1 }.size.to_s + ")"
  puts " ".ljust(15) + "-".ljust(108, "-")

  puts "##  ".rjust(19) + "Attachment".ljust(64) + "Content Type".ljust(32) + "Attacher"
  puts "--  ".rjust(19) + "----------".ljust(64) + "------------".ljust(32) + "--------"

  bug_attachments.each { |a|
    # Prune out all of the obsolete attachements
    puts " ".ljust(15) + count.to_s.rjust(2, "0") + ".".ljust(2) + a["description"].ljust(64) + a["content_type"].ljust(32) + a["attacher"] unless a["is_obsolete"].to_i == 1
    count += 1
  }

end
puts "\n\n"

exit 0
