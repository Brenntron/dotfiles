#!/usr/bin/env ruby

require 'sfbugzilla'

me = File.basename($0)
abort "usage: #{me} 'Search string'\n\nExample: #{me} 2012-0150\n\n" if ARGV[0].nil?

xmlrpc = Bugzilla::XMLRPC.new(BUGZILLA_HOST)
user = Bugzilla::User.new(xmlrpc)
bz = Bugzilla::Bug.new(xmlrpc)
user.session(nil, nil) {}

found = {}

puts "SEARCHING: #{ARGV}\n\n"
bugs = bz.search(:product => 'Research', :component => [ 'Malware', 'Snort Rules', 'SO Rules', 'ClamAV Signatures' ], :summary => ARGV)['bugs']

bugs.each do |bug|
  bid = bug['id']
  found[bid] = bug['summary']
end

found.each do |k,v|
  puts k.to_s.rjust(6) + ": " + v
end
puts

