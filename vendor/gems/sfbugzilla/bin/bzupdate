#!/usr/bin/env ruby

require 'sfbugzilla'
require 'optparse'

options = {
  :ids => []
}

attachments = Array.new

o = OptionParser.new do |opts|
  opts.on("-b", "--bug bug", "The bug to update.") do |v|
    options[:ids] << v
  end
  opts.on("-p", "--product product", "The bug product.") do |v|
    options[:product] = v
  end
  opts.on("-o", "--component component", "The bug component.") do |v|
    options[:component] = v
  end
  opts.on("--summary summary", "Update the bug summary") do |v|
    options[:summary] = v
  end
  opts.on("-s", "--status status", "The bug status.") do |v|
    options[:status] = v
  end
  opts.on("-r", "--resolution resolution", "The bug resolution.") do |v|
    options[:resolution] = v
  end
  opts.on("-q", "--qa-contact contact", "The QA contact for the bug.") do |v|
    options[:qa_contact] = v
  end
  opts.on("-S", "--assigned_to contact", "The assignee of the bug.") do |v|
    options[:assigned_to] = v
  end
  opts.on("-d", "--depends-on bug", "Make this bug dependent on another bug.") do |v|
    if options[:depends_on].nil?
      options[:depends_on] = {:add => []}
    end
    options[:depends_on][:add] << v
  end
  opts.on("--remove-depends bug", "Remove the dependency against this bug.") do |v|
    if options[:depends_on].nil?
      options[:depends_on] = {:remove => []}
    end
    options[:depends_on][:remove ] << v
  end
  opts.on("-B", "--blocks bug", "Make this bug block another bug.") do |v|
    if options[:blocks].nil?
      options[:blocks] = {:add => []}
    end
    options[:blocks][:add] << v
  end
  opts.on("--remove-blocks bug", "Remove the block from this bug.") do |v|
    if options[:blocks].nil?
      options[:blocks] = {:remove => []}
    end
    options[:blocks][:remove ] << v
  end
  opts.on("-V", "--vrt", "Set the VRT Security Bugs group.") do |v|
    options[:groups] ||= {}
    options[:groups][:add] ||= []
    options[:groups][:add] << 'Restriction:VRT Security Bugs'
  end
  opts.on("-g", "--add-group group", "Assign a group to this bug.") do |v|
    options[:groups] ||= {}
    options[:groups][:add] ||= []
    options[:groups][:add] << v
  end
  opts.on("-G", "--remove-group group", "Assign a group to this bug.") do |v|
    options[:groups] ||= {}
    options[:groups][:remove] ||= []
    options[:groups][:remove] << v
  end
  opts.on("-D", "--duplicate bug", "Mark the bug as a duplicate.") do |v|
    options[:dupe_of] = v
  end
  opts.on("-P", "--priority priority", "Set the priority of this bug") do |v|
    options[:priority] = v
  end
  opts.on("-a", "--attachment attachment", "Add file as attachment.") do |v|
    if File.exists?(v)
      attachments << v
    else
      puts "The attachment file #{v} was not found."
    end
  end
  opts.on("-w", "--whiteboard entry", "Update whiteboard entry.") do |v|
    options[:status_whiteboard] = v
  end
  opts.on("-c", "--comment comment", "Add a comment.") do |v|
    if options[:comment].nil?
      options[:comment] = {}
    end

    # Try and remove any of the non-ascii printable range so REXML doesn't croak when listing bugs/comments
    options[:comment][:body] = v.to_s.force_encoding("UTF-8").gsub(/[^\r\n\s\x20-\x7e]/, '??')
  end
  opts.on("-C", "--comment-file file", "Add file as comment.") do |v|
    if File.exists?(v)
      if options[:comment].nil?
        options[:comment] = {}
      end

      # Try and remove any of the non-ascii printable range so REXML doesn't croak when listing bugs/comments
      options[:comment][:body] = File.read(v).force_encoding("UTF-8").gsub(/[^\r\n\s\x20-\x7e]/, '??')
    else
      puts "The comment file #{v} was not found."
    end
  end
end
o.parse!

if options[:ids].empty? && ARGV.size > 0
  options[:ids] = ARGV
end

abort("Bug is required.\n\n#{o}") if options[:ids].empty?

xmlrpc = Bugzilla::XMLRPC.new(BUGZILLA_HOST)
xmlrpc.login(Bugzilla::User.new(xmlrpc))
bug = Bugzilla::Bug.new(xmlrpc)

begin
  bug.update(options)
rescue => e
  $stderr.puts "ERROR: #{e.message}"
end

attachments.each do |file|
  begin

    # We will need the MD5 of this file
    md5 = Digest::MD5.hexdigest(File.read(file))

    # Check to see if this is a duplicate attachment
    comments = bug.comments({ :ids => options[:ids], :include_fields => ['attachment_id', 'text'] })["bugs"][options[:ids].first]["comments"]

    # Check each comment looking for the listed MD5
    comments.each do |comment|
      next if comment['attachment_id'].nil? 

      # Next search for the MD5 in the text of the comment
      raise Exception.new("Duplicate attachment: #{file} - #{comment['attachment_id']}") if comment['text'].include?(md5)

    end

    # If we have made it this far, we are safe to attach the file
    bug.attach_file(options[:ids], file)

  rescue Exception => e
    $stderr.puts "ERROR: #{e.message}"
  end
end
